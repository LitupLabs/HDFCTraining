  <decision name="numOfLiveTrades" id="_128C5AD2-131F-45BD-9E42-F48C519D97B5">
    <variable name="numOfLiveTrades" id="_907EEACD-DC6F-4B40-A3CC-D2DAE68ED782" typeRef="number" />
    <informationRequirement id="_4601282E-E266-49C4-9F98-FE218DF1980A">
      <requiredInput href="#_76088C6A-EE2B-4C75-8840-225CDEA3974B" />
    </informationRequirement>
    <literalExpression id="_1A61401A-ECFB-464C-A149-BA2B8793CD4F" typeRef="number" label="numOfLiveTrades">
      <text>
count(
  Raw Input.applicant.tbl_tradelines[
      tl_closed_date = &quot;01/01/1900 00:00:00&quot;
      or tl_closed_date = &quot;null&quot;
      or tl_closed_date = null
      or tl_closed_date = &quot;&quot;
  ]
)
</text>
    </literalExpression>
  </decision>
