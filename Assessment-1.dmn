    <context id="_88E3A2B4-6813-43A4-88BD-A27FD3A25DA8" typeRef="number" label="noOfLiveTrades">
      <contextEntry id="_2D409294-C2D7-4C73-BFC2-FEEDE78C6A5C">
        <variable id="_11E4387E-6539-4DA4-BB6E-FD6B7A86C021" name="for_loop" typeRef="trade" />
        <for id="_C31E5D94-8A1B-420C-B6E9-590E713A825C" typeRef="trade" label="for_loop" iteratorVariable="i">
          <in id="_62D914B7-B737-48A4-92D6-DFEE5F2AEB01">
            <literalExpression id="_4DF8F4F9-6E3B-4F27-AFDF-AC6CA7483470" label="Expression Name">
              <text>Tradeline</text>
            </literalExpression>
          </in>
          <return id="_E57FC725-C190-4C19-AB5D-05CD8DF7C46E">
            <literalExpression id="_7D66D33C-5A9A-4A07-8568-AC8B75B22931" label="Expression Name">
