  <businessKnowledgeModel name="cntOfUnsecTrades" id="_6FCC0131-CBB5-4F2F-9507-CF897DB33794">
    <variable name="cntOfUnsecTrades" id="_84D92B44-DBEF-4157-AA73-B330878F2A8A" typeRef="number" />
    <encapsulatedLogic label="cntOfUnsecTrades" typeRef="number" id="_F47B78F4-2B08-4B6A-83D2-7BFD9666769A" kind="FEEL">
      <formalParameter id="_1B446E92-13B3-4717-AEE5-45F4C454E84E" name="tradeline" typeRef="tradelines_obj" />
      <literalExpression id="_07426670-4B05-402C-9123-FF0481481AC6" typeRef="number" label="Return">
        <text>if tradeline.tl_acct_type = null then 0
else if ((upper case(replace(tradeline.tl_acct_type, &quot; &quot;, &quot;&quot;)) in [&quot;BUSINESSLOAN&quot;,&quot;CONSUMERLOAN&quot;,&quot;EDUCATIONLOAN&quot;,&quot;LOANONCREDITCARD&quot;,&quot;MICROFINANCEHOUSINGLOAN&quot;,&quot;PERSONALLOAN&quot;,&quot;MUDRALOANSSHISHUKISHORTARUN&quot;,&quot;OTHER&quot;,&quot;PRIMEMINISTERJAANDHANYOJANAOVERDRAFT&quot;]) and (tradeline.tl_closed_date in (null, &quot;null&quot;, &quot;&quot;,date(&quot;1900-01-01&quot;))))
then 1
else 0</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
