          <match id="_6768684F-4F73-4592-B07F-FB7567A7C707">
            <literalExpression id="_F8F28667-8D32-4EB5-90A6-7609A1151835" label="Expression Name">
              <text>item in (null, &quot;null&quot;, &quot;&quot;,date(&quot;1900-01-01&quot;))</text>
