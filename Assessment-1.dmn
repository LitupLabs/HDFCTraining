  <decision name="cntOfUnsecureLiveLoan" id="_8E150D1B-4A65-4265-83AD-05D14211B125">
    <variable name="cntOfUnsecureLiveLoan" id="_E0B99138-6630-43D2-BD47-FFF2D62D6312" typeRef="number" />
    <informationRequirement id="_0BE0BA5D-36CD-4972-9205-D3C6CE767BAF">
      <requiredInput href="#_DB087796-1901-408A-A281-BE01DEB628C8" />
    </informationRequirement>
    <knowledgeRequirement id="_323A3D16-1632-4EA6-A86C-ED907463D19C">
      <requiredKnowledge href="#_6FCC0131-CBB5-4F2F-9507-CF897DB33794" />
    </knowledgeRequirement>
    <context id="_80526F20-75F3-409B-80CC-6960B961876E" typeRef="number" label="cntOfUnsecureLiveLoan">
      <contextEntry id="_30351921-1FD2-49FC-AFF8-2DB05ABBBA52">
        <variable id="_A6958683-E35C-4604-A615-DB6E260EE924" name="sumOfUnsecLive" typeRef="trade" />
        <for id="_B5979F00-B31B-4A8B-91DB-32A18EA41606" typeRef="trade" label="sumOfUnsecLive" iteratorVariable="item">
          <in id="_A0AFC9E1-D5B4-45D8-B293-188D10D4ADE6">
            <literalExpression id="_305A1B06-D876-4768-90A9-3CF795E51D92" label="Expression Name">
              <text>Tradeline</text>
            </literalExpression>
          </in>
          <return id="_AA398576-867D-4803-84E9-817C844F875A">
            <literalExpression id="_4445CF1F-9E19-42F4-814A-8F59CB067412" label="Expression Name">
              <text>cntOfUnsecTrades(item)</text>
            </literalExpression>
          </return>
        </for>
      </contextEntry>
      <contextEntry id="_9F71DE3B-1DF8-4DC3-9192-74C7CF72386E">
        <literalExpression id="_93927102-FB4D-4698-A32E-D06D9605EC25" typeRef="number" label="cntOfUnsecureLiveLoan">
          <text>sum(sumOfUnsecLive)</text>
