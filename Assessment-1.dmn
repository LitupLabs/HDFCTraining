      <contextEntry id="_EA83D010-132A-4748-B009-9CD099492A11">
        <variable id="_70E153DC-A113-4BDE-BCB9-16FF417BB29D" name="filtered" typeRef="trade">
          <description></description>
        </variable>
        <filter id="_52638733-1334-4869-A4DE-7DFB5079E174" typeRef="trade" label="filtered">
          <in id="_0B18D9BD-4094-4D67-BF77-28562A3E3688">
            <literalExpression id="_9633588C-CE4C-4B87-B559-318B299632C6" label="Expression Name">
