  <decision name="numOfLiveTrades" id="_BF916CA9-1FBC-4AFF-8217-50FE950B09EE">
    <variable name="numOfLiveTrades" id="_D86D018A-5C90-4728-8A33-71EE8907766D" typeRef="number" />
    <informationRequirement id="_326D29A0-3482-4012-9532-B0B643FC470D">
      <requiredInput href="#_F966A6C0-4D95-46F4-B0A5-1824E5C0293E" />
    </informationRequirement>
    <context id="_5114DACB-AA5E-4656-853C-6D0BFF6F3C51" typeRef="number" label="numOfLiveTrades">
      <contextEntry id="_8C64752A-E2DE-40A2-8B13-6DBE1D4DD3BD">
        <variable id="_F335A368-4CA2-45D8-889B-24CC1D638E66" name="lst_Closeddates" typeRef="lstTrades" />
        <for id="_B8759452-080B-427B-A177-234989D0CA9C" typeRef="lstTrades" label="lst_Closeddates" iteratorVariable="item">
          <in id="_47E8CD7B-5301-4E84-B926-980E30B3B619">
            <literalExpression id="_0DE2C69D-2554-4260-8C58-945581BAAE33" label="Expression Name">
              <text>tbl_tradelines</text>
            </literalExpression>
          </in>
          <return id="_297B7721-6F43-4745-BAD0-D7D34E12CD88">
            <literalExpression id="_FA0870E4-BBF9-4598-ABD9-BC42CAF8F6C6" label="Expression Name">
              <text>item.tl_closed_date</text>
            </literalExpression>
          </return>
        </for>
      </contextEntry>
      <contextEntry id="_3636B966-EE95-49D8-A052-7FF29E3BF780">
        <variable id="_F543269B-1D7B-441A-89F9-26A481AF1E2A" name="filtered_List_Closeddates" typeRef="lstTrades">
          <description></description>
        </variable>
        <filter id="_3E17E54F-3F5F-4DCE-A9E9-109C80917130" typeRef="lstTrades" label="filtered_List_Closeddates">
          <in id="_48A04A8B-76EB-404C-A6A4-EDCC9FE3721D">
            <literalExpression id="_A165B06F-4A8D-4A91-8FEE-A78BB26B4149" label="Expression Name">
              <text>lst_Closeddates</text>
            </literalExpression>
          </in>
          <match id="_BD374D0F-6D4A-40CC-BC00-D406AAB9F791">
            <literalExpression id="_899F6DBF-6F8B-4468-AE13-83A0F36070E3" label="Expression Name">
              <text>not(item in (null, &quot;null&quot;, &quot;&quot;,date(&quot;1900-01-01&quot;)))</text>
            </literalExpression>
          </match>
        </filter>
      </contextEntry>
      <contextEntry id="_B9B91FCE-F4D1-43D4-B0D6-DEC06CFFF444">
        <literalExpression id="_394FBD17-2D54-494E-B421-E392E2271774" typeRef="number" label="num_Livetrades">
          <text>count(filtered_List_Closeddates)</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
  <decision name="totalBureauOverDue" id="_6945DFE3-629A-40C5-BF86-A04FFA4DC0EF">
    <variable name="totalBureauOverDue" id="_9AEC8EA9-C1E4-46EF-95F5-2F89BF5B7534" typeRef="number" />
    <informationRequirement id="_9C875A26-430A-411C-9FB1-DBD44ED850FC">
      <requiredInput href="#_F966A6C0-4D95-46F4-B0A5-1824E5C0293E" />
    </informationRequirement>
    <context id="_CFB4AF0B-A993-42ED-A17C-FE54F1BD6FF4" typeRef="number" label="totalBureauOverDue">
      <contextEntry id="_F82633B7-5BD9-44ED-8D1D-E947CC862E18">
        <variable id="_68E99FEB-9058-4BCF-9B40-7C0AF437556E" name="lstOverdue" typeRef="lstTrades" />
        <for id="_622B10EB-7739-4B93-9F1F-D881C134041C" typeRef="lstTrades" label="lstOverdue" iteratorVariable="item">
          <in id="_9E0D96B3-180D-4165-8B7B-17E0D6EEC975">
            <literalExpression id="_9466D9FB-DF0B-4930-A535-3B60B32D56CD" label="Expression Name">
              <text>tbl_tradelines</text>
            </literalExpression>
          </in>
          <return id="_7014ABB5-EC48-4073-AFCA-739F8C381CF9">
            <literalExpression id="_E83E2B34-555C-4B31-9325-FB9A56C18894" label="Expression Name">
              <text>if item.tl_overdue_amount = null then 0 else item.tl_overdue_amount</text>
            </literalExpression>
          </return>
        </for>
      </contextEntry>
      <contextEntry id="_C0FE80E3-6B59-4A7E-B67C-DCF6130393EC">
        <literalExpression id="_687EB0F7-96CC-48C9-A19F-9A99D1E11335" typeRef="number" label="totalBureauOverDue">
          <text>sum(lstOverdue)</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
