  <decision name="numOfLiveTrades" id="_9B2BE6A9-AC9E-4856-8C6C-6FE714F29182">
    <variable name="numOfLiveTrades" id="_B5F23F76-9D8A-4233-AA79-55E3875E640D" typeRef="number" />
    <informationRequirement id="_A376DE78-98F6-42E6-8F35-0E925734C594">
      <requiredInput href="#_532304C2-97F7-4368-995B-3F90BA449C77" />
    </informationRequirement>
    <context id="_0E717D6C-3DF5-4EFD-85EF-EADFC6130FB8" typeRef="number" label="numOfLiveTrades">
      <contextEntry id="_D16F1E75-16F8-48C7-81A9-B2B4AAF98AA0">
        <variable id="_1EFEBE78-5F0F-4276-84FC-BAA82A603803" name="closedDates_tbl" typeRef="trade_table" />
        <for id="_68F2E7F5-D0EF-483C-A438-E71D983A5810" typeRef="trade_table" label="closedDates_tbl" iteratorVariable="item">
          <in id="_57BD2ECB-B29B-4927-876F-CB7291CA2DAC">
            <literalExpression id="_CFF9D174-8C91-4047-9FBC-9AD2E6EAD0D0" label="Expression Name">
              <text>tbl_tradelines</text>
            </literalExpression>
          </in>
          <return id="_4C23FB92-0968-4CCA-B0A9-5807DC2C8A75">
            <literalExpression id="_CFA41139-248C-4D8E-AECE-38631D9B2FF0" label="Expression Name">
              <text>item.tl_closed_date</text>
            </literalExpression>
          </return>
        </for>
      </contextEntry>
      <contextEntry id="_66312DA7-4934-4601-B9B5-D651120B56A1">
        <variable id="_462AD115-20FA-4582-BB71-0449AF97D81F" name="closedDate_filter" typeRef="trade_table">
          <description></description>
        </variable>
        <filter id="_CFCE422D-E0B8-4EF6-8A9A-7A37D4757B7B" typeRef="trade_table" label="closedDate_filter">
          <in id="_E2A753A4-FCE6-49C5-BF18-19D9B65A7C07">
            <literalExpression id="_3AE4F671-EA01-4CB0-85A4-CE6F4360C203" label="Expression Name">
              <text>closedDates_tbl</text>
            </literalExpression>
          </in>
          <match id="_202E9746-B4D6-4947-B862-78A3BB5523D8">
            <literalExpression id="_66F543B6-2772-4C38-9F72-43EFB146B90B" label="Expression Name">
              <text>not(item in (null, &quot;null&quot;, &quot;&quot;,date(&quot;1900-01-01&quot;)))</text>
            </literalExpression>
          </match>
        </filter>
      </contextEntry>
      <contextEntry id="_CE67AF2C-2B4B-46CE-8098-4E78069501F5">
        <literalExpression id="_67331BAD-E5C1-43F4-8D96-589855672800" typeRef="number" label="numOfLiveTrades">
          <text>count(closedDate_filter)</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
  <decision name="totalBureauOverDue" id="_E89034CF-8E0C-400A-9CA0-B8335D800A31">
    <variable name="totalBureauOverDue" id="_45B2AD32-ECF1-47F7-84E0-566A083492CC" typeRef="number" />
    <informationRequirement id="_A4FD1168-67E7-4DAE-BB1E-89897E088B8D">
      <requiredInput href="#_532304C2-97F7-4368-995B-3F90BA449C77" />
    </informationRequirement>
    <context id="_35C9A3FD-3C8A-4D09-9CD9-251A23FE7B54" typeRef="number" label="totalBureauOverDue">
      <contextEntry id="_AC356596-6737-48A4-AC64-A03843576C07">
        <variable id="_E1C5C943-6515-4248-A2A0-76F384BCA71F" name="overdue_table" typeRef="trade_table" />
        <for id="_F3F79FE7-7D68-42F7-8CC1-7749603D16F2" typeRef="trade_table" label="overdue_table" iteratorVariable="item">
          <in id="_ECABE191-7D5E-4474-88AC-9301271DBD4F">
            <literalExpression id="_DA46C213-5343-489F-8FDD-1F28B6B4E1C1" label="Expression Name">
              <text>tbl_tradelines</text>
            </literalExpression>
          </in>
          <return id="_E12A3D4B-4E28-434E-B31C-9F4C64834365">
            <literalExpression id="_7DC01D57-770B-436E-9D11-A47325E7AFDE" label="Expression Name">
              <text>if item.tl_overdue_amount = null then 0 else item.tl_overdue_amount</text>
            </literalExpression>
          </return>
        </for>
      </contextEntry>
      <contextEntry id="_8B9980CE-0749-46FC-B1A8-E31B1C76791C">
        <literalExpression id="_FE33C0ED-ABAD-4554-BF1F-C6E26CB16696" typeRef="number" label="totalBureauOverDue">
          <text>sum(overdue_table)</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
  <decision name="cntOfUnSecureLiveLoan" id="_FE4A242A-895C-45EE-82F2-1189CBB3B3DD">
    <variable name="cntOfUnSecureLiveLoan" id="_E00422D3-47DF-4573-BBB8-79B29CC9C309" typeRef="number" />
    <informationRequirement id="_8AD1F9F7-537B-4FC9-AB1B-3F63988F1D3B">
      <requiredInput href="#_532304C2-97F7-4368-995B-3F90BA449C77" />
    </informationRequirement>
    <knowledgeRequirement id="_01D3C033-A9BC-4D03-8496-B17146767FD7">
      <requiredKnowledge href="#_5D3CFB38-F380-4949-B0EA-B6C2E5291E76" />
    </knowledgeRequirement>
    <context id="_1EEB856C-AAE5-4876-ABD9-ABF060ACC32F" typeRef="number" label="cntOfUnSecureLiveLoan">
      <contextEntry id="_A9152C1A-B264-4FD5-A50E-79BB4D9E6993">
        <variable id="_AA2D45F2-52F1-435D-8103-B585C4010078" name="unsecLoan_fetch" typeRef="trade_table" />
        <for id="_2275C5B2-0F61-4DB2-B076-50DC349CF9F6" typeRef="trade_table" label="unsecLoan_fetch" iteratorVariable="item">
          <in id="_A30E28CB-8115-421B-975F-B30E3C6916B7">
            <literalExpression id="_8F23B392-0BC7-4916-A562-4B9213934F68" label="Expression Name">
              <text>tbl_tradelines</text>
            </literalExpression>
          </in>
          <return id="_E47718D6-B0FB-424D-8AE6-25BA566C2AC7">
            <literalExpression id="_F3F00C07-ACF6-4DE3-B4B7-3CA801027FFB" label="Expression Name">
              <text>UnSecureLiveLoanCheck(item)</text>
            </literalExpression>
          </return>
        </for>
      </contextEntry>
      <contextEntry id="_227CEBC1-A5D6-481F-A4E0-4B3C8A8F8B43">
        <literalExpression id="_7BB8FB74-FA54-4171-A3A6-68B590FD3B90" typeRef="number" label="cntOfUnSecureLiveLoan">
          <text>sum(unsecLoan_fetch)</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
  <businessKnowledgeModel name="UnSecureLiveLoanCheck" id="_5D3CFB38-F380-4949-B0EA-B6C2E5291E76">
    <variable name="UnSecureLiveLoanCheck" id="_19403017-425D-4926-A806-6FACA3E91450" typeRef="number" />
    <encapsulatedLogic label="UnSecureLiveLoanCheck" typeRef="number" id="_5CE729EB-BB90-41D5-8A98-54A4A8FAC0B8" kind="FEEL">
      <formalParameter id="_D2AF0781-8580-4993-B724-1D242027B1BB" name="trade" typeRef="tradelines" />
      <literalExpression id="_D992699D-29D3-49F2-A0C4-CD83EA48EAC3" typeRef="number" label="Return">
        <text>
if trade.tl_accnt_type = null then 0
else if (upper case(replace(trade.tl_accnt_type, &quot; &quot;, &quot;&quot;)) in [&quot;BUSINESSLOAN&quot;,&quot;CONSUMERLOAN&quot;,&quot;EDUCATIONLOAN&quot;,&quot;LOANONCREDITCARD&quot;,&quot;MICROFINANCEHOUSINGLOAN&quot;,&quot;PERSONALLOAN&quot;,&quot;MUDRALOANSSHISHUKISHORTARUN&quot;,&quot;OTHER&quot;,&quot;PRIMEMINISTERJAANDHANYOJANAOVERDRAFT&quot;])
then 1
else 0</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
