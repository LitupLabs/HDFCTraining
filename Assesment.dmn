  <decision name="numOfLiveTrades" id="_33AAA680-78E5-4B20-8D29-8B3F2EC6D199">
    <variable name="numOfLiveTrades" id="_35929E8E-250B-4C63-8A47-D2C161786B8C" typeRef="number" />
    <informationRequirement id="_EDC0D9C0-0918-42D4-8939-8324E5C69D27">
      <requiredInput href="#_9E014170-3F60-4862-BE7F-E25260A90DE3" />
    </informationRequirement>
    <context id="_3B8C53FC-E8E7-4659-B3D7-47035A8FB430" typeRef="number" label="numOfLiveTrades">
      <contextEntry id="_E0A6E851-8504-4DD6-A3D2-A876B532F453">
        <variable id="_1FEA502D-569A-414C-BCD4-5E3BCE2B1C63" name="closeddates_tbl" typeRef="trade_table" />
        <for id="_64696167-FA17-46F1-A32A-240A10C888EC" typeRef="trade_table" label="closeddates_tbl">
          <in id="_8381AD7C-00EC-4650-A08A-96CB455C1159">
            <literalExpression id="_E0D53F39-3CD1-49F5-8FB6-44A85E297FB0" label="Expression Name">
              <text>tbl_tradelines</text>
            </literalExpression>
          </in>
          <return id="_BB7C7C5D-154B-4ED7-A83F-D4B2F3DA9C02">
            <literalExpression id="_88215BD5-C1EE-40BC-AA4A-3CCEDCDD3031" label="Expression Name">
              <text>item.tl_closed_date</text>
            </literalExpression>
          </return>
        </for>
      </contextEntry>
      <contextEntry id="_602F6561-8DDD-4284-8B2E-D7B0FA58AB25">
        <variable id="_55409A2B-708A-45B9-951F-C1752FC2EF70" name="closedDate_filter">
          <description></description>
        </variable>
        <filter id="_D00FCE25-7B09-418A-BC38-365940D040B6" label="closedDate_filter">
          <in id="_70A50975-462C-4747-B605-456C4BAF97CB">
            <literalExpression id="_2E8F676C-60C6-43D1-867B-71D7843EA1E3" label="Expression Name">
              <text>closedDates_tbl</text>
            </literalExpression>
          </in>
          <match id="_DE1E614D-D0C5-4282-84BF-F234DFB944B8">
            <literalExpression id="_8C7A1F45-2990-4801-BD6E-0FB2062E945E" label="Expression Name">
              <text>not(item in (null, &quot;null&quot;, &quot;&quot;,date(&quot;1900-01-01&quot;)))</text>
            </literalExpression>
          </match>
        </filter>
      </contextEntry>
      <contextEntry id="_D2F31149-37A7-4590-9130-115D491C8044">
        <literalExpression id="_4B281C7F-DFCF-4A84-85B7-4F19C2E42649" typeRef="number" label="numOfLiveTrades">
          <text>count(closedDate_filter)</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
  <decision name="totalBureauOverDue" id="_162EF456-2676-4217-9E00-6D81F9C035FB">
    <variable name="totalBureauOverDue" id="_AC01A8A0-063A-42C7-9E21-1ACA1496E575" typeRef="number" />
    <informationRequirement id="_2BEB106B-5E72-4E9B-94EF-9128EC32902B">
      <requiredInput href="#_9E014170-3F60-4862-BE7F-E25260A90DE3" />
    </informationRequirement>
    <context id="_262D3E51-27EC-4654-B25F-9D1DA5DE4C15" typeRef="number" label="totalBureauOverDue">
      <contextEntry id="_B743555F-CE11-4A80-8A2A-09FC819CDDC4">
        <variable id="_EE89292A-C551-46C6-8D3B-A564E7E7FD5C" name="overdue_table" typeRef="trade_table" />
        <for id="_BCAC6C60-8432-46AD-819E-FA128A36D27E" label="overdue_table" typeRef="trade_table">
          <in id="_D849BA4C-326E-4A79-8CBA-3E1EC5C6CF87">
            <literalExpression id="_73C2ECBB-9067-4C21-A036-4A7377E91FFD" label="Expression Name">
              <text>tbl_tradelines</text>
            </literalExpression>
          </in>
          <return id="_10CF9CD1-B955-42E2-AA8F-A1E697BDD9A9">
            <literalExpression id="_B8E3BC3F-3A59-474F-8C45-460AFEB3DB1C" label="Expression Name">
              <text>if item.tl_overdue_amount = null then 0 else item.tl_overdue_amount</text>
            </literalExpression>
          </return>
        </for>
      </contextEntry>
      <contextEntry id="_C6546635-DD4B-4C25-826E-DEEA32319BA3">
        <literalExpression id="_44498B39-B089-457A-9206-3E7D664250E1" typeRef="number" label="totalBureauOverDue">
          <text>sum(overdue_table)</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
