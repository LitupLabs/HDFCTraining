    <context id="_AA773319-0CDF-449F-AE30-4F3EE28E2197" typeRef="number" label="Emi calculation">
      <contextEntry id="_94C41BF2-A62F-4758-AD6D-DD6725A0D7BB">
        <variable id="_693C20D3-CB3C-474A-A99A-4BD47AEAFC89" name="Principal" typeRef="number" />
