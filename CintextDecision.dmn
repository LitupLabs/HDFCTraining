      <contextEntry id="_5FF7C2A9-6CA5-4AC3-B575-EEC197C94745">
        <variable id="_3751BFDC-41A9-4E3E-86C9-D622C8334384" name="rate" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_EF40A991-3DDB-44DC-95D2-CD1318679392" typeRef="number" label="rate">
          <text>Loan.intrestRate /12</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_4B4EA95C-942F-4E69-A156-55835C7D4BAE">
        <variable id="_CBA53805-8611-4676-A355-313AFB01A4F5" name="tenure" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_D0F1C83C-2DDB-4804-BF93-24BA94C11D0C" typeRef="number" label="tenure">
          <text>Loan.tenure</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_A4F70313-5B78-454A-9AA8-D41FA2221503">
        <variable id="_AB10FD52-F24B-4639-8002-B2B688837C1E" name="emi" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_21EFEB54-132F-4A21-A4BC-6E83E99B9C86" typeRef="number" label="emi">
          <text>(principal * rate ) / (1 - ( 1 + rate ) ** (-tenure))</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
