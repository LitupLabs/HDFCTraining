  <decision name="Total Income" id="_5269FEA1-894C-4C56-AA61-9639366EF35D">
    <variable name="Total Income" id="_FB4CC477-EDEF-45F1-A49C-DE0D2B028F82" typeRef="number" />
    <informationRequirement id="_DB510AE5-64C7-4D06-8D37-39B595C89E41">
      <requiredInput href="#_BB9BF479-4402-4406-A759-372C9E06A035" />
    </informationRequirement>
    <literalExpression id="_72A59C05-1CDD-482F-B505-4B8F45493134" typeRef="number" label="Total Income">
      <text>Loanapplication.Financials.Monthlyincome + sum(Loanapplication.Financials.Otherincomes)</text>
    </literalExpression>
  </decision>
  <decision name="EMI  RATIO" id="_52E9B56E-21C1-4BE1-80A6-2030ECB37F85">
    <variable name="EMI  RATIO" id="_FFE9D79B-2376-473D-92A2-596682F343D7" typeRef="number" />
    <informationRequirement id="_EEE22871-BA8E-4CB9-BB93-EFFCC2E72392">
      <requiredInput href="#_BB9BF479-4402-4406-A759-372C9E06A035" />
    </informationRequirement>
    <informationRequirement id="_C6D0D3D8-F33B-46E2-8A2F-254EBCDC3DD8">
      <requiredDecision href="#_5269FEA1-894C-4C56-AA61-9639366EF35D" />
    </informationRequirement>
    <literalExpression id="_74ED6EEB-6DB1-401A-99A0-73F4CFC6EB39" typeRef="number" label="EMI  RATIO">
      <text>Loanapplication.Financials.existingEMI / Total Income</text>
    </literalExpression>
  </decision>
  <decision name="Risk Category" id="_092C4A59-ECEF-4087-B621-E62DA90DBEDE">
    <variable name="Risk Category" id="_401206E2-915C-4857-9747-3BD7ECC00F95" typeRef="Riskcategory" />
    <informationRequirement id="_DDE241E4-8E95-4C66-9B71-5164F836D8CD">
      <requiredDecision href="#_52E9B56E-21C1-4BE1-80A6-2030ECB37F85" />
    </informationRequirement>
    <decisionTable id="_B08A39C3-D080-4907-B7FF-BFC2C056E7E7" typeRef="Riskcategory" hitPolicy="FIRST" label="Risk Category">
      <input id="_D5818627-ED55-4D9C-BA60-69B46113A99E">
        <inputExpression id="_8D1216BC-BAD6-4AF5-8566-867F5CEA71C2" typeRef="number">
          <text>EMI  RATIO</text>
        </inputExpression>
      </input>
      <output id="_8D99000F-643F-448E-87E1-38274D8F216D" typeRef="Riskcategory" />
      <annotation name="Annotations" />
      <rule id="_2257E4E5-62B9-42B9-A398-9CA2F9C1D181">
        <inputEntry id="_4CBE6F7C-D878-48C8-A192-5DF1E20472CA">
          <text>&lt;= .3</text>
        </inputEntry>
        <outputEntry id="_7DF4DC6D-64EF-4F01-8FB1-154220CE2BF5">
          <text>&quot;LOW&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text>// Your annotations here</text>
        </annotationEntry>
      </rule>
      <rule id="_CA09F889-A13A-4FE4-94F5-ACC269DADB8A">
        <inputEntry id="_FB0F18D9-7AF2-4DF3-B897-80D0F7D00104">
          <text>(.3 .. .5]</text>
        </inputEntry>
        <outputEntry id="_167EFF60-B3E5-4703-899C-3436145B21FD">
          <text>&quot;MEDIUM&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
      <rule id="_3BAD5B77-12E9-488F-8B2D-851B4C71CF08">
        <inputEntry id="_7FFF8977-CA3C-4220-8549-95ABE75208F7">
          <text>&gt; .5</text>
        </inputEntry>
        <outputEntry id="_BE544B08-B1C9-4D06-8A4F-0E4B3293CBAB">
          <text>&quot;HIGH&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
    </decisionTable>
  </decision>
