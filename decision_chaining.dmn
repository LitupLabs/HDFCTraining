  <decision name="Total Income" id="_1A8EC393-1D65-45BA-A986-C0EE714DA5B1">
    <variable name="Total Income" id="_F0331BF5-F40A-4194-8F55-427F4C1ECB5A" typeRef="number" />
    <informationRequirement id="_EAFEE031-40AA-4C3E-B8C9-F33AD756A4A8">
      <requiredInput href="#_499B0A0A-129B-451D-BE63-396C30208A78" />
    </informationRequirement>
    <literalExpression id="_7E5630BF-3F09-46BC-BAC4-F9DF5C3D4959" typeRef="number" label="Total Income">
      <text>LoanApplication.financials.monthlyIncome + sum(LoanApplication.financials.otherIncome)</text>
    </literalExpression>
  </decision>
  <decision name="emi_ratio" id="_D717BB5B-58C9-41FC-BE5D-5831BC545A0A">
    <variable name="emi_ratio" id="_DE261E97-1BB4-4369-A747-03E13D250DA6" typeRef="number" />
    <informationRequirement id="_10BD914A-11ED-4159-8D53-67E53C41E820">
      <requiredDecision href="#_1A8EC393-1D65-45BA-A986-C0EE714DA5B1" />
    </informationRequirement>
    <informationRequirement id="_829C31D5-A085-443E-9E60-87C83B53B580">
      <requiredInput href="#_499B0A0A-129B-451D-BE63-396C30208A78" />
    </informationRequirement>
    <literalExpression id="_E9679AB6-BE70-4722-9679-223607CEA45C" typeRef="number" label="emi_ratio">
      <text>LoanApplication.financials.existingEMIs / Total Income
 </text>
    </literalExpression>
  </decision>
  <decision name="Risk Category" id="_7061309C-FF96-4018-BE9E-84F6C74B0E7C">
    <variable name="Risk Category" id="_3009F3C2-32BF-43C7-B4AE-768BCD8882B6" typeRef="RiskCategory" />
    <informationRequirement id="_36CAE81D-5C09-49BE-9665-EDF52E883586">
      <requiredDecision href="#_D717BB5B-58C9-41FC-BE5D-5831BC545A0A" />
    </informationRequirement>
    <decisionTable id="_370E03CA-D5D8-4B1D-ABEC-DA983CCD720D" typeRef="RiskCategory" hitPolicy="RULE ORDER" label="Risk Category">
      <input id="_5605F945-4BBB-467A-B4F9-91ADE842C389">
        <inputExpression id="_C1357D5F-4218-494C-ACF6-A943F925D8C0" typeRef="number">
          <text>emi_ratio</text>
        </inputExpression>
      </input>
      <output id="_336448C7-D01A-454B-9A66-06FA215BB150" typeRef="RiskCategory" />
      <annotation name="Annotations" />
      <rule id="_7098C150-511E-459C-A443-3FE2F71FBC4B">
        <inputEntry id="_D35D3036-62B5-4529-A44E-FEAC1B55A1FC">
          <text>&lt;=0.3</text>
        </inputEntry>
        <outputEntry id="_E5EA995A-C408-41F4-A4AD-638DE25F0143">
          <text>&quot;LOW&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text>// Your annotations here</text>
        </annotationEntry>
      </rule>
      <rule id="_1854EC9A-18BF-4A8C-B2A9-A2A89053EC80">
        <inputEntry id="_50F01C50-BDAA-483B-A5CC-BBDEA40874BE">
          <text>(0.3 .. 0.6]</text>
        </inputEntry>
        <outputEntry id="_0ED608FB-0FD3-481E-B907-88C24BCE4E9D">
          <text>&quot;MEDIUM&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
      <rule id="_BCDAC4F3-DE51-4B32-87FC-F4EA8E63E9B5">
        <inputEntry id="_77BE3AB0-AED4-4DD8-AE87-AA1FB78A48A1">
          <text>&gt;0.5</text>
        </inputEntry>
        <outputEntry id="_0DF9F16E-A405-40E1-8BC1-B35A337A37E3">
          <text>&quot;HIGH&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
    </decisionTable>
  </decision>
