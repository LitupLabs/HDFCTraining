    <itemComponent id="_5AFCB6BE-1F47-4682-96CB-9607C4B20336" name="selectedVendor" isCollection="false" typeLanguage="https://www.omg.org/spec/DMN/20240513/FEEL/">
      <typeRef>ScoredVendor</typeRef>
    </itemComponent>
    <itemComponent id="_ECCF6B2C-D5ED-417B-AE90-C31443715793" name="approvalRequired" isCollection="false" typeLanguage="https://www.omg.org/spec/DMN/20240513/FEEL/">
      <typeRef>boolean</typeRef>
    </itemComponent>
  </itemDefinition>
  <itemDefinition id="_71923BEB-E1B2-4119-BDF6-58B0752AD041" name="Amount" isCollection="true" typeLanguage="https://www.omg.org/spec/DMN/20240513/FEEL/" />
  <decision name="Eligible Vendors" id="_7BD7FD8A-A34F-4EDC-B373-DD7C80F647CC">
    <variable name="Eligible Vendors" id="_6A084F37-A468-418D-B27D-6ABB48C62667" typeRef="VendorList" />
    <informationRequirement id="_739612EF-E4CE-4C13-9624-F377E0D63A3D">
      <requiredInput href="#_6CFC31BA-BE7D-43FE-8ED2-23C43BD36D97" />
    </informationRequirement>
    <informationRequirement id="_9EAA565A-24B4-465D-BAC1-A019C7D2DBB3">
      <requiredInput href="#_124A1091-23CE-48E4-952B-F3E906E49DB2" />
    </informationRequirement>
    <knowledgeRequirement id="_98E1F13F-55F5-44FE-901E-CB207F999298">
      <requiredKnowledge href="#_7D3819A8-B951-4D65-860C-41854FA66129" />
    </knowledgeRequirement>
    <filter id="_13FE8F35-1E8A-4EFB-9E61-1F6BDBAC0AB2" typeRef="VendorList" label="Eligible Vendors">
      <in id="_E7BFECE4-7ACC-4F49-90DD-0A9ADB1FBD9C">
        <literalExpression id="_9FC98DED-DC52-4ABD-817D-93A89B888F9A" label="Expression Name">
          <text>Vendors</text>
        </literalExpression>
      </in>
      <match id="_B91C6286-3978-454B-9122-F34D597817E5">
        <literalExpression id="_05AFE494-221B-4A12-B3E8-F9CE5C7E36DB" label="Expression Name">
          <text>Is Vendor Eligible(item,Policies)</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Total Procurement Cost" id="_8FB5B2B1-9B43-4A81-A5F7-E563904422C1">
    <variable name="Total Procurement Cost" id="_3F84C3FA-E7EF-4A74-A9F7-00E09EA76816" typeRef="number" />
    <informationRequirement id="_3AF471AD-A845-4847-9245-C6BBB1878E5B">
      <requiredDecision href="#_C0FD0692-4F7C-4968-B479-702E45DD945B" />
    </informationRequirement>
    <literalExpression id="_C4AF8D32-37A2-4548-94E9-0E5D9E9B8907" typeRef="number" label="Total Procurement Cost">
      <text>sum(FilteredItem Totals)</text>
    </literalExpression>
  </decision>
  <decision name="Item Totals" id="_DAD01CFC-C954-4AD4-931C-8BA3FEF5D2FF">
    <variable name="Item Totals" id="_D19767E8-5E9D-462D-9DCB-10573008C23E" typeRef="Amount" />
    <informationRequirement id="_1CC02212-31A1-4619-9D28-D630A554DF46">
      <requiredInput href="#_CC718A8E-03E8-4AC9-98ED-9AF5823A0BF2" />
    </informationRequirement>
    <knowledgeRequirement id="_0663EFEC-87B5-4014-AEBE-A30F0AE765AD">
      <requiredKnowledge href="#_1614CD3A-7C7D-47F3-8E6D-8253C148F621" />
    </knowledgeRequirement>
    <for id="_A2FC179D-A44A-4CD6-B360-72606E246D44" typeRef="Amount" label="Item Totals" iteratorVariable="item">
      <in id="_7C87258D-D4EC-4BE3-971C-CB6CFAFBD640">
        <literalExpression id="_59CDE304-A7E2-4476-8089-3F51D4294309" label="Expression Name">
          <text>PurchaseRequest.items</text>
        </literalExpression>
      </in>
      <return id="_6240FEA7-B1BD-4AC2-A02C-800D08DBC1C7">
        <literalExpression id="_4E2D6A35-5DC3-4AE4-80A5-5F1CF75CCFE6" label="Expression Name">
          <text>Calculate Item Total(item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="Scored Vendors" id="_74ACCC92-903A-4D19-9308-E2A06A584B32">
    <variable name="Scored Vendors" id="_83833272-F9FE-46A7-8ED9-A33CB7A8CCDD" typeRef="ScoredVendorList" />
    <informationRequirement id="_6B75D9DC-7D78-4459-80FB-35EF82F4D9CC">
      <requiredDecision href="#_7BD7FD8A-A34F-4EDC-B373-DD7C80F647CC" />
    </informationRequirement>
    <knowledgeRequirement id="_B721E9DF-1797-42BF-A362-FACDD1947939">
      <requiredKnowledge href="#_7D82CC40-1938-4C42-98F2-ED98ACCC4CD8" />
    </knowledgeRequirement>
    <literalExpression id="_BFFBE0D4-F49C-4BF2-A7D2-94B01FC94CFB" typeRef="ScoredVendorList" label="Scored Vendors">
      <text>for v in Eligible Vendors

return {

vendorId: v.vendorId,

score: Calculate Vendor Score(v),

basePriceFactor: v.basePriceFactor

}
 </text>
    </literalExpression>
  </decision>
  <decision name="FilteredItem Totals" id="_C0FD0692-4F7C-4968-B479-702E45DD945B">
    <variable name="FilteredItem Totals" id="_B13BCD76-923E-4A9E-AA04-9F4269A831C4" typeRef="Amount" />
    <informationRequirement id="_98BC0063-3A37-452C-AE6B-AF38BC073CB9">
      <requiredDecision href="#_DAD01CFC-C954-4AD4-931C-8BA3FEF5D2FF" />
    </informationRequirement>
    <filter id="_1C488912-8C4D-456D-B89F-D5CEE4466CBF" typeRef="Amount" label="FilteredItem Totals">
      <in id="_B7D57711-F9B1-4EC8-899A-AA0928961BD1">
        <literalExpression id="_D4A854C2-8DE0-4226-B412-8A3DE1BA57C3" label="Expression Name">
          <text>Item Totals</text>
        </literalExpression>
      </in>
      <match id="_6DA4E9D4-5126-4A2E-956B-D62F74AA027D">
        <literalExpression id="_BEE2C722-FC99-43A6-8AAA-EE665BA112F3" label="Expression Name">
          <text>item !=0</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Best Vendor" id="_9532BF22-20B3-40C0-9935-B4C6D8C1C738">
    <variable name="Best Vendor" id="_E9103D7D-EE13-479E-B4A6-7A4BD130DDA7" typeRef="ScoredVendor" />
    <informationRequirement id="_7AA1911B-20C3-4D88-AB4D-120DEEDBA687">
      <requiredDecision href="#_74ACCC92-903A-4D19-9308-E2A06A584B32" />
    </informationRequirement>
    <filter id="_7B1D8967-0E12-462A-8C7D-3485532A7124" typeRef="ScoredVendor" label="Best Vendor">
      <in id="_38E457C8-562F-4ACE-AC75-73B44AF33040">
        <literalExpression id="_386D39D5-3B6E-4E2F-9770-A3B708A370C4" label="Expression Name">
          <text>Scored Vendors</text>
        </literalExpression>
      </in>
      <match id="_9F209389-0E5B-4260-8D3D-C260910A7383">
        <literalExpression id="_AC7AEC87-66A0-4065-AC97-14F8AB7349B0" label="Expression Name">
          <text>item.score = max(Scored Vendors.score)</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Final Vendor" id="_D54DEA3C-6E3F-48E3-B2CC-4A4FAB03D409">
    <variable name="Final Vendor" id="_F3FC0C47-DD9E-45D7-9D6D-6C6DDF909D39" typeRef="ScoredVendor" />
    <informationRequirement id="_E352E38B-34F9-42D7-AE89-97EDE231FC64">
      <requiredDecision href="#_9532BF22-20B3-40C0-9935-B4C6D8C1C738" />
    </informationRequirement>
    <informationRequirement id="_6974E460-981B-4F8D-9D42-671E5C9EF21E">
      <requiredDecision href="#_8FB5B2B1-9B43-4A81-A5F7-E563904422C1" />
    </informationRequirement>
    <literalExpression id="_481DE88E-0B0E-42A7-BE41-F0F4B3EF90C3" typeRef="ScoredVendor" label="Final Vendor">
      <text>for v in Best Vendor

return {

vendorId: v.vendorId,

score: Total Procurement Cost* v.basePriceFactor,

basePriceFactor: v.basePriceFactor

}</text>
    </literalExpression>
  </decision>
  <decision name="Approval Decision" id="_12AE0615-5916-403D-A7C6-A0871F5277FF">
    <variable name="Approval Decision" id="_CF9F26A3-C9BA-4EFE-8C50-1246052D09E0" typeRef="boolean" />
    <informationRequirement id="_F1474AFC-B08D-4203-A173-B6B3A60C8FE1">
      <requiredDecision href="#_D54DEA3C-6E3F-48E3-B2CC-4A4FAB03D409" />
    </informationRequirement>
    <informationRequirement id="_CD1DD965-3CEF-413E-A4F3-1E79A16F5D03">
      <requiredInput href="#_124A1091-23CE-48E4-952B-F3E906E49DB2" />
    </informationRequirement>
    <literalExpression id="_F6EAEBFF-D94F-49F2-B06E-2D5C91A83203" typeRef="boolean" label="Approval Decision">
      <text>Final Vendor.score &gt; Policies.approvalThreshold</text>
    </literalExpression>
  </decision>
  <decision name="Recommended Vendor" id="_B8E2BD13-BF72-45F5-939B-01A923B4F442">
    <variable name="Recommended Vendor" id="_BC005D3E-FD47-4B77-BD25-5937124EB971" typeRef="Recommendation" />
    <informationRequirement id="_61580759-156C-4D24-8FEB-C4481B7EDA64">
      <requiredDecision href="#_D54DEA3C-6E3F-48E3-B2CC-4A4FAB03D409" />
    </informationRequirement>
    <informationRequirement id="_7C532EF4-D4D5-4936-874C-C04216627FDE">
      <requiredDecision href="#_12AE0615-5916-403D-A7C6-A0871F5277FF" />
    </informationRequirement>
    <literalExpression id="_244AE390-9FD2-440E-A94D-89C8C1489404" typeRef="Recommendation" label="Recommended Vendor">
      <text>for v in Final Vendor

return {

selectedVendor: Final Vendor,

approvalRequired: Approval Decision

}</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Is Vendor Eligible" id="_7D3819A8-B951-4D65-860C-41854FA66129">
    <variable name="Is Vendor Eligible" id="_95C1A4EB-6859-47A1-A8C9-49A1FD7BD668" typeRef="boolean" />
    <encapsulatedLogic label="Is Vendor Eligible" typeRef="boolean" id="_4CC0CD4A-DB7F-40D9-8E64-648D008ABD93" kind="FEEL">
      <formalParameter id="_A10E1273-1C13-4B5D-BF6D-D0564D2145E3" name="vendor" typeRef="Vendor" />
      <formalParameter id="_4B60AD88-D700-442D-BEAD-ABDBB3D62706" name="policies" typeRef="Policies" />
      <conditional id="_63A48CAC-097A-48A9-88D0-406CB6990A1E" label="Return">
        <if id="_51B8E70A-1361-49F5-95BE-9B8DD9A7B51D">
          <literalExpression id="_43B1DAF1-9C92-4DB3-BF2F-54323D12BD41" label="Expression Name">
            <text>vendor.complianceScore &gt;=policies.minComplianceScore and vendor.deliveryDays &lt;= policies.maxDeliveryDays</text>
          </literalExpression>
        </if>
        <then id="_3384505A-389F-45E0-A4EA-FD7C94051D91">
          <literalExpression id="_FEDF7B39-79BF-42D6-87CF-F0F90708B982" label="Expression Name">
            <text>true</text>
          </literalExpression>
        </then>
        <else id="_D24557F8-D648-49EC-B290-E98FDC26DDBB">
          <literalExpression id="_1853A7C6-F160-4A6E-94DE-5FBECCAB48CE" label="Expression Name">
            <text>false</text>
          </literalExpression>
        </else>
      </conditional>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Item Total" id="_1614CD3A-7C7D-47F3-8E6D-8253C148F621">
    <variable name="Calculate Item Total" id="_ADC22597-DAC0-418B-90AA-25FB9E0E3F41" typeRef="number" />
    <encapsulatedLogic label="Calculate Item Total" typeRef="number" id="_BAAF9D31-F983-49D3-B5C9-2BA183D327E3" kind="FEEL">
      <formalParameter id="_F209C74E-69BD-47F7-81FF-2CDD4D444F61" name="item" typeRef="Item" />
      <literalExpression id="_58F170A8-2885-4662-97BE-72E5E335BDD1" typeRef="number" label="Return">
        <text>if item.quantity = null or item.unitPrice = null then 0 else item.quantity * item.unitPrice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Rating" id="_F0721C1C-EA0A-44F3-B442-757CBA8D40C0">
    <variable name="Calculate Vendor Rating" id="_1A715301-6B77-432D-8A69-1371F74036E4" typeRef="number" />
    <encapsulatedLogic label="Calculate Vendor Rating" typeRef="number" id="_3E29A034-44FA-4916-A9DE-5CDA5BA75DEA" kind="FEEL">
      <formalParameter id="_060770AC-53D9-450B-B60E-9B22004C54E1" name="Vendor" typeRef="Vendor" />
      <literalExpression id="_6E3785C9-B9C0-4CA1-B790-6F2391BBAB00" typeRef="number" label="Return">
        <text>Vendor.rating * 10</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Score" id="_7D82CC40-1938-4C42-98F2-ED98ACCC4CD8">
    <variable name="Calculate Vendor Score" id="_FB559B8B-58CD-4227-A63C-E25BB456D841" typeRef="number" />
    <encapsulatedLogic label="Calculate Vendor Score" typeRef="number" id="_B0EF23CC-2289-4BBF-8AB5-7C2CCE784017" kind="FEEL">
      <formalParameter id="_FF13066E-89AC-47B8-A2AC-AA22A591B1B8" name="Vendor" typeRef="Vendor" />
      <context id="_E2315575-F5B5-448B-B287-634C7D9AF1FB" typeRef="number" label="Return">
        <contextEntry id="_A39BC4E9-3C52-480F-8403-CB315A4BD09F">
          <variable id="_B34D39CC-D1B7-4EAC-BD84-1588DD8C6C4D" name="rating" typeRef="number" />
          <literalExpression id="_69F8DD3A-9401-4D40-8EE4-BE04B41D3B95" typeRef="number" label="rating">
            <text>Calculate Vendor Rating(Vendor)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_9378EF68-A196-4931-98F6-4EB09F493447">
          <variable id="_6F674CDD-4AB8-4B48-8169-1ABB226D6AD4" name="deliveryScore" typeRef="number">
            <description></description>
          </variable>
          <conditional id="_CDF680BB-571B-402A-86DB-B03600E04E7F" typeRef="number" label="deliveryScore">
            <if id="_A4D40820-D922-4A90-BD08-48D156674F45">
              <literalExpression id="_2C337FB6-4540-411D-95B1-71FBE9CB2741" label="Expression Name">
                <text>Vendor.deliveryDays &lt;= 2</text>
              </literalExpression>
            </if>
            <then id="_7E346496-0174-4C05-B532-36F3A28B5020">
              <literalExpression id="_62662643-FEC3-4899-BED1-F7A41728C983" label="Expression Name">
                <text>20</text>
              </literalExpression>
            </then>
            <else id="_4947F228-9661-411D-9116-EAD73AB9D4CC">
              <literalExpression id="_8E839947-BDB9-4CE0-B5C2-521DABB83686" label="Expression Name">
                <text>10</text>
              </literalExpression>
            </else>
          </conditional>
        </contextEntry>
        <contextEntry id="_344C3E83-7648-44C9-A94F-3E72D5611B96">
          <variable id="_4E4A7963-D454-4524-9416-50ED5F6AFA7F" name="complianceScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_92AFDA7B-ADD1-484C-878D-92496A9E2A47" typeRef="number" label="complianceScore">
            <text>Vendor.complianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_D6D004A1-0DCE-481E-AE4F-49EF0716DA93">
          <variable id="_F8E7F9C7-1DF7-494C-BEB5-C9154C4E40A1" name="totalScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_7C131BA9-39D2-4BAD-B30A-3F1EF6BCDE93" typeRef="number" label="totalScore">
            <text>rating + deliveryScore + complianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_80618B8C-F01C-404B-8E8F-74F60728E3E9">
          <literalExpression id="_BC07F726-7EB0-4CE7-82D9-E44987545FE6" typeRef="number" label="Return">
            <text>totalScore</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
