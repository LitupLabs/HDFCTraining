    <itemComponent id="_6C2FAEC0-E97A-49C5-9897-52B6252C0237" name="vendorId" isCollection="false" typeLanguage="https://www.omg.org/spec/DMN/20240513/FEEL/">
      <typeRef>string</typeRef>
