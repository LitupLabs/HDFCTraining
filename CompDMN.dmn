    <itemComponent id="_808C88A6-2EA0-4480-B436-127EAFE038E4" name="finalCost" isCollection="true" typeLanguage="https://www.omg.org/spec/DMN/20240513/FEEL/">
      <typeRef>FinalCost</typeRef>
    </itemComponent>
