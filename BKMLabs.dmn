  <decision name="Risk Category" id="_E5FC2307-A89C-4823-9EFA-A58904338617">
    <variable name="Risk Category" id="_892D4678-69B0-40C8-B72B-69E9B4A6E277" typeRef="RiskCategory" />
    <informationRequirement id="_815C2886-F5EB-48A7-9604-443FB4980B26">
      <requiredInput href="#_37997244-1A8D-48B8-8CA8-A5F50A565C45" />
    </informationRequirement>
    <knowledgeRequirement id="_A27F45DA-57EF-4554-B38D-E93360BB23A4">
      <requiredKnowledge href="#_EB460485-C2E8-47C6-883C-04C2AE552191" />
    </knowledgeRequirement>
    <literalExpression id="_5CF60559-5826-4217-B663-5EC68177A1C6" typeRef="RiskCategory" label="Risk Category">
      <text>if Calculate Risk Score() &lt;= 2 then &quot;HIGH&quot; else if Calculate Risk Score() = 3 then &quot;MEDIUM&quot; else &quot;LOW&quot;</text>
    </literalExpression>
  </decision>
  <decision name="Financial Eligibility" id="_62876714-FEEC-47EB-A39F-61B9FDB3A6B5">
    <variable name="Financial Eligibility" id="_D35017DA-934E-4057-87E5-8F417DD12081" typeRef="boolean" />
    <informationRequirement id="_C7B04BF3-B0F4-46FE-868E-7DCA542A0D90">
      <requiredInput href="#_37997244-1A8D-48B8-8CA8-A5F50A565C45" />
    </informationRequirement>
    <knowledgeRequirement id="_5AE9CE6E-4E39-4604-B743-75C16067BDA0">
      <requiredKnowledge href="#_EC7CBA4B-6ABA-4B33-96E0-7DD6D9AD07DB" />
    </knowledgeRequirement>
    <conditional id="_62FD349B-A361-4025-B51B-A67BBAE0229D" typeRef="boolean" label="Financial Eligibility">
      <if id="_21B31DC7-562C-4608-9AE7-99406E14B8FE">
        <literalExpression id="_8EE52B97-C165-4B14-9990-F41FDA77D15B" label="Expression Name">
          <text>Calculate Financial Strength() &gt; 30000</text>
        </literalExpression>
      </if>
      <then id="_EA5D812E-9CE8-406E-A2D5-F8F5E2EA1CAB">
        <literalExpression id="_279284D8-D319-4874-8F0F-085F215161E5" label="Expression Name">
          <text>true</text>
        </literalExpression>
      </then>
      <else id="_CEE94FB4-C516-4B9E-9B71-20744CCAB555">
        <literalExpression id="_B5F27A07-F658-4EC4-B5F3-4EC6EA49DB3C" label="Expression Name">
          <text>false</text>
        </literalExpression>
      </else>
    </conditional>
  </decision>
  <decision name="Loan Approval" id="_95CE92AF-A0CC-48CC-984D-5806EB70ECB2">
    <variable name="Loan Approval" id="_84D6152C-E2CF-406A-9103-FF5C7B764FF9" typeRef="boolean" />
    <informationRequirement id="_2BFA32DF-69AA-48BC-9359-C0F508A20010">
      <requiredDecision href="#_E5FC2307-A89C-4823-9EFA-A58904338617" />
    </informationRequirement>
    <informationRequirement id="_FB7E2A20-4ED0-4D6A-91F9-BC7761DF9326">
      <requiredDecision href="#_62876714-FEEC-47EB-A39F-61B9FDB3A6B5" />
    </informationRequirement>
  </decision>
  <businessKnowledgeModel name="Calculate Risk Score" id="_EB460485-C2E8-47C6-883C-04C2AE552191">
    <variable name="Calculate Risk Score" id="_79E82A4C-87E1-463F-9013-D92005AC8292" typeRef="number" />
    <encapsulatedLogic label="Calculate Risk Score" typeRef="number" id="_00EA0BB0-34BC-400E-BD92-991B017F7130" kind="FEEL">
      <formalParameter id="_491D7077-2B95-4B27-9B63-271280030B82" name="LoanApplication" typeRef="LoanApplication" />
      <decisionTable id="_A88D79A2-C4D7-4519-B8DA-DE0BE3FFDD2B" typeRef="number" hitPolicy="UNIQUE" label="Return">
        <input id="_4376BCDE-34FB-4953-94B9-C81CF14F0626">
          <inputExpression id="_6A793EDB-2B75-4476-A4C5-1E3A9ED06445" typeRef="number">
            <text>LoanApplication.customer.creditScore
 </text>
          </inputExpression>
        </input>
        <output id="_22CE4A82-42C7-46D8-AE0B-353F4A923450" />
        <annotation name="Annotations" />
        <rule id="_92921989-E9BD-4242-95FF-405816537FED">
          <inputEntry id="_9222547D-0859-4B41-9AF7-BCD1B46255F7">
            <text>&lt; 0</text>
          </inputEntry>
          <outputEntry id="_577CB10A-61C5-4802-A19C-3E9DFA4AF9E0">
            <text>0</text>
          </outputEntry>
          <annotationEntry>
            <text>// Your annotations here</text>
          </annotationEntry>
        </rule>
        <rule id="_E3124C61-F101-40F4-A49C-50380E277149">
          <inputEntry id="_8AA51843-2F6E-45F7-85AD-0BA91B2DAE67">
            <text>[0 .. 650]</text>
          </inputEntry>
          <outputEntry id="_BCC79B1C-50A7-47A1-AF54-28647147E66C">
            <text>2</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_6C003CA7-F5AB-451E-8526-99064965BA5E">
          <inputEntry id="_EFD70DAC-B18C-4516-9AFB-07565A3471FF">
            <text>(650 .. 750]</text>
          </inputEntry>
          <outputEntry id="_51C35E6E-2F3B-4B26-96F0-3ABB27136B1C">
            <text>3</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_840B9258-6C14-4698-8792-2C7733DD394F">
          <inputEntry id="_DC2753BC-090A-49F3-9AFC-1E7E1F1DA9EC">
            <text>&gt; 750</text>
          </inputEntry>
          <outputEntry id="_604FFB24-67E1-43ED-8D67-94FD54D76E5B">
            <text>4</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
      </decisionTable>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Financial Strength" id="_EC7CBA4B-6ABA-4B33-96E0-7DD6D9AD07DB">
    <variable name="Calculate Financial Strength" id="_6A330022-A22B-46DF-80E7-529FDBC46EF5" typeRef="number" />
    <encapsulatedLogic label="Calculate Financial Strength" typeRef="number" id="_E283FC37-C50B-4C98-B2A2-4EC2800F3BE5" kind="FEEL">
      <formalParameter id="_5CEA6842-EC5F-4847-9A96-05C8BE1CF7FF" name="LoanApplication" typeRef="LoanApplication" />
      <context id="_D97EBD17-3B6A-47D4-9406-597BB25D5FDA" typeRef="number" label="Return">
        <contextEntry id="_08B82369-1B31-4347-8827-B5EE3B3D34DD">
          <variable id="_8CFE8D9A-6E6D-4F92-9636-BD0C257CF443" name="monthlyIncome" typeRef="number" />
          <literalExpression id="_1AADEE5B-D314-4586-A721-BDADECA85936" typeRef="number" label="monthlyIncome">
            <text>LoanApplication.financials.monthlyIncome</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_83D9088E-DE1D-4AE6-A92A-FB004C5DCF1D">
          <variable id="_256D3F03-4699-4633-9576-247250F4CFD7" name="totalIncome" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_6E439293-0FC8-4F1A-9845-D5514EB31A64" typeRef="number" label="totalIncome">
            <text>monthlyIncome + sum(LoanApplication.financials.otherIncomes)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_B086EB72-BDCB-4305-BF4C-AF4953BB1A97">
          <literalExpression id="_5BDA4E3B-F0A7-4B8D-A37B-29CCAF665ACE" typeRef="number" label="Return">
            <text>totalIncome - LoanApplication.financials.existingEMIs</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <inputData name="LoanApplication" id="_37997244-1A8D-48B8-8CA8-A5F50A565C45">
    <variable name="LoanApplication" id="_075EF7A2-DEC3-407C-8822-D0473D3787BD" typeRef="LoanApplication" />
