  <businessKnowledgeModel name="Calculate Risk Score" id="_C0039D6E-74A3-4320-A3CB-1E2224AC0711">
    <variable name="Calculate Risk Score" id="_AA87B1D4-3897-4605-9AC7-CEA05AA7E03E" typeRef="number" />
    <encapsulatedLogic label="Calculate Risk Score" typeRef="number" id="_AFC26A61-38E3-45CA-8EA2-90156364DA94" kind="FEEL">
      <formalParameter id="_59CCEBCC-03EC-4247-9D34-7FF9473E56E6" name="LoanApplication" typeRef="LoanApplications" />
      <decisionTable id="_9FBD59B1-FAED-4BBB-8D9D-A0815F219465" typeRef="number" hitPolicy="UNIQUE" label="Return">
        <input id="_04E7DC7E-B3D2-4457-B903-4A5AA078CCA8">
          <inputExpression id="_2E3DDB93-F672-43E0-A1F6-B21F9B3A66BD" typeRef="number">
            <text>LoanApplication.customer.creditScore</text>
          </inputExpression>
        </input>
        <output id="_8C242AD9-396D-42A1-90FA-41C6DEE63DF3" />
        <annotation name="Annotations" />
        <rule id="_ACA04716-8EFD-4123-A15B-2DFB6B99DEC4">
          <inputEntry id="_0A3C3031-0E37-4327-98A9-7DEF48B9359B">
            <text>&lt; 0</text>
          </inputEntry>
          <outputEntry id="_EE9314D8-266D-423F-8060-FA3CB756F37A">
            <text>0</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_60BEC531-4744-47CD-886A-EC835B1C9730">
          <inputEntry id="_D5F013B6-C04D-4C2B-A8A2-8A740852F9C8">
            <text>[0 .. 650]</text>
          </inputEntry>
          <outputEntry id="_CA39E747-0AA1-4692-9092-861D483D69AD">
            <text>2</text>
          </outputEntry>
          <annotationEntry>
            <text>// Your annotations here</text>
          </annotationEntry>
        </rule>
        <rule id="_2952CE0C-0458-4BF3-A7F9-8220A38CAD61">
          <inputEntry id="_611957A1-3EB8-444A-9A12-536C5E9FE531">
            <text>(650 .. 750]</text>
          </inputEntry>
          <outputEntry id="_4EB44838-7818-4E66-B97B-660120CE2989">
            <text>3</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_D849B91B-A7FC-4413-BF3D-E32AD0D4703F">
          <inputEntry id="_8D07B8FF-1A72-40C4-871C-9EB242CD8DB2">
            <text>&gt; 750 </text>
          </inputEntry>
          <outputEntry id="_1B0627C3-C338-45BD-A893-1B463D4CFE3A">
            <text>4</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
      </decisionTable>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Financial Strength" id="_0C6C91E2-FC13-4DCB-9492-2E08CB767DED">
    <variable name="Calculate Financial Strength" id="_F26C47F2-7E47-4AD3-B336-8FD8ACEBCCDE" />
    <encapsulatedLogic label="Calculate Financial Strength" id="_E45E4208-C42E-40B3-AFE3-3AE31718D0F8" kind="FEEL">
      <formalParameter id="_6AD2BA6C-0551-4B77-9A7E-CFCA1FDD62DD" name="LoanApplication" typeRef="LoanApplications" />
      <context id="_F3363969-6153-4BBF-9B78-B55106833588" label="Return">
        <contextEntry id="_1C5864AC-3399-4C50-A21C-0C53E19DF37B">
          <variable id="_C46830A3-6791-44E9-A6EF-6C46AD836708" name="monthlyIncome" typeRef="number" />
          <literalExpression id="_E5CACD22-1523-410D-9452-AE0C5A5BA22E" typeRef="number" label="monthlyIncome">
            <text>LoanApplication.financials.monthlyIncome</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_C1D69A1E-E319-426E-A19B-4DF49AAA37D9">
          <variable id="_F0BAD9F4-F305-4244-B0F6-546C654ECFAB" name="totalIncome" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_3C1755DA-5164-4514-A0BF-B6C1258CB542" typeRef="number" label="totalIncome">
            <text>monthlyIncome + sum(LoanApplication.financials.otherIncomes)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_72009C4E-1281-4F9B-B2D7-940D52ADDF2A">
          <literalExpression id="_A0621C4A-4CF4-4A5A-9AB6-B0A8CCE3EADF" label="Return">
            <text>totalIncome - LoanApplication.financials.existingEMIs</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
  </businessKnowledgeModel>
