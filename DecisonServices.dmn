  <decision name="Risk Category" id="_4433BD9A-3E38-4147-98C4-E5CCDDFB9F9E">
    <variable id="_F74757D6-9F05-4E81-BA68-7F19CAC275AC" typeRef="string" name="Risk Category" />
    <informationRequirement id="_20EC77AD-A813-472E-93DD-0FD046070E1C">
      <requiredInput href="#_DDFCA00B-1E90-451D-A2B0-1931E87EA1A2" />
    </informationRequirement>
    <knowledgeRequirement id="_22DBA661-85A7-4860-A517-3E109BF0A85B">
      <requiredKnowledge href="#_32144BDC-846E-4222-B8E1-71D8BC71360B" />
    </knowledgeRequirement>
    <knowledgeRequirement id="_FE9D2CFC-7F2A-462F-A061-C239744CD89B">
      <requiredKnowledge href="#_FD892B72-42F4-47BF-AC88-92E7885BB2A3" />
    </knowledgeRequirement>
    <literalExpression id="_0A9DB772-5794-4CE1-9589-A2ECBA639316" typeRef="string" label="Risk Category">
      <text>if Calculate Risk Score() = 3 then &quot;HIGH&quot; else if Calculate Risk Score() = 2 then &quot;MEDIUM&quot; else &quot;LOW&quot;</text>
    </literalExpression>
  </decision>
  <decision name="Financial Eligibility" id="_DEB0DC3E-CF50-458C-ABBB-9353051DBA0D">
    <variable id="_1FB7B953-9D66-4B18-9935-29DD95B4E208" typeRef="boolean" name="Financial Eligibility" />
    <informationRequirement id="_45F2EC9B-D1D2-4C8A-8D2B-AAA657B02525">
      <requiredInput href="#_DDFCA00B-1E90-451D-A2B0-1931E87EA1A2" />
    </informationRequirement>
    <knowledgeRequirement id="_DAF056EA-0506-48CB-8252-369625B0D9D4">
      <requiredKnowledge href="#_32144BDC-846E-4222-B8E1-71D8BC71360B" />
    </knowledgeRequirement>
    <knowledgeRequirement id="_87FCB5B5-6F23-4742-AB80-6D569794962D">
      <requiredKnowledge href="#_F6BC9316-B8FE-4EA0-A49E-EC2BD110B795" />
    </knowledgeRequirement>
    <literalExpression id="_8D25E1B8-66DF-47E1-8098-276ED12D5133" typeRef="boolean" label="Financial Eligibility">
      <text>Calculate Financial Eligibility() &gt; 30000</text>
    </literalExpression>
  </decision>
  <decision name="Loan Approval" id="_CFD0AC48-1628-48B9-AB41-7F9AEB38FBA8">
    <description></description>
    <variable id="_0F88975A-DBA8-43AB-B9C5-1ED895D0C626" typeRef="boolean" name="Loan Approval" />
    <informationRequirement id="_B7166D2C-20D6-4E96-85FC-65F796B945CF">
      <requiredDecision href="#_4433BD9A-3E38-4147-98C4-E5CCDDFB9F9E" />
    </informationRequirement>
    <informationRequirement id="_48FFE6EC-DBC2-459E-BA68-EC0F2BA2DB90">
      <requiredDecision href="#_DEB0DC3E-CF50-458C-ABBB-9353051DBA0D" />
    </informationRequirement>
    <knowledgeRequirement id="_E2C64C28-2FF9-44D9-9561-7F35AD87F667">
      <requiredKnowledge href="#_32144BDC-846E-4222-B8E1-71D8BC71360B" />
    </knowledgeRequirement>
    <literalExpression id="_A7A9A6E7-5458-4342-B4A2-4C391F84113C" typeRef="boolean" label="Loan Approval">
      <text>Risk Category != &quot;HIGH&quot; and Financial Eligibility = true</text>
    </literalExpression>
  </decision>
  <decision name="CallDS" id="_26C445FB-56D5-4A49-AB36-425AD0DEF20C">
    <variable name="CallDS" id="_CAD7ED8C-115E-4F7D-8B5E-32FBD6AB2350" typeRef="boolean" />
    <informationRequirement id="_FC6D59E1-AA18-48D3-9600-E4D94CA6EDE5">
      <requiredInput href="#_DDFCA00B-1E90-451D-A2B0-1931E87EA1A2" />
    </informationRequirement>
    <knowledgeRequirement id="_DB6F51F9-201C-475F-85EE-10E4A86C3604">
      <requiredKnowledge href="#_32144BDC-846E-4222-B8E1-71D8BC71360B" />
    </knowledgeRequirement>
    <literalExpression id="_8B90120F-0368-4116-8B93-F0BE5425153D" typeRef="boolean" label="CallDS">
      <text>Loan Decison Service(LoanApplication</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Calculate Risk Score" id="_FD892B72-42F4-47BF-AC88-92E7885BB2A3">
    <variable name="Calculate Risk Score" id="_26A40631-9AEE-4A80-AACF-D06ACC88F2E8" typeRef="number" />
    <encapsulatedLogic label="Calculate Risk Score" typeRef="number" id="_44CA927B-0B66-485D-BBB0-A3A8093EDEAE" kind="FEEL">
      <formalParameter id="_40728BA6-B80F-4993-8A86-B357EB9026C1" name="LoanAppliaction" typeRef="LoanAppliaction" />
      <literalExpression id="_7D1148C3-B46C-4064-BCE7-5C63F7EAE8DE" typeRef="number" label="Return">
        <text>if LoanAppliaction.customer.creditScore &gt;= 750 then 3 else if LoanAppliaction.customer.creditScore &gt;= 650 then 2 else 1</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Financial Eligibility" id="_F6BC9316-B8FE-4EA0-A49E-EC2BD110B795">
    <variable name="Calculate Financial Eligibility" id="_24F4DE77-5814-49D9-BA95-DE4178D53096" typeRef="number" />
    <encapsulatedLogic label="Calculate Financial Eligibility" typeRef="number" id="_FD64B4C9-BA58-410B-80F1-536C333E2636" kind="FEEL">
      <formalParameter id="_630C7036-303B-4EFA-B85D-2B0C86AB71AA" name="LoanAppliaction" typeRef="LoanAppliaction" />
      <literalExpression id="_8870C2F1-530B-4DEB-B506-A43594251094" typeRef="number" label="Return">
        <text>LoanAppliaction.financials.montlyIncome + sum(LoanAppliaction.financials.otherIncomes) - LoanAppliaction.financials.existingEMIs</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <inputData name="LoanApplication" id="_DDFCA00B-1E90-451D-A2B0-1931E87EA1A2">
    <variable name="LoanApplication" id="_9D61C750-5826-47DD-B7D7-33657AE451A4" typeRef="LoanAppliaction" />
  </inputData>
