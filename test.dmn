    </informationRequirement>
    <literalExpression id="_0A8BB417-3352-4DEA-96B9-A9FFD1D4DCEB" typeRef="boolean" label="Is Eligible">
      <text>CustomerApplication.loan.tenure &lt;=20 and  CustomerApplication.financials.monthlyIncome &gt; 30000 and CustomerApplication.creditScore &gt; 650</text>
    </literalExpression>
  </decision>
