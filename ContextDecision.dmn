    <context id="_30E2DAC7-93F4-43E2-B771-28DE27ED4D8E" typeRef="number" label="EMICalculation">
      <contextEntry id="_AA340F80-E2B0-4F69-A607-B139CD61E34B">
        <variable id="_2625D6B6-6130-4657-827C-1E5AD9449BCC" name="principal" typeRef="number" />
        <literalExpression id="_419CD83E-9E1C-4E0C-B82C-4DE5CF40F225" typeRef="number" label="principal">
          <text>Loan.amount</text>
        </literalExpression>
