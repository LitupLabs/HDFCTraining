      <contextEntry id="_C6D63E01-F1DF-4BE6-8A76-7D83D438DDE5">
        <variable id="_5AA40F5F-7746-4D66-9FAA-0E882080F739" name="rate" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_AA8E3B04-6AAD-4D9D-920E-ECD6D60D15A6" typeRef="number" label="rate">
          <text>calRate()</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_4285E2B6-31CF-487E-B76A-F5A48E080899">
        <variable id="_28475AD1-B5AB-42AF-A02B-758D305952F9" name="tenure" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_FBC5FAE8-DB1E-4435-9C3B-9E26CEA40D7B" typeRef="number" label="tenure">
          <text>Loan.tenure</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_6CC7CBF0-AB23-4BB3-8187-4D4E600872AA">
        <variable id="_25FBCC4A-1516-448B-83A4-4E0FDFDB943D" name="emi" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_BE9F62D1-8180-4478-8982-5D575560F77D" typeRef="number" label="emi">
          <text>(principal * rate) / (1 - (1 + rate) ** (-tenure))</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_3752F98A-535A-44FB-AFC8-B8F4276D224F">
        <literalExpression id="_311C70EB-DE91-4A45-B36B-04039CDB35EB" typeRef="number" label="EMICalculation">
          <text>emi</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
