      <contextEntry id="_66996A1D-AB58-4979-BD65-33799E9438D4">
        <variable id="_D95BFD1B-FB21-4F39-AF18-6AB904E14EC7" name="rate" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_EA0386A6-F827-4E2F-9DEC-7B1E4F61BDCA" typeRef="number" label="rate">
          <text>Calculate Rate</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_7A4C921C-E92C-4FBE-9CD7-F8A55C9366B1">
        <variable id="_5243B6F6-F4AB-4E87-940E-2899A6C89A94" name="tenure" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_2F5C9135-A2B4-4E4E-9DF4-0210A83832CF" typeRef="number" label="tenure">
          <text>Loan.tenure</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_7A9450C8-EF46-4435-814B-0B9313EBC7AF">
        <variable id="_C3908CAC-95CD-452C-9144-6A109DA31201" name="emi" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_4069733B-9F44-42A1-896B-D45930938CC4" typeRef="number" label="emi">
          <text>(principal * rate)/ (1 - (1+ rate) ** (-tenure))</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_188F19AC-DB06-4689-9294-3634AAEBF4E4">
        <literalExpression id="_1530FAB8-E28E-4BF9-848A-D2EF2E74CC6B" typeRef="number" label="EMI Calculation">
          <text>emi</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
