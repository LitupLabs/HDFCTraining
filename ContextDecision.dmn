    <context id="_6EFFB1B9-56FC-4137-A921-48B1E3C2562C" typeRef="number" label="EMI Calculation">
      <contextEntry id="_FBBEEFDD-B0C2-4DE2-8D21-106E47E90A95">
        <variable id="_3FE775C9-9C1F-4B3B-9969-2B3581A443DD" name="principal" typeRef="number" />
