    <context id="_DBAE4036-77BF-47EF-A70D-644869B0595B" typeRef="number" label="EMI Calculation">
      <contextEntry id="_60641108-6BC1-4F01-855C-660263BE8F2E">
        <variable id="_1F17C804-02CD-43C8-AB76-8D8F7C461D0E" name="principal" typeRef="number" />
        <literalExpression id="_8132DDF1-E684-42A8-AD3D-D58A2BF5F546" typeRef="number" label="principal">
          <text>Loan.amount</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_851BDFB7-F243-49FA-BB7C-F1A5E12BB98A">
        <variable id="_D1BAAE8D-DC67-4043-90D4-90A239F943F5" name="rate" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_6FDBD282-79B5-4F9B-A9D0-A63696A16DD7" typeRef="number" label="rate">
          <text>Loan.interestRate / 12</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_9785A75C-0B40-49E1-B2E0-1EFD0138626B">
        <variable id="_211E219C-6AC5-452E-957D-05F32F7238B9" name="tenure" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_EB6723FC-1FFB-450E-B8E3-43F2DB3D5DBC" typeRef="number" label="tenure">
          <text>Loan.tenure</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_20A161B7-465E-40BF-9FB1-6DCAE9DC9E7B">
        <variable id="_E276D44D-6BC3-4134-9228-682F19B61D8C" name="emi" typeRef="number">
          <description></description>
        </variable>
        <literalExpression id="_2C0C272F-D241-4281-A11C-D7DFB339856C" typeRef="number" label="emi">
          <text>(principal * rate ) / (1 - ( 1 + rate ) ** (-tenure))</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_CA940430-63BC-47A0-8DB4-146D705947FA">
        <literalExpression id="_487A7EBF-F766-44D9-B2E6-4B864310766E" typeRef="number" label="EMI Calculation">
          <text>emi</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
