    </knowledgeRequirement>
    <literalExpression id="_1047E1FB-384A-4D5B-8EBA-D090E591D335" label="Scored Vendors">
      <text>for v in Eligible Vendors

return {

vendorId: v.vendorId,

score: Calculate Vendor Score(v),

basePriceFactor: v.basePriceFactor

}
 </text>
    </literalExpression>
  </decision>
