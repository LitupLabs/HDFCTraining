    <literalExpression id="_B64E54AC-29BF-4DFE-8C3E-441D99CF2B91" typeRef="number" label="InvalidClosedDateCount">
      <text>count(
  tradelines.tbl tradelines[
       tl_closed_date = &quot;01/01/1900 00:00:00&quot;
    or tl_closed_date = &quot;null&quot;
    or tl_closed_date = null
    or tl_closed_date = &quot;&quot;
  ]
)</text>
