  <itemDefinition id="_12DD98A0-7958-4CF3-87C6-4E3E81537EF0" name="riskcategory" isCollection="true" typeLanguage="https://www.omg.org/spec/DMN/20240513/FEEL/">
    <typeRef>string</typeRef>
    <allowedValues id="_5AC34CD2-5F4C-4664-B21F-68188D404044" kie:constraintType="enumeration">
      <text>&quot;HIGH&quot;, &quot;MEDIUM&quot;, &quot;LOW&quot;</text>
    </allowedValues>
  </itemDefinition>
