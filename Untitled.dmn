    </informationRequirement>
    <conditional id="_7D09532A-1A82-4942-96BB-06C470A49BD7" typeRef="number" label="unsec live trade count">
      <if id="_C3EADDDE-FF69-45F9-9274-FD5B7D1D00D4">
        <literalExpression id="_3F9D5B7D-018E-4E2E-BA41-74067DED829D" label="Expression Name">
          <text>count(Live trade)&gt;0 and 
Tradelist in (&quot;BUSINESS LOAN&quot;,&quot;CONSUMER LOAN&quot;, &quot;EDUCATION LOAN&quot;, &quot;LOAN ON CREDIT CARD&quot;, &quot;MICROFINANCE HOUSING LOAN&quot;, &quot;PERSONAL LOAN&quot;, &quot;MUDRA LOANS SHISHU KISHOR TARUN&quot;, &quot;OTHER&quot;, &quot;PRIMEMINISTER JAANDHAN YOJANA OVERDRAFT&quot;)</text>
        </literalExpression>
      </if>
      <then id="_366D3E64-E97B-4957-B0A2-13BB45A61BDF">
        <literalExpression id="_1BBD12D7-D5C0-4C97-B473-8896B3E9F6C1" label="Expression Name">
          <text>count(Tradelist)</text>
        </literalExpression>
      </then>
      <else id="_E952C69A-2E60-41B0-8792-31F67857DE76">
        <literalExpression id="_BB259B0A-4CCD-41C3-9057-F653252850DF" label="Expression Name">
          <text>0</text>
        </literalExpression>
      </else>
    </conditional>
  </decision>
