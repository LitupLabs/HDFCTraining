          <match id="_4F082067-BE94-43C9-85A4-167744FEFEAE">
            <literalExpression id="_BB397DFE-C0AA-4DB1-A1E5-280DE0E07072" label="Expression Name">
              <text>not(item in (null , &quot;null&quot;,&quot;&quot;,&quot;01-01-1900&quot;))</text>
