    <context id="_56DED3E6-40D3-4961-A6AC-B9A413A946EA" typeRef="number" label="NumOfLiveTrades">
      <contextEntry id="_4B4B7DC7-386B-4905-93F9-1387959E2846">
        <variable id="_B6908BE0-44BE-42A5-8EB2-A566CC5CC5D2" name="for_loop" typeRef="trade" />
