        </filter>
      </contextEntry>
      <contextEntry id="_9B8D76F2-2068-43FC-8623-2756D7A98140">
        <literalExpression id="_FF350F6D-4B37-445A-B9BF-9CA325D611FA" typeRef="number" label="NumOfLiveTrades">
          <text>count(fliter)</text>
        </literalExpression>
