  <decision name="Item Totals" id="_F71B967F-F1FD-4BAC-AF1C-CC8ED6F31AC8">
    <variable name="Item Totals" id="_15638817-C41C-4CB9-B721-63CD2DE2E8C3" typeRef="Amount" />
    <informationRequirement id="_8A99BB74-3C4C-4139-A646-589A3B2D9440">
      <requiredInput href="#_319D80D7-A8E9-4F9D-9531-48A0971F136B" />
    </informationRequirement>
    <knowledgeRequirement id="_55ED0D31-6C4A-4AEB-979E-52C34168B13C">
      <requiredKnowledge href="#_64F349BF-0EC7-4CAF-8CE1-83C045688CD1" />
    </knowledgeRequirement>
    <for id="_4379EDEA-9EBC-42D9-ABDE-28A9151FD004" typeRef="Amount" label="Item Totals" iteratorVariable="i">
      <in id="_24F100D0-1372-4EED-A48D-494EB4C574E0">
        <literalExpression id="_8CD5357B-93C8-4D9E-8323-A86B0CF7268B" label="Expression Name">
          <text>PurchaseRequest.items</text>
        </literalExpression>
      </in>
      <return id="_CE9CA4F5-82E7-466B-BF9B-726799509462">
        <literalExpression id="_DFF6544A-D0E5-4712-B363-1DD06E967DEA" label="Expression Name">
          <text>Calculate Item Total(i)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="Total Procurement Cost" id="_0CCD6F61-9D33-48F0-8150-F1664E67F9C6">
    <variable name="Total Procurement Cost" id="_3F78B6DD-5AA1-43AA-91AB-FCC2069A10A2" typeRef="number" />
    <informationRequirement id="_BCBF959E-A1B5-4673-8810-8CE494D09560">
      <requiredDecision href="#_892DF098-3CB8-4500-A1DC-49948F071715" />
    </informationRequirement>
    <literalExpression id="_CA3865FF-E05E-41D0-B32F-B8675B7795F5" typeRef="number" label="Total Procurement Cost">
      <text>sum(Filtered Item Totals)</text>
    </literalExpression>
  </decision>
  <decision name="Eligible Vendors" id="_74AEE765-B589-4553-B442-EC7CA06DC64F">
    <variable name="Eligible Vendors" id="_B591E614-1D22-4E46-99FD-8072ED63FC2C" typeRef="VendorList" />
    <informationRequirement id="_330960B7-567F-48FE-BA74-9A0D48DAD687">
      <requiredInput href="#_8C6B02FC-9824-4617-AF03-711A3C423C21" />
    </informationRequirement>
    <informationRequirement id="_BB515FEF-E1F0-42DA-9B40-BB04C78E08C1">
      <requiredInput href="#_29BA6489-5818-40AA-851D-B7412EE15494" />
    </informationRequirement>
    <knowledgeRequirement id="_195E58DE-0C52-44AC-80E6-7A5916B245D0">
      <requiredKnowledge href="#_AAED8A76-3660-45D4-A767-D50D0D514B55" />
    </knowledgeRequirement>
    <filter id="_62067532-2B13-4C8D-9C41-1BBFD285E755" typeRef="VendorList" label="Eligible Vendors">
      <in id="_73D26D62-3333-47EB-B37E-0EB105726ACF">
        <literalExpression id="_105C7ECD-071B-47C6-9098-0B8B7338814C" label="Expression Name">
          <text>Vendors</text>
        </literalExpression>
      </in>
      <match id="_A3F83F55-3ADC-4D6B-9951-89B5ECC3065C">
        <literalExpression id="_5E43A04D-74C0-4115-8A14-EF6E4F7813DB" label="Expression Name">
          <text>Is Vendor Eligible(item,Policies)</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Filtered Item Totals" id="_892DF098-3CB8-4500-A1DC-49948F071715">
    <variable name="Filtered Item Totals" id="_0EC8FF1B-8EF6-44C3-9FDF-B7F711FE22BF" typeRef="Amount" />
    <informationRequirement id="_C81B21B3-B9FD-4AE2-BB42-61F726B1D346">
      <requiredDecision href="#_F71B967F-F1FD-4BAC-AF1C-CC8ED6F31AC8" />
    </informationRequirement>
    <filter id="_A4CB7583-5AA2-4E68-A59B-1FEDD6A99D28" typeRef="Amount" label="Filtered Item Totals">
      <in id="_4133971D-5130-4DFF-B495-389AB90C9414">
        <literalExpression id="_7CDC71B8-AC56-498F-8DCB-9FFA1642BEC0" label="Expression Name">
          <text>Item Totals</text>
        </literalExpression>
      </in>
      <match id="_FBA5762B-7CDE-42EB-82C8-097B56ADC242">
        <literalExpression id="_04BB6ECB-E7F9-46A2-97E5-FA91A8F9C197" label="Expression Name">
          <text>item!=0</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Scored Vendors" id="_894ADF32-7846-4492-B6EE-1C8506E23509">
    <variable name="Scored Vendors" id="_A68A5B08-0DAF-4631-BA15-D570DBE088FC" typeRef="ScoredVendorList" />
    <informationRequirement id="_A421E0D1-AD49-494B-9FA5-CA0325AB7305">
      <requiredDecision href="#_74AEE765-B589-4553-B442-EC7CA06DC64F" />
    </informationRequirement>
    <knowledgeRequirement id="_87440501-E9CE-4D51-8332-591522B336B3">
      <requiredKnowledge href="#_E5CD3220-E513-425D-85A3-E0D5B34B200C" />
    </knowledgeRequirement>
    <literalExpression id="_7529B59E-8072-4640-9B31-E5B6B796F21E" typeRef="ScoredVendorList" label="Scored Vendors">
      <text>for v in Eligible Vendors
return {
vendorId: v.vendorId,
score: Calculate Vendor Score(v),
basePriceFactor: v.basePriceFactor
}</text>
    </literalExpression>
  </decision>
  <decision name="Best Vendor" id="_467586DE-9295-40A1-AB92-91729EA34B7D">
    <variable name="Best Vendor" id="_EBFE3E02-D3CA-49EE-A1D9-9EEF95660483" typeRef="ScoredVendor" />
    <informationRequirement id="_B08136B1-4F15-4BEC-AFAC-8A3597A50882">
      <requiredDecision href="#_894ADF32-7846-4492-B6EE-1C8506E23509" />
    </informationRequirement>
    <filter id="_CF00CDF3-C13D-4070-9B05-4DB749935572" typeRef="ScoredVendor" label="Best Vendor">
      <in id="_57E57112-96BA-42B9-BE3F-A12841FF8B09">
        <literalExpression id="_CC86F041-0E6F-4456-9DD1-711C1071AB35" label="Expression Name">
          <text>Scored Vendors</text>
        </literalExpression>
      </in>
      <match id="_22552D51-141C-4254-B0CB-AF9EF3DDFD59">
        <literalExpression id="_88535E94-64DB-4D55-88D7-4C61647F57E9" label="Expression Name">
          <text>item.score=max(Scored Vendors.score)</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Final Vendor" id="_F82E54F3-945B-42D2-963D-3849D21F3766">
    <variable name="Final Vendor" id="_3A8CBB80-B4D8-4050-8CE0-E37C161F8BB7" typeRef="ScoredVendor" />
    <informationRequirement id="_F7AFC1D2-6BDE-45C6-B111-29128F8E51C5">
      <requiredDecision href="#_467586DE-9295-40A1-AB92-91729EA34B7D" />
    </informationRequirement>
    <informationRequirement id="_962885B4-A75C-45E2-B10E-FEF224A1AA47">
      <requiredDecision href="#_0CCD6F61-9D33-48F0-8150-F1664E67F9C6" />
    </informationRequirement>
    <literalExpression id="_44C272BF-8851-443A-B5E9-01D3E550777F" typeRef="ScoredVendor" label="Final Vendor">
      <text>for v in Best Vendor
return {
vendorId: v.vendorId,
score: Total Procurement Cost* v.basePriceFactor,
basePriceFactor: v.basePriceFactor
}</text>
    </literalExpression>
  </decision>
  <decision name="Recommended Vendor" id="_7C014F8F-CB6C-4EF2-922A-2007B591E447">
    <variable name="Recommended Vendor" id="_6F32ACE5-0C6B-4142-999B-348D98E1618B" typeRef="Recommendation" />
    <literalExpression id="_896ABAA5-4CE9-436D-9CBC-0B9E3C024B47" typeRef="Recommendation" label="Recommended Vendor">
      <text>for v in Final Vendor
return {
selectedVendor: Final Vendor,
approvalRequired: Approval Decision
}</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Calculate Item Total" id="_64F349BF-0EC7-4CAF-8CE1-83C045688CD1">
    <variable name="Calculate Item Total" id="_114C12D6-A0E5-48D5-90C4-6AAC66323B9C" typeRef="number" />
    <encapsulatedLogic label="Calculate Item Total" typeRef="number" id="_57224D47-8413-4318-8BC2-A46DDACAA3BB" kind="FEEL">
      <formalParameter id="_1440A952-7A71-4471-9406-9CD036F18A6D" name="item" typeRef="Item" />
      <literalExpression id="_7273857C-8479-4C6A-A3E7-C500A8BC7D90" label="Return">
        <text>if item.quantity = null or item.unitPrice = null then 0 else item.quantity * item.unitPrice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Score" id="_E5CD3220-E513-425D-85A3-E0D5B34B200C">
    <variable name="Calculate Vendor Score" id="_1A738847-1C2D-4559-943A-BFCFA50EA2AA" typeRef="number" />
    <encapsulatedLogic label="Calculate Vendor Score" typeRef="number" id="_10284CEE-6FB5-4831-A276-A391E53F7F9B" kind="FEEL">
      <formalParameter id="_2228528B-BF0F-4173-8002-52BD4F807D7B" name="vendor" typeRef="Vendor" />
      <context id="_6D2FD7F4-79D0-4761-9AB9-E04C2BFE34AB" typeRef="number" label="Return">
        <contextEntry id="_D6BA0FED-2BEE-4FA5-B4A5-3E03B1627510">
          <variable id="_8FC53554-11C1-4926-B4D3-EA35AE426D4B" name="ratingScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_329D420E-CB20-4A66-A4CB-C6FE8D69954C" typeRef="number" label="ratingScore">
            <text>Calculate Vendor Rating(vendor)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_63A91EFD-88F5-4DF4-AC57-16578FC8D091">
          <variable id="_3F8CADD7-CB45-492E-BD80-79442D570BC5" name="deliveryScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_D52A27E8-FF0B-4296-B44F-9B52A18FF7B2" typeRef="number" label="deliveryScore">
            <text>if vendor.deliveryDays &lt;= 5 then 30 else 10</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_B9C6018D-1585-4993-9E0E-A6A3D6A17AFE">
          <variable id="_B5784944-A7AE-4B60-A1E2-00AA08F37D6A" name="complianceScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_47363BDA-04C7-4708-A65C-CAE95EBDF3D0" typeRef="number" label="complianceScore">
            <text>vendor.complianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_89E94740-A235-44EA-83DA-A2501A26FC8B">
          <variable id="_860D9A5E-0E5E-470F-98EE-E5B5DDB946D3" name="totalScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_B336A9CE-0444-4D40-A8E1-36C274DA0941" typeRef="number" label="totalScore">
            <text>ratingScore + deliveryScore + complianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_419A89E1-0F08-43FA-8AB1-E2461D04BDA8">
          <literalExpression id="_DBC8DE56-D9E2-4068-B918-89C90B2FB986" typeRef="number" label="Return">
            <text>totalScore</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
    <knowledgeRequirement id="_1E560C08-D57C-40D0-8CF6-4DFF9153EEC8">
      <requiredKnowledge href="#_C043D9CE-CE0F-4237-B69A-68A581248660" />
    </knowledgeRequirement>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Is Vendor Eligible" id="_AAED8A76-3660-45D4-A767-D50D0D514B55">
    <variable name="Is Vendor Eligible" id="_86813DA4-9C6C-4577-B65B-7169C51D5AE1" typeRef="boolean" />
    <encapsulatedLogic label="Is Vendor Eligible" typeRef="boolean" id="_57FA5275-A0BE-429D-907A-DE08D483D165" kind="FEEL">
      <formalParameter id="_B8CE1FBD-E8B8-4891-B2D2-E0112C5BE001" name="vendor" typeRef="Vendor" />
      <formalParameter id="_DCE8FD9D-2937-4CB7-9F78-E31D54E5032C" name="policies" typeRef="Policies" />
      <conditional id="_82BC163F-47A6-4878-9BB2-E13316A49D09" typeRef="boolean" label="Return">
        <if id="_DD383C6F-7D94-4D9A-BE3D-E90B140A7276">
          <literalExpression id="_133CA991-CD38-42F1-BF7C-220EA479B7DF" label="Expression Name">
            <text>vendor.complianceScore &gt;= policies.minComplianceScore
  and vendor.deliveryDays &lt;= policies.maxDeliveryDays</text>
          </literalExpression>
        </if>
        <then id="_EFE315A0-23EF-498A-B2AC-D8DF8BE0E429">
          <literalExpression id="_B7711980-CA95-4647-80D3-E6BC8211C6C9" label="Expression Name">
            <text>true</text>
          </literalExpression>
        </then>
        <else id="_7AADC4C6-03F3-4EEC-B3E9-58E8F0783175">
          <literalExpression id="_0F33BB21-7986-4840-AE8D-A0661F4F1FBF" label="Expression Name">
            <text>false</text>
          </literalExpression>
        </else>
      </conditional>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Rating" id="_C043D9CE-CE0F-4237-B69A-68A581248660">
    <variable name="Calculate Vendor Rating" id="_B57C1FE7-A428-49D1-8C5B-36ACC00E6775" typeRef="number" />
    <encapsulatedLogic label="Calculate Vendor Rating" typeRef="number" id="_18883FBB-236F-48A5-89D5-CE3EB82CDB47" kind="FEEL">
      <formalParameter id="_A4429664-C714-40FA-ABD7-717D1EB62FB9" name="vendor" typeRef="Vendor" />
      <literalExpression id="_40192FAA-19FA-4AB8-9AED-194CAC7F3B93" typeRef="number" label="Return">
        <text>vendor.rating * 10</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
