  <decision name="Risk Category" id="_13536F26-56C3-4441-BB52-F6BA7F63FADB">
    <variable id="_8EB62B1D-65D4-4566-A2AA-D05EEA959156" typeRef="string" name="Risk Category" />
    <informationRequirement id="_E5C98C7A-CD9F-4B2A-9D6D-57B2820D90FD">
      <requiredInput href="#_10E7857D-7028-44EC-B016-ADD5041FE82F" />
    </informationRequirement>
    <knowledgeRequirement id="_76D11302-BD3F-4080-A3EF-4D266EB9B5B4">
      <requiredKnowledge href="#_CE2D1719-5E02-40E3-A508-8E43BDBA4017" />
    </knowledgeRequirement>
    <knowledgeRequirement id="_817C9DB4-DCBC-41EE-99D8-4D113C21F102">
      <requiredKnowledge href="#_26717DFC-E3C2-4678-8809-39FDA1A32FDA" />
    </knowledgeRequirement>
    <literalExpression id="_D28367B6-A6AF-485C-A063-945379C78F0D" typeRef="string" label="Risk Category">
      <text>if Calculate Risk Score() = 3 then &quot;HIGH&quot; else if Calculate Risk Score() = 2 then &quot;MEDIUM&quot; else &quot;LOW&quot;</text>
    </literalExpression>
  </decision>
  <decision name="Financial Eligibility" id="_B0E10C2F-F606-4227-90B0-FE6A974CEA2E">
    <variable id="_0E2F61C8-5DE0-4012-AB78-24BE0BC9BCE7" name="Financial Eligibility" typeRef="boolean" />
    <informationRequirement id="_CE9EC495-41FF-4FB8-9B34-5F32A5C02A45">
      <requiredInput href="#_10E7857D-7028-44EC-B016-ADD5041FE82F" />
    </informationRequirement>
    <knowledgeRequirement id="_C5686D55-137E-4752-9454-2A70063765B3">
      <requiredKnowledge href="#_CE2D1719-5E02-40E3-A508-8E43BDBA4017" />
    </knowledgeRequirement>
    <knowledgeRequirement id="_9AB6C3B2-3B16-4E82-9AE8-0122E30F956F">
      <requiredKnowledge href="#_3B362740-FA93-4927-B45A-5C17DC872077" />
    </knowledgeRequirement>
    <literalExpression id="_A9934C00-E243-41CA-B4F9-93C683DC7A6D" typeRef="boolean" label="Financial Eligibility">
      <text>Calculate Financial Eligiblity() &gt; 30000</text>
    </literalExpression>
  </decision>
  <decision name="Loan Approval" id="_3E80AC58-194F-4B4B-A067-98DB42E459E1">
    <variable id="_78CD0DD4-481A-465A-9AF9-46382A8E3769" typeRef="boolean" name="Loan Approval" />
    <informationRequirement id="_D795C8AB-5811-4158-8D42-09ADA33093CA">
      <requiredDecision href="#_13536F26-56C3-4441-BB52-F6BA7F63FADB" />
    </informationRequirement>
    <informationRequirement id="_4C75A98B-C7B4-47B2-A15B-B2211C578C62">
      <requiredDecision href="#_B0E10C2F-F606-4227-90B0-FE6A974CEA2E" />
    </informationRequirement>
    <literalExpression id="_EEBEBEF2-97A1-4FE2-A6AC-B793E71972B9" typeRef="boolean" label="Loan Approval">
      <text>Risk Category != &quot;HIGH&quot; and Financial Eligibility = true</text>
    </literalExpression>
  </decision>
  <decision name="CallDS" id="_DA0A2206-7464-4BD5-8162-3B4F748B1E34">
    <variable name="CallDS" id="_74B74390-5CA2-492B-BBDB-CCBCA70E8E5C" typeRef="boolean" />
    <informationRequirement id="_8A702405-1EFF-4DBE-B093-0B8916313CD5">
      <requiredInput href="#_10E7857D-7028-44EC-B016-ADD5041FE82F" />
    </informationRequirement>
    <knowledgeRequirement id="_6FF7A58E-86BD-4D09-81F8-6FE0FC63853E">
      <requiredKnowledge href="#_CE2D1719-5E02-40E3-A508-8E43BDBA4017" />
    </knowledgeRequirement>
    <literalExpression id="_FB352832-387A-4EF1-BB76-C846D970E6CB" typeRef="boolean" label="CallDS">
      <text>Loan Decision Service(LoanApplication)</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Calculate Risk Score" id="_26717DFC-E3C2-4678-8809-39FDA1A32FDA">
    <variable name="Calculate Risk Score" id="_26612D00-6669-49B3-AB03-B05F35095041" typeRef="number" />
    <encapsulatedLogic label="Calculate Risk Score" typeRef="number" id="_0AFC37ED-8B45-43E1-97F9-7376AD920D07" kind="FEEL">
      <formalParameter id="_112F8288-D92E-4709-961D-6D586ED052C2" name="LoanApplication" typeRef="LoanApplication" />
      <literalExpression id="_27E1EDD8-06B1-4BAE-B71F-8FC19731A0D8" typeRef="number" label="Return">
        <text>if LoanApplication.customer.creditScore &gt; 750 then 3 else if LoanApplication.customer.creditScore  &gt; 650 then 2 else 1</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Financial Eligiblity" id="_3B362740-FA93-4927-B45A-5C17DC872077">
    <variable name="Calculate Financial Eligiblity" id="_C3A256F7-8999-46BD-846A-99FEA3D47734" typeRef="number" />
    <encapsulatedLogic label="Calculate Financial Eligiblity" typeRef="number" id="_181F1D1A-BE5F-42AE-A900-D6225061FC85" kind="FEEL">
      <formalParameter id="_3B223583-E51B-4706-B22D-05E85915584D" name="LoanApplication" typeRef="LoanApplication" />
      <literalExpression id="_34A4C30E-7529-49D5-9093-D41C0F90DCF8" typeRef="number" label="Return">
        <text>LoanApplication.financials.monthlyIncome + sum(LoanApplication.financials.otherIncomes) - LoanApplication.financials.existingEMIs</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <inputData name="LoanApplication" id="_10E7857D-7028-44EC-B016-ADD5041FE82F">
    <variable name="LoanApplication" id="_FE58FFA3-5374-4012-8295-C535EBDAF334" typeRef="LoanApplication" />
  </inputData>
