  <decision name="Risk Category" id="_057D8ACB-8A77-478B-A632-A29394CC080C">
    <variable id="_CB298FC6-5232-4523-8DDD-A1950E76BD05" typeRef="string" name="Risk Category" />
    <informationRequirement id="_6ACE7691-1621-453F-9C29-5E26194CD6DF">
      <requiredInput href="#_9A9C7EBF-D93E-42B0-BAE2-43F913B3EBB7" />
    </informationRequirement>
    <knowledgeRequirement id="_5CA11495-1121-4349-BC6A-731901DD26E8">
      <requiredKnowledge href="#_AE47CFD1-BCD5-4C86-8CB2-31B5F9362897" />
    </knowledgeRequirement>
    <knowledgeRequirement id="_2ADAB84D-513B-472F-8945-81BDCB0A517D">
      <requiredKnowledge href="#_13A6FE44-8127-4748-9333-1B14AF370454" />
    </knowledgeRequirement>
    <literalExpression id="_C0D8699A-3503-4C4C-8707-C1D2A5E0449A" typeRef="string" label="Risk Category">
      <text>if Calculate Risk Score() = 3 then &quot;HIGH&quot; else if Calculate Risk Score() = 2 then &quot;MEDIUM&quot; else &quot;LOW&quot;
 </text>
    </literalExpression>
  </decision>
  <decision name="Financial Eligiblity" id="_5EAD1FC9-C732-44F3-8A5D-FC520295A37C">
    <variable id="_FC220F67-FBA7-4E4A-877D-04B28F23C6AF" typeRef="boolean" name="Financial Eligiblity" />
    <informationRequirement id="_584884E9-DAAA-4E92-B85F-69BB3E8275E3">
      <requiredInput href="#_9A9C7EBF-D93E-42B0-BAE2-43F913B3EBB7" />
    </informationRequirement>
    <knowledgeRequirement id="_0D2136A9-CBDA-4D44-9501-C320E0AC1D83">
      <requiredKnowledge href="#_AE47CFD1-BCD5-4C86-8CB2-31B5F9362897" />
    </knowledgeRequirement>
    <knowledgeRequirement id="_800FD56B-F137-4742-A623-FCD99939E319">
      <requiredKnowledge href="#_4EA35582-16D4-4F9E-9E29-8D0A1EE57120" />
    </knowledgeRequirement>
    <literalExpression id="_74CB5442-49E9-4CE9-8BEF-A2A76457E483" typeRef="boolean" label="Financial Eligiblity">
      <text>Calculate Financial Eligiblity() &gt; 30000</text>
    </literalExpression>
  </decision>
  <decision name="Loan Approval" id="_A606E4C9-ACB0-4598-AA5E-F0F29F4CBE43">
    <variable id="_96A198FB-A171-4E00-BCD4-C44F9433223C" typeRef="boolean" name="Loan Approval" />
    <informationRequirement id="_A4382668-EE06-43A3-8013-EB8DCF70BCB7">
      <requiredDecision href="#_057D8ACB-8A77-478B-A632-A29394CC080C" />
    </informationRequirement>
    <informationRequirement id="_D04C2892-6288-4428-BE78-38AA67B52930">
      <requiredDecision href="#_5EAD1FC9-C732-44F3-8A5D-FC520295A37C" />
    </informationRequirement>
    <knowledgeRequirement id="_50671194-2A88-49BA-9DE0-EB546A794FAC">
      <requiredKnowledge href="#_AE47CFD1-BCD5-4C86-8CB2-31B5F9362897" />
    </knowledgeRequirement>
    <literalExpression id="_B1A8FE9E-1C61-41D8-97CD-6DF5D349E579" typeRef="boolean" label="Loan Approval">
      <text>Risk Category != &quot;HIGH&quot; and Financial Eligiblity = true</text>
    </literalExpression>
  </decision>
  <decision name="CallDS" id="_66799EBC-3C76-42F3-9EA4-26841B32A717">
    <variable name="CallDS" id="_8D2C2AF5-94E1-4F83-BAA1-9CF79316792F" typeRef="boolean" />
    <literalExpression id="_3B997996-AC2C-4F66-8D2D-6953281A63B0" typeRef="boolean" label="CallDS" />
  </decision>
  <businessKnowledgeModel name="Calculate Risk Score" id="_13A6FE44-8127-4748-9333-1B14AF370454">
    <variable name="Calculate Risk Score" id="_7D0D5485-BE0B-45F7-9E77-89B8CBCBE29F" typeRef="number" />
    <encapsulatedLogic label="Calculate Risk Score" typeRef="number" id="_9279D148-1CD7-490E-935B-3F8236E90B50" kind="FEEL">
      <formalParameter id="_32A96358-A123-47C5-A243-8FC94431B673" name="LoanApplication" typeRef="LoanApplication" />
      <literalExpression id="_63C6B1B9-90A6-457E-81D0-B7AE25DA010D" typeRef="number" label="Return">
        <text>if LoanApplication.Customer.creditScore &gt;= 750 then 3 else if LoanApplication.Customer.creditScore &gt;= 650 then 2 else 1
 </text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Financial Eligiblity" id="_4EA35582-16D4-4F9E-9E29-8D0A1EE57120">
    <variable name="Calculate Financial Eligiblity" id="_B4312196-5FAD-4377-9D58-5BE808258B11" typeRef="number" />
    <encapsulatedLogic label="Calculate Financial Eligiblity" typeRef="number" id="_A782A24E-C54B-4CB8-A616-52F3843AD0BE" kind="FEEL">
      <formalParameter id="_C0A265F6-6ACE-4C3F-B878-26226F348BFF" name="LoanApplication" typeRef="LoanApplication" />
      <literalExpression id="_8C0A8351-63A7-436A-A3F7-FA275EF5D73A" typeRef="number" label="Return">
        <text>LoanApplication.Financials.monthlyIncomes + sum(LoanApplication.Financials.otherincomes) - LoanApplication.Financials.existingEMIs</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <inputData name="LoanApplication" id="_9A9C7EBF-D93E-42B0-BAE2-43F913B3EBB7">
    <variable name="LoanApplication" id="_E9F875AD-0FE9-4BCA-AED2-E3931A9A5025" typeRef="LoanApplication" />
  </inputData>
