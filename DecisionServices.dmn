  <decision name="Risk Category" id="_FD1E1864-020E-4A8B-852C-310009064304">
    <variable id="_97DC3771-7EB9-4B57-A999-76122B197BB0" typeRef="string" name="Risk Category" />
    <informationRequirement id="_FA8F848A-1BF2-4C1E-82B4-B5CFBD077FE3">
      <requiredInput href="#_F0246DE3-22A8-4FE8-AA3F-18A0314C7F98" />
    </informationRequirement>
    <knowledgeRequirement id="_DC9566EF-036D-4694-A38A-3D6834F41487">
      <requiredKnowledge href="#_499A8801-C2D9-4DB3-96C1-463778FAE57A" />
    </knowledgeRequirement>
    <knowledgeRequirement id="_348AB02E-FD50-4D39-A807-26A11041F899">
      <requiredKnowledge href="#_766F0EC3-5EF9-4899-AA86-F5317FF1C277" />
    </knowledgeRequirement>
    <literalExpression id="_E3B8B6DA-A55A-48DC-B84B-485EA4CDDE1D" typeRef="string" label="Risk Category">
      <text>if Calculate Risk Score() = 3 then &quot;LOW&quot;
else if Calculate Risk Score () = 2 then &quot;MEDIUM&quot;
else &quot;HIGH&quot;</text>
    </literalExpression>
  </decision>
  <decision name="Financial Eligiblity" id="_ECE36F1E-E0E6-4BDE-8362-A02EA95CEDD3">
    <variable id="_60531B94-1BA8-4197-B349-314EBA45DB66" typeRef="boolean" name="Financial Eligiblity" />
    <informationRequirement id="_DFF2B32C-E2E8-44F4-9F78-7DD4AFF9CBED">
      <requiredInput href="#_F0246DE3-22A8-4FE8-AA3F-18A0314C7F98" />
    </informationRequirement>
    <knowledgeRequirement id="_1A6B5F86-115C-4446-9DBB-08C3BD8F8EC0">
      <requiredKnowledge href="#_499A8801-C2D9-4DB3-96C1-463778FAE57A" />
    </knowledgeRequirement>
    <knowledgeRequirement id="_4FF03EDE-1048-4D4B-90A6-BA2E63DFB3BE">
      <requiredKnowledge href="#_2DEFEF6A-FDDB-48CE-915B-F38F6792AB03" />
    </knowledgeRequirement>
    <literalExpression id="_6BF9F593-0621-41DB-B294-E2A481A749B3" typeRef="boolean" label="Financial Eligiblity">
      <text>Calculate Financial Eligiblity () &gt; 30000</text>
    </literalExpression>
  </decision>
  <decision name="Loan Approval" id="_71AED9E5-DFB0-4921-A8EC-8D888762BEF0">
    <variable id="_7D427C00-2E18-4522-B396-9C23DD8E055A" name="Loan Approval" typeRef="boolean" />
    <informationRequirement id="_246DAF6F-5CDA-43FF-9854-B86C81D34924">
      <requiredDecision href="#_FD1E1864-020E-4A8B-852C-310009064304" />
    </informationRequirement>
    <informationRequirement id="_CB01D66F-1A7D-43DA-AED4-23B891A23FAC">
      <requiredDecision href="#_ECE36F1E-E0E6-4BDE-8362-A02EA95CEDD3" />
    </informationRequirement>
    <knowledgeRequirement id="_6FB359B8-24DF-4594-BC7E-4B017CDFBA30">
      <requiredKnowledge href="#_499A8801-C2D9-4DB3-96C1-463778FAE57A" />
    </knowledgeRequirement>
    <literalExpression id="_74DB7268-C43F-402C-839D-7BF210150308" typeRef="boolean" label="Loan Approval">
      <text>Risk Category!= &quot;HIGH&quot; and Financial Eligiblity = true</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Calculate Risk Score" id="_766F0EC3-5EF9-4899-AA86-F5317FF1C277">
    <variable name="Calculate Risk Score" id="_9DE96624-0E97-4CD5-B00D-7A7DB4C5C62A" typeRef="number" />
    <encapsulatedLogic label="Calculate Risk Score" typeRef="number" id="_0FBC3692-D026-4355-9B05-49CD4CA9D3A8" kind="FEEL">
      <formalParameter id="_C3B46288-B908-4063-88D0-2C2B810AC112" name="LoanApplication" typeRef="LoanApplication" />
      <literalExpression id="_EDFA7AB7-C181-48DD-BD32-803CD91DE3DD" typeRef="number" label="Return">
        <text>if LoanApplication.customer.creditScore &gt;= 750 then 3 else if LoanApplication.customer.creditScore &gt;= 650 then 2 else 1</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Financial Eligiblity" id="_2DEFEF6A-FDDB-48CE-915B-F38F6792AB03">
    <variable name="Calculate Financial Eligiblity" id="_B872EA1A-9FBA-4C71-BBC7-5A86ACB2DF00" typeRef="number" />
    <encapsulatedLogic label="Calculate Financial Eligiblity" typeRef="number" id="_715E5974-AD85-4647-B46C-A97E6A061A3C" kind="FEEL">
      <formalParameter id="_315D148A-5964-4262-ACAB-CC41665F8733" name="LoanApplication" typeRef="LoanApplication" />
      <literalExpression id="_7F8AE6FD-61E1-46E8-99A7-81FF613BC400" typeRef="number" label="Return">
        <text>LoanApplication.financials.monthlyIncome + sum(LoanApplication.financials.otherIncomes) - LoanApplication.financials.existingEMIs</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <inputData name="LoanApplication" id="_F0246DE3-22A8-4FE8-AA3F-18A0314C7F98">
    <variable name="LoanApplication" id="_2EBA894F-656B-4F41-AEA3-B56C7C7ACF45" typeRef="LoanApplication" />
  </inputData>
