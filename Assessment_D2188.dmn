    <literalExpression id="_337AB8FB-36E4-4F29-984A-FAD4D9BF6117" typeRef="number" label="cntOfUnSecureLiveLoan">
      <text>count(tbl_tradelines[not(tbl_tradelines.tl_closed_date in [&quot;01/01/1900 00:00:00&quot;, &quot;null&quot;, null, &quot;&quot;] ) and tbl_tradelines.tl_acct_type in [&apos;BUSINESSLOAN&apos;,&apos;CONSUMERLOAN&apos;, &apos;EDUCATIONLOAN&apos;, &apos;LOANONCREDITCARD&apos;, &apos;MICROFINANCEHOUSINGLOAN&apos;, &apos;PERSONALLOAN&apos;, &apos;MUDRALOANSSHISHUKISHORTARUN&apos;, &apos;OTHER&apos;, &apos;PRIMEMINISTERJAANDHANYOJANAOVERDRAFT&apos;]])</text>
    </literalExpression>
  </decision>
