    <literalExpression id="_4E0166FF-2DFE-40FB-87E2-D1A4736F732D" typeRef="number" label="numOfLiveTrades">
      <text>count(not(tbl_tradelines.tl_closed_date in [&quot;01/01/1900 00:00:00&quot;, &quot;null&quot;, null, &quot;&quot;] ))</text>
    </literalExpression>
  </decision>
  <decision name="cntOfUnSecureLiveLoan" id="_9D3FD60D-27EF-4999-AB49-B24FA0300811">
