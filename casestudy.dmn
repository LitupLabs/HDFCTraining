          <in id="_529B5CD2-3699-4C89-B813-7B427E27EC13">
            <literalExpression id="_2609B759-2D92-4526-9E78-74F3190E7B37" label="Expression Name">
              <text>tbltradelines</text>
            </literalExpression>
          </in>
          <return id="_279D044C-87D8-4A1F-A2D2-84ACB5A5E634">
            <literalExpression id="_A5B86B56-9303-4AA0-854C-4200720661B7" label="Expression Name">
              <text>if i.tl_overdue_amount = null then 0 else i.tl_overdue_amount</text>
