    <context id="_12033194-AB66-4D74-9E30-0709B1DE8C12" typeRef="number" label="numOfLiveTrades">
      <contextEntry id="_A705704F-B353-474F-9112-5EFBBF8B6DE0">
        <variable id="_66D18517-D292-452E-8FB2-B0ED296E76BD" name="live" typeRef="trade" />
        <for id="_DA13AE11-A1A3-4186-A412-7425206EA184" typeRef="trade" label="live" iteratorVariable="i">
          <in id="_3C8535F2-088C-495A-B980-0B1FCEA85597">
            <literalExpression id="_E927A322-473F-4F33-8ECB-6A91893BED0E" label="Expression Name">
              <text>tbltradelines</text>
            </literalExpression>
          </in>
          <return id="_D08010CE-9D88-476D-86A2-F14A65314343">
            <literalExpression id="_7EA43C2B-D5D0-4E11-873E-12E4A30F3635" label="Expression Name">
              <text>i.tl_closed_date</text>
            </literalExpression>
          </return>
        </for>
      </contextEntry>
      <contextEntry id="_2B550078-1BF4-42E6-88BA-879E9327F585">
        <variable id="_E88F47CB-A03E-4240-BFBC-B51AB6FDF65D" name="filter" typeRef="trade">
          <description></description>
        </variable>
        <filter id="_A9A237ED-0403-4906-BC4D-52D41FAB6B7C" typeRef="trade" label="filter">
