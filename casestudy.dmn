            <literalExpression id="_86CF356C-3B86-4053-9131-D71203F9BC3E" label="Expression Name">
              <text>live</text>
            </literalExpression>
          </in>
          <match id="_4EEB6B10-FCE1-4A5C-AE62-9F89646AA1D3">
            <literalExpression id="_F1BD236C-1D23-40DC-9E72-F6F2B2BD2BDE" label="Expression Name">
              <text>not(item in (&quot;01/01/1900 00:00:00&quot;, &quot;null&quot;, null, &quot;&quot;))</text>
            </literalExpression>
          </match>
        </filter>
      </contextEntry>
      <contextEntry id="_261E3840-EB41-4969-8867-4662E469EC5F">
        <literalExpression id="_FEA4A501-484A-44C5-B07A-7DF487574CE6" typeRef="number" label="livetrade">
          <text>count(filter)</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
  <decision name="totalBureauOverDue" id="_EEB4B1CC-3729-46B5-A6CA-CC0CD6DC1072">
