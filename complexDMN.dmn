  <decision name="itemtotal" id="_360EF0EB-231F-4448-9860-A51B744329AB">
    <variable name="itemtotal" id="_58F0F33E-C493-4540-8BFF-EC434E2F47C4" typeRef="amount" />
    <informationRequirement id="_270C9177-CF0A-442A-B05C-84A1B23E2B2B">
      <requiredInput href="#_DDD64DCF-2162-4440-A035-9AB6C8D39D19" />
    </informationRequirement>
    <knowledgeRequirement id="_10AA3318-55FC-45B7-A316-E5FA6F0FAAA3">
      <requiredKnowledge href="#_B085B2E7-F5E6-441F-86D5-A5F3B1EFD3C9" />
    </knowledgeRequirement>
    <for id="_B720F08A-F965-4547-A904-9BBDB6F6C008" typeRef="amount" label="itemtotal" iteratorVariable="item">
      <in id="_966EEEB6-16BB-4E46-A9D5-6C0D3671669B">
        <literalExpression id="_77F7EC21-C60A-439B-AB55-71551925AC2D" label="Expression Name">
          <text>purchaserequest.items</text>
        </literalExpression>
      </in>
      <return id="_6F5EF3E7-1939-43A3-B4F7-30249AC54D57">
        <literalExpression id="_586B131C-92EF-445D-A4BE-1BD1B4C3B7E2" label="Expression Name">
          <text>calculateitemtotal(item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="totalprocurementcost" id="_777285A1-8535-4856-8FBE-5B55C0544B4B">
    <variable name="totalprocurementcost" id="_40824E13-F86A-4494-8496-82AAEEE9FD6E" typeRef="number" />
    <informationRequirement id="_2173D8CD-C168-4C56-A236-25CC54569C21">
      <requiredDecision href="#_B7FBA25B-A500-49F8-8F44-0D28F2812656" />
    </informationRequirement>
    <literalExpression id="_FB08E099-AF84-439F-AA41-6C10D4699C51" typeRef="number" label="totalprocurementcost">
      <text>sum(itemtotal)</text>
    </literalExpression>
  </decision>
  <decision name="eligiblevenders" id="_73FFB477-28A0-4C3F-9157-1FF52511E19D">
    <variable name="eligiblevenders" id="_E16E84A2-6DAF-4210-91E1-9792CFA6516A" typeRef="vendorlist" />
    <informationRequirement id="_ABD8CA02-D95C-4AD3-9322-870F83447CD8">
      <requiredInput href="#_54A615ED-BE73-408E-ABD0-084AA478315E" />
    </informationRequirement>
    <informationRequirement id="_BD6035FA-D1CE-44CF-A162-BF0686683D30">
      <requiredInput href="#_D42391B6-928F-4C6B-8D06-86FEF5393BBA" />
    </informationRequirement>
    <knowledgeRequirement id="_54ECE063-8197-4F5C-8E3E-65829D2E3C78">
      <requiredKnowledge href="#_064B8F08-438E-4EDC-8C1F-C861C9742171" />
    </knowledgeRequirement>
    <filter id="_5B099E63-F5A2-4FDC-9B8E-B4CF227D2225" typeRef="vendorlist" label="eligiblevenders">
      <in id="_89C5415F-1E4E-435A-A8C6-133B83D49ACF">
        <literalExpression id="_C9E1237E-9FE4-4AD6-AE4C-60CCCE3C3E4D" label="Expression Name">
          <text>vendors</text>
        </literalExpression>
      </in>
      <match id="_01EE9F70-94CC-4B81-9C1A-B431F59A0031">
        <literalExpression id="_ECE0E65F-AD7F-4178-B438-944F4A20B9C6" label="Expression Name">
          <text>is vendor eligible(item, policies)</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="filtereditemtotals" id="_B7FBA25B-A500-49F8-8F44-0D28F2812656">
    <variable name="filtereditemtotals" id="_A00A0CF4-E48A-4C63-BF68-8DC06C8B8262" typeRef="amount" />
    <informationRequirement id="_66AD8058-0114-40DE-8B36-186A505D0665">
      <requiredDecision href="#_360EF0EB-231F-4448-9860-A51B744329AB" />
    </informationRequirement>
    <filter id="_97F35FF6-57F8-45F1-B918-0A52323455E0" typeRef="amount" label="filtereditemtotals">
      <in id="_807C41F5-AC76-4664-B8EC-1EBE38058B5F">
        <literalExpression id="_9A5A76B6-F7ED-46BA-9883-3E5B1D5F0F74" label="Expression Name">
          <text>itemtotals</text>
        </literalExpression>
      </in>
      <match id="_36B36E9A-5FEE-4F21-95F2-F12EDBC36D1F">
        <literalExpression id="_9FA56E33-16E8-4F59-8FC9-2A7045C31962" label="Expression Name">
          <text>item!=0</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <businessKnowledgeModel name="calculateitemtotal" id="_B085B2E7-F5E6-441F-86D5-A5F3B1EFD3C9">
    <variable name="calculateitemtotal" id="_8F76B61D-54DF-45FD-A0EB-BD5A775625B9" typeRef="number" />
    <encapsulatedLogic label="calculateitemtotal" typeRef="number" id="_499851F2-8EB0-4622-89E2-4DF30E2B05F6" kind="FEEL">
      <formalParameter id="_ECA00901-486D-4E5B-9AF1-39FABE709A00" name="item" typeRef="item" />
      <literalExpression id="_1FA83085-73D9-4C1F-A7C7-CF355DCE7344" typeRef="number" label="Return">
        <text>if item.quantity = null or item.unitprice = null then 0 else item.quantity * item.unitprice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="is vendor eligible" id="_064B8F08-438E-4EDC-8C1F-C861C9742171">
    <variable name="is vendor eligible" id="_2E654FF6-491E-4286-8CE4-08B11F7C296C" typeRef="boolean" />
    <encapsulatedLogic label="is vendor eligible" typeRef="boolean" id="_82EDBDC2-99CC-493B-98B9-C8A769219A62" kind="FEEL">
      <formalParameter id="_8A0F6484-C455-4F48-B6F8-6F0EA19144BC" name="vendor" typeRef="vendor" />
      <formalParameter id="_138DBE0B-EB0D-4881-A18B-2DA3746ECC6B" name="policies" typeRef="policies" />
      <conditional id="_97D6AD58-0EF0-434B-BE3C-26A7C318F98F" label="Return">
        <if id="_C891C850-4832-4F72-B343-257B3CD5B7E9">
          <literalExpression id="_91175B48-B58D-45C3-B13A-AF9AFE9780E8" label="Expression Name">
            <text>vendor.compliancescore &gt;= policies.mincompliancescore and vendor.deliverydate &lt;= policies.maxdeliverydays</text>
          </literalExpression>
        </if>
        <then id="_035AC073-428C-4E9B-8504-7E264F01305F">
          <literalExpression id="_05E1896F-9ED5-4F42-A298-E3B245072C51" label="Expression Name">
            <text>true</text>
          </literalExpression>
        </then>
        <else id="_052094F5-B137-490D-92B9-6E5E821BD0F2">
          <literalExpression id="_61A81008-2408-4FA4-9F86-BDBECEC45035" label="Expression Name">
            <text>false</text>
          </literalExpression>
        </else>
      </conditional>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="calculatevendorscore" id="_66B9AAA7-0A80-473B-9C78-B8FA002E131A">
    <variable name="calculatevendorscore" id="_C8BCE434-B413-4373-8F3B-0151D72433F4" />
    <encapsulatedLogic label="calculatevendorscore" id="_130A7087-2498-4B04-8766-FA5916DC3251" kind="FEEL">
      <formalParameter id="_03A6EE2B-EE1B-4FB9-9BAC-C0BFF7310885" name="vendor" typeRef="vendor" />
      <context id="_978D5C62-BA38-43B5-B4DF-2E23A4877297" label="Return">
        <contextEntry id="_AC46FE17-87DE-4BFE-BF3F-8A43FEA121EB">
          <variable id="_7B3CBDCD-AED9-458E-BD28-ED05C24E9AF7" name="ratingscore" typeRef="number" />
          <literalExpression id="_D8F59283-5752-486C-92CD-3870F1DEBA4D" typeRef="number" label="ratingscore">
            <text>calculatevendorrating(vendor)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_0A27B534-B241-465F-80CF-2B729ED43D1E">
          <variable id="_207B6618-7D85-42A9-A1A2-0BECC55C35DF" name="compliancescore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_C808B0A7-58E3-43B5-8CF0-3B585C377073" typeRef="number" label="compliancescore">
            <text>totalscore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_23EFEF55-DAD7-49D7-B725-FBD7AE3C2791">
          <variable id="_95954CA0-092F-4F2B-8FA2-0C644BBBBED0" name="totalscore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_DA27C52C-4911-494B-A315-81EFE5BD1589" typeRef="number" label="totalscore">
            <text>ratingscore + deliveryscore + compliancescore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_A965FA01-8CB9-4D17-9018-F2281F0A5BE5">
          <variable id="_BC28D678-4612-4012-8957-413B07890634" name="ContextEntry-5">
            <description></description>
          </variable>
          <literalExpression id="_1DE3BDB1-E350-49DC-AE95-EDAB7FA624D2" label="ContextEntry-5">
            <text>totalscore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_22D6060B-6405-4B56-967F-BF03CE1C63F7">
          <conditional id="_B00CBA1F-DE7E-457B-8C3B-D25CB6ACDA11" label="Return">
            <if id="_8FEF6456-F57F-4324-87DD-818C2624F65D">
              <literalExpression id="_9B806CA4-18D9-4819-822D-696A81A13FB5" label="Expression Name">
                <text>vendor.deliverydays&lt;=3</text>
              </literalExpression>
            </if>
            <then id="_B3A80C87-D68A-4908-B8B4-552A58058988">
              <literalExpression id="_0D8861CF-A5C8-4A5A-B586-BCB77C4433D2" label="Expression Name">
                <text>30</text>
              </literalExpression>
            </then>
            <else id="_BFD3CF4A-AF52-46F5-A092-14065CB37129">
              <literalExpression id="_64DFF28A-265C-4923-B5C1-6F39E8862F7C" label="Expression Name">
                <text>10</text>
              </literalExpression>
            </else>
          </conditional>
        </contextEntry>
      </context>
    </encapsulatedLogic>
    <knowledgeRequirement id="_6C03AA49-CA27-4C95-B44D-EFDCCB187A2D">
      <requiredKnowledge href="#_0D95072A-7600-4918-BD7B-A59616E28301" />
    </knowledgeRequirement>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="calculatevendorrating" id="_0D95072A-7600-4918-BD7B-A59616E28301">
    <variable name="calculatevendorrating" id="_6C1C5AAF-5E2C-45B6-97CB-1B4DBC863A19" typeRef="number" />
    <encapsulatedLogic label="calculatevendorrating" typeRef="number" id="_5CC6CD2F-44B4-4885-8D96-50845984347C" kind="FEEL">
      <formalParameter id="_0F151C90-25EC-4AB8-93CB-53D3AEB64751" name="vendor" typeRef="vendor" />
      <literalExpression id="_B114F757-6CD7-44C9-8227-6007C3B3865B" typeRef="number" label="Return">
        <text>vendor.rating * 10</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
