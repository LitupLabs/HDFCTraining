  <decision name="totalBureauOverDue" id="_FE9A31CE-5C45-4448-83BE-C07F26B46BD8">
    <variable name="totalBureauOverDue" id="_C871D6DC-F8AE-49FD-94E6-6B176302B7C0" typeRef="number" />
    <informationRequirement id="_E6A9FE53-6471-44AA-A155-55F8576044FB">
      <requiredInput href="#_4E424C55-6A42-4349-84BC-84334D228350" />
    </informationRequirement>
    <context id="_FB40893A-B3F8-4438-BDFE-F87B798E385B" typeRef="number" label="totalBureauOverDue">
      <contextEntry id="_06856EE3-0906-4DBF-9980-05C07BDA24D2">
        <variable id="_3E87F4F2-D37A-4637-BF5C-361BD7022D48" name="for_loop" typeRef="overdue" />
        <for id="_7EC470AF-5588-442B-8205-867DED580A56" typeRef="overdue" label="for_loop" iteratorVariable="o">
          <in id="_D1D87D6F-836F-44CA-9C71-DDE02D699151">
            <literalExpression id="_F3FC4B73-5B61-46FA-BC65-555BB91B53C4" label="Expression Name">
              <text>tradeline</text>
            </literalExpression>
          </in>
          <return id="_E07DFF93-D929-4C65-90F2-35D59A48246C">
            <literalExpression id="_B89A53FB-BA6D-49E6-A7CD-D84D5D0161AA" label="Expression Name">
              <text>if o.tl_overdue_amount = null then 0 else o.tl_overdue_amount</text>
            </literalExpression>
          </return>
        </for>
      </contextEntry>
      <contextEntry id="_9412D1EE-7531-424F-AB2E-BF0B730CFE46">
        <literalExpression id="_96B44E1F-7339-460D-A4FF-DBE71F94482B" typeRef="number" label="totalBureauOverDue">
          <text>sum(for_loop)</text>
        </literalExpression>
      </contextEntry>
      <contextEntry id="_CCE0F5D3-D32B-44F1-A1D8-F816BCD0F36E">
        <literalExpression id="_96B44E1F-7339-460D-A4FF-DBE71F94482B" typeRef="number" label="totalBureauOverDue">
          <text>sum(for_loop)</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
