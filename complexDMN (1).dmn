  <decision name="Item Totals" id="_E5CE8033-84D1-42E7-8D2E-D961292D606D">
    <variable name="Item Totals" id="_DE863B32-F2D7-46DA-A997-0F7A2130168D" typeRef="ItemTotal" />
    <informationRequirement id="_D0AE81B8-FD52-4EFA-B384-D12C283180B4">
      <requiredInput href="#_56DBDCE7-0629-4E91-9127-370AE11635D7" />
    </informationRequirement>
    <knowledgeRequirement id="_7D8329AC-DD0D-4E9F-9BA1-D0A169C9DE90">
      <requiredKnowledge href="#_0F955EB6-0397-45EA-AEFE-AB6EC4669D70" />
    </knowledgeRequirement>
    <for id="_647A2FC5-0E31-4210-82C9-755554933724" typeRef="ItemTotal" label="Item Totals" iteratorVariable="item">
      <in id="_FAF2E595-2353-4064-90B8-05E897730196">
        <literalExpression id="_8A06DAC7-03AF-47F2-B4DA-F374796AA11D" label="Expression Name">
          <text>PurchaseRequest.items</text>
        </literalExpression>
      </in>
      <return id="_9E038D89-D4E7-4E23-9C91-99FB95A3BCEB">
        <literalExpression id="_3BCCB833-00E3-4B63-B8A7-6CB7F7D87606" label="Expression Name">
          <text>Calculate Item Total(item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="Total Procurement Cost" id="_A188FC08-6704-48FD-B687-761FD75B6773">
    <variable name="Total Procurement Cost" id="_767317E5-8723-46A1-BEB0-102A7027D62F" typeRef="number" />
    <informationRequirement id="_49B45833-9FED-479F-9DAF-88EDEE17D070">
      <requiredDecision href="#_E5CE8033-84D1-42E7-8D2E-D961292D606D" />
    </informationRequirement>
    <literalExpression id="_A3830A05-BDEF-4E68-A843-ECB7A7C8FDBB" typeRef="number" label="Total Procurement Cost">
      <text>sum(Item Totals)</text>
    </literalExpression>
  </decision>
  <decision name="Eligible Vendors" id="_169AF82F-1910-4465-858F-D57C8780F762">
    <variable name="Eligible Vendors" id="_C9B1EA18-87F9-44E0-BF46-5AC7B2C0CB18" typeRef="VendorList" />
    <informationRequirement id="_1EC3593E-5283-4171-9264-6071C9ABCB2B">
      <requiredInput href="#_81EE490F-E3FF-43A3-ABAC-29B3615D9EBB" />
    </informationRequirement>
    <informationRequirement id="_F4564380-9E2A-44E1-B489-DDA6B1006B79">
      <requiredInput href="#_5BF5E4DB-5BE4-4572-A85E-7659D26AD5DA" />
    </informationRequirement>
    <knowledgeRequirement id="_A2F38A79-8DCB-4406-8BFC-B8649E3BE9D8">
      <requiredKnowledge href="#_9B71226F-B2A1-44C8-8C35-BC47A72B96A1" />
    </knowledgeRequirement>
    <filter id="_B0C321C8-DBC5-429B-A334-6544A04A46A4" typeRef="VendorList" label="Eligible Vendors">
      <in id="_084D3982-0800-4D19-A9A8-D34E4E34A0A0">
        <literalExpression id="_4AF585EA-394A-406A-AAEE-10ABB70E7C57" label="Expression Name">
          <text>Vendors</text>
        </literalExpression>
      </in>
      <match id="_AFCFC0D9-7E33-47AC-B919-98E3C3708294">
        <literalExpression id="_CA98B8AC-12DE-42B7-9976-709E3F17D570" label="Expression Name">
          <text>Is Vendor Eligible(item,Policies)</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <businessKnowledgeModel name="Calculate Item Total" id="_0F955EB6-0397-45EA-AEFE-AB6EC4669D70">
    <variable name="Calculate Item Total" id="_44237A8A-309D-4DCE-A266-E5EDD947F471" typeRef="number" />
    <encapsulatedLogic label="Calculate Item Total" typeRef="number" id="_1633B51A-ABC6-433C-8F5E-F09EA1CB05A1" kind="FEEL">
      <formalParameter id="_D0BE7831-30A5-48A2-B022-58CE9A79A3BC" name="item" typeRef="Item" />
      <literalExpression id="_5DB3FEAE-6BAD-4D03-B5D8-9C5689996C0D" typeRef="number" label="Return">
        <text>if item.quantity = null or item.unitPrice = null then 0 else item.quantity * item.unitPrice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Is Vendor Eligible" id="_9B71226F-B2A1-44C8-8C35-BC47A72B96A1">
    <variable name="Is Vendor Eligible" id="_FB7AEBF4-0CEC-4A5B-849B-3B5A1589E34B" typeRef="boolean" />
    <encapsulatedLogic label="Is Vendor Eligible" typeRef="boolean" id="_E54342FF-9988-4C79-B86E-AA8231A5C8A9" kind="FEEL">
      <formalParameter id="_B49B395F-FEE3-4F6A-9529-FCEAD64A5119" name="vendor" typeRef="Vendor" />
      <formalParameter id="_B07EE0E8-A238-4F88-8893-CCCA0DDA8F81" name="policies" typeRef="Policies" />
      <conditional id="_B53DB7DE-5A18-4604-8D21-3258A0817122" label="Return">
        <if id="_E2E43710-8C46-4E6D-BB73-C4F2FE0C75D4">
          <literalExpression id="_766342A1-3FD4-490B-B6D9-17E0F4A3CA4C" label="Expression Name">
            <text>vendor.complianceScore &gt;=policies.minComplianceScore and vendor.deliveryDays &lt;= policies.maxDeliveryDays</text>
          </literalExpression>
        </if>
        <then id="_8C329BDB-1313-4C1C-8BCD-3E11A0595992">
          <literalExpression id="_1BEF3EED-994C-44C6-94D5-1A780007890A" label="Expression Name">
            <text>true</text>
          </literalExpression>
        </then>
        <else id="_3F90043F-B268-4491-A2A1-0320D961292F">
          <literalExpression id="_72197EDD-692C-47EA-9881-C836E2538DF3" label="Expression Name">
            <text>false</text>
          </literalExpression>
        </else>
      </conditional>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Score" id="_5F07BF3F-9B51-4AB9-9095-5A5A4998FD29">
    <variable name="Calculate Vendor Score" id="_B0E009D2-6F07-4C22-A136-67E9406BB9BE" typeRef="number" />
    <encapsulatedLogic label="Calculate Vendor Score" id="_7E0F7E2C-3994-411E-B3DF-91B86A670FDE" kind="FEEL">
      <formalParameter id="_8199A74E-370C-4723-8B34-5425329CD515" name="vendor" typeRef="Vendor" />
      <context id="_736177BC-1F2D-4F73-8612-DAE023CAED91" label="Return">
        <contextEntry id="_6E9FDD65-7FD2-486C-8CF9-3BD831BB317C">
          <variable id="_00DCB73B-047E-40FC-A41C-CCC3A0C93C67" name="ratingScore" typeRef="number" />
          <literalExpression id="_663B9098-A0A7-4324-8AB9-B3AD59F9EA5D" typeRef="number" label="ratingScore">
            <text>Calculate Vendor Rating(vendor)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_86C66288-3CA1-49EF-9115-27FF68D85CE1">
          <variable id="_5F151232-DDBB-4177-ABA9-08A77C0AD6DE" name="deliveryScore" typeRef="number">
            <description></description>
          </variable>
          <conditional id="_0EAF79B4-2D49-4E6C-8451-135C2CDC626C" typeRef="number" label="deliveryScore">
            <if id="_49310EFE-F436-4B87-84EB-92FA520B1460">
              <literalExpression id="_7B58B078-6BF0-443C-959B-883E77FF69D1" label="Expression Name">
                <text>vendor.deliveryDays&lt;=3</text>
              </literalExpression>
            </if>
            <then id="_825306C8-526E-4D95-B101-FFCF4905D766">
              <literalExpression id="_095CFA98-9008-41AA-AE48-849F584CFED7" label="Expression Name">
                <text>30</text>
              </literalExpression>
            </then>
            <else id="_1CFA6887-57CB-4A65-99B1-0CEB06D99663">
              <literalExpression id="_41D49FE8-36F5-47A5-8579-9731259C5EB7" label="Expression Name">
                <text>10</text>
              </literalExpression>
            </else>
          </conditional>
        </contextEntry>
        <contextEntry id="_68FDC4FB-D039-4862-8249-93F0BBF549D3">
          <variable id="_BD9FB379-AF67-4F9D-9AFE-FA69DDCCFA60" name="Return" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_98C1FFE1-F53A-4876-86C1-9A69D9538DAF" label="Return">
            <text>vendor.complianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_809F085C-0672-4C81-8CBC-69805ACFCDC4">
          <variable id="_8E1C8EDE-2004-4C04-AF75-A01DC5D11C20" name="totalScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_24A78D8B-ABAD-465F-8F19-BC1BBBD87C10" typeRef="number" label="totalScore">
            <text>ratingScore + deliveryScore + complianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_0C4C5785-7DAD-4E40-85D5-8041BA1DAA1A">
          <literalExpression id="_98C1FFE1-F53A-4876-86C1-9A69D9538DAF" label="Return">
            <text>totalScore</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
    <knowledgeRequirement id="_2A27CE72-CFEE-4BD2-9EB5-8A9A391BCA85">
      <requiredKnowledge href="#_DB754D57-2BEF-40D3-B20C-1E04663AEC0A" />
    </knowledgeRequirement>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Rating" id="_DB754D57-2BEF-40D3-B20C-1E04663AEC0A">
    <variable name="Calculate Vendor Rating" id="_5E63574E-13FE-4917-96CF-B481DBF8B63F" typeRef="number" />
    <encapsulatedLogic label="Calculate Vendor Rating" typeRef="number" id="_14814567-E00E-4BF4-AABA-6455017EB82F" kind="FEEL">
      <formalParameter id="_C68781C7-4877-4CE9-A03B-4796B7B9308E" name="vendor" typeRef="Vendor" />
      <literalExpression id="_5A70942C-4172-4CE9-B597-CBCD917B798D" typeRef="number" label="Return">
        <text>vendor.rating * 10</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
