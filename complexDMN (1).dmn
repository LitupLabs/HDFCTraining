  <businessKnowledgeModel name="Calculate Item Total" id="_CBEFDCE7-F8EE-4429-BEE9-A8A3D7E6FE33">
    <variable name="Calculate Item Total" id="_81511AC4-09A3-4F6E-AB20-F15932ADFBBF" typeRef="number" />
    <encapsulatedLogic label="Calculate Item Total" typeRef="number" id="_7E734984-E1D4-49EF-941F-9292F77922ED" kind="FEEL">
      <formalParameter id="_9B000484-D534-493A-8FD2-BACE644927B2" name="Item" typeRef="Item" />
      <literalExpression id="_EEA4811A-AE0B-4779-BF05-B3D6CD97920C" label="Return">
        <text>if Item.quantity = null or Item.unitPrice = null then 0 else Item.quantity * Item.unitPrice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Is Vendor Eligible" id="_4A37B64F-C1E0-44A8-97DA-F08BAEAD11A4">
    <variable name="Is Vendor Eligible" id="_42CC87A4-AD8D-44E4-B0FF-80A3C7029A91" typeRef="boolean" />
    <encapsulatedLogic label="Is Vendor Eligible" typeRef="boolean" id="_5703C895-7ED9-435F-97E1-81B10EBCA63F" kind="FEEL">
      <formalParameter id="_09D9F572-9449-4EA1-9443-8FAAE29C59EA" name="vendor" typeRef="Vendor" />
      <formalParameter id="_C211BC17-DCC7-4170-995D-B83B23B93672" name="policies" typeRef="Policies" />
      <conditional id="_6B6856D5-B543-4C37-97AD-3CFC794FE0D1" label="Return">
        <if id="_D67F135D-D6F0-4760-803F-1AB6531BA69D">
          <literalExpression id="_FDAA6A08-0156-4102-8F6B-B399FB448D83" label="Expression Name">
            <text>vendor.complianceScore &gt; policies.minComplianceScore and vendor.deliveryDays &lt;= policies.maxDeliveryDays</text>
          </literalExpression>
        </if>
        <then id="_118F4327-89B2-41E0-BD1E-0A705AEF51D1">
          <literalExpression id="_2B0D9079-0A96-430B-A82B-F9C29CDC1E45" label="Expression Name">
            <text>true</text>
          </literalExpression>
        </then>
        <else id="_575A7DB4-E6D6-40B7-8507-56051CE84FC8">
          <literalExpression id="_08FF18D5-E368-4C5C-BAE0-60F2FFF59F72" label="Expression Name">
            <text>false</text>
          </literalExpression>
        </else>
      </conditional>
    </encapsulatedLogic>
  </businessKnowledgeModel>
