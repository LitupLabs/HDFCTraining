    <for id="_CD9922E1-4315-44F2-9458-7EC9F5FB780A" label="Item Totals" iteratorVariable="item">
      <in id="_FC50FB5F-F820-42F2-AA8A-13250695DAD5">
        <literalExpression id="_B2BEF86C-A7E4-40C1-B4A1-B263D076CCC8" label="Expression Name">
          <text>PurchaseRequest.items</text>
        </literalExpression>
      </in>
      <return id="_2557E4D9-CCBA-42D1-B36D-A419C357286A">
        <literalExpression id="_3CB6827D-BFD4-45D9-BF7A-D6864D35A9FC" label="Expression Name">
          <text>Calculate Item Total(item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <businessKnowledgeModel name="Calculate Item Total" id="_CBEFDCE7-F8EE-4429-BEE9-A8A3D7E6FE33">
    <variable name="Calculate Item Total" id="_81511AC4-09A3-4F6E-AB20-F15932ADFBBF" typeRef="number" />
    <encapsulatedLogic label="Calculate Item Total" typeRef="number" id="_7E734984-E1D4-49EF-941F-9292F77922ED" kind="FEEL">
      <formalParameter id="_9B000484-D534-493A-8FD2-BACE644927B2" name="item" typeRef="Item" />
      <literalExpression id="_EEA4811A-AE0B-4779-BF05-B3D6CD97920C" label="Return">
        <text>item.quantity = null or item.unitPrice = null then 0 else item.quantity * item.unitPrice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
