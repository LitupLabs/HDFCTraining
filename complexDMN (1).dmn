      <requiredInput href="#_F69A7E9B-1094-4B09-8F4C-FF3A3F64F62E" />
    </informationRequirement>
    <knowledgeRequirement id="_BED7E9E8-B93C-4886-900F-E16A98E2DB43">
      <requiredKnowledge href="#_CBEFDCE7-F8EE-4429-BEE9-A8A3D7E6FE33" />
    </knowledgeRequirement>
    <for id="_CD9922E1-4315-44F2-9458-7EC9F5FB780A" typeRef="ItemTotal" label="Item Totals" iteratorVariable="item">
      <in id="_AA89BE5F-0391-4569-93EB-B84F81E6396B">
        <literalExpression id="_B2BEF86C-A7E4-40C1-B4A1-B263D076CCC8" label="Expression Name">
          <text>Purchase Request.items</text>
        </literalExpression>
      </in>
      <return id="_FD935954-4A48-485F-B8D6-D3C03DAAB69B">
        <literalExpression id="_3CB6827D-BFD4-45D9-BF7A-D6864D35A9FC" label="Expression Name">
          <text>Calculate Item Total(item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
