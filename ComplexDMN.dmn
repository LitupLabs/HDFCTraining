  <decision name="ItemTotal" id="_6425976E-C74A-468A-A45A-9923D3D1F000">
    <variable name="ItemTotal" id="_EDFBC362-A86E-4AAD-8707-29D60C9D05A0" typeRef="Amount" />
    <informationRequirement id="_40BE3723-24DC-4600-80E1-236839494897">
      <requiredInput href="#_EC5592E0-4861-4279-9412-E0F98CF05D7D" />
    </informationRequirement>
    <knowledgeRequirement id="_67877894-60DB-48FA-A0F6-6F213EA14F22">
      <requiredKnowledge href="#_7FC0D9DA-C2D8-40F2-B0AF-D881BE2A56BB" />
    </knowledgeRequirement>
    <for id="_F20FB6B7-ABB4-41E2-AAD4-C84DEAB36F95" typeRef="Amount" label="ItemTotal" iteratorVariable="item">
      <in id="_F7BAEA06-E4C1-4B56-885F-A66B6ED0BB48">
        <literalExpression id="_971EA25F-0E2C-4B9B-B7A9-6512DAB13C3D" label="Expression Name">
          <text>PurchaseRequest.items</text>
        </literalExpression>
      </in>
      <return id="_408D6719-8615-40B3-BFAF-90E0A49CC9F5">
        <literalExpression id="_2A3BAC37-9133-461A-8CD3-842765CC6B93" label="Expression Name">
          <text>CalItemTotal(item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="totalProcurementCost" id="_2DC52B78-44F3-488D-9B7E-853B57815A51">
    <variable name="totalProcurementCost" id="_1E508995-E6A9-4062-964A-6053C3B59611" typeRef="number" />
    <informationRequirement id="_C8A9089D-13C1-49B7-A814-58AD2FCEEF7A">
      <requiredDecision href="#_06390C8F-D2EF-490F-8D57-8E989328F6E8" />
    </informationRequirement>
    <literalExpression id="_BA4261B2-7035-4A27-8C8A-D82D1207B063" typeRef="number" label="totalProcurementCost">
      <text>sum(FilteredItem Totals)</text>
    </literalExpression>
  </decision>
  <decision name="eligibleVendors" id="_53666FB8-7605-4950-B986-2CAD8D1B5DED">
    <variable name="eligibleVendors" id="_49CD2AC3-E177-4132-9F25-BBBDF6A468C1" typeRef="VendorList" />
    <informationRequirement id="_BF718330-BA0C-4355-899C-CD4A920844CB">
      <requiredInput href="#_A5135249-D507-4321-AA64-5A13B1529F3A" />
    </informationRequirement>
    <informationRequirement id="_DC03B4AF-5138-4EF4-BD05-E77E41EC7930">
      <requiredInput href="#_71F38F71-854D-486E-8568-A7741B13DFB9" />
    </informationRequirement>
    <knowledgeRequirement id="_FAB3818B-CCA9-4CFB-8C2E-002CEA9C3412">
      <requiredKnowledge href="#_178AF838-B108-45B3-9C1F-490C4F86E3DB" />
    </knowledgeRequirement>
    <filter id="_D2B0A698-AF46-4600-8E49-BE3529F691AA" typeRef="VendorList" label="eligibleVendors">
      <in id="_566B60EE-F6AB-47FD-9763-764641DC4172">
        <literalExpression id="_25BC65E1-C489-4AEF-A1E2-9A51B9BE54AF" label="Expression Name">
          <text>Vendors</text>
        </literalExpression>
      </in>
      <match id="_FB017884-0F37-4587-BB36-F901D4332AE4">
        <literalExpression id="_E05F70CB-7B1E-4389-8B8C-85DC4E028A96" label="Expression Name">
          <text>IsVendorEligible(item,Policies)</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="FilteredItem Totals" id="_06390C8F-D2EF-490F-8D57-8E989328F6E8">
    <variable name="FilteredItem Totals" id="_BE92D11E-C227-46F9-A97A-1E3C709C9D8F" typeRef="Amount" />
    <informationRequirement id="_80B56AF4-DF97-4479-96EE-F20393B0DCB9">
      <requiredDecision href="#_6425976E-C74A-468A-A45A-9923D3D1F000" />
    </informationRequirement>
    <filter id="_EDAAF317-3DCD-4514-AB85-356E2A2009B1" typeRef="Amount" label="FilteredItem Totals">
      <in id="_94DCDBF5-8681-43FF-8740-84ADA29C9F98">
        <literalExpression id="_5B7CDEFA-D92B-43EA-BD06-3CAA8B2BBA7A" label="Expression Name">
          <text>ItemTotal</text>
        </literalExpression>
      </in>
      <match id="_F7C56E8B-81A1-4F53-9182-EF8FB9B772CF">
        <literalExpression id="_8F3BB283-A6AF-4D20-A2FB-DBBC098FE36B" label="Expression Name">
          <text>item!=0</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Scored Vendors" id="_AC7660AC-317B-4228-BDC1-29EA64046ACA">
    <variable name="Scored Vendors" id="_054D5058-CD5E-4FF9-8F91-3C4700222E45" typeRef="ScoredVendorList" />
    <informationRequirement id="_A929043E-FE22-4DAD-910E-DF549B79F1F4">
      <requiredDecision href="#_53666FB8-7605-4950-B986-2CAD8D1B5DED" />
    </informationRequirement>
    <knowledgeRequirement id="_2EF5253A-91DC-4445-B84C-3F7907EA0A3D">
      <requiredKnowledge href="#_732E7991-A9FE-4B39-8DB3-A94228EBE565" />
    </knowledgeRequirement>
    <literalExpression id="_4A2CD289-5C68-44E3-AC20-96A383F1B9AC" typeRef="ScoredVendorList" label="Scored Vendors">
      <text>for v in eligibleVendors return {vendorId:v.vendorId, score: calVendorScore(v), basePriceFactor:  v.basePriceFactor }</text>
    </literalExpression>
  </decision>
  <decision name="Best Vendor" id="_59511A81-63C2-4DEF-B089-A531CB7AC31F">
    <variable name="Best Vendor" id="_0EBD5682-3E41-4894-8EE3-9E613035BE5B" typeRef="ScoredVendor" />
    <informationRequirement id="_5FA83D91-DEC9-4338-AD48-7A0580C5173D">
      <requiredDecision href="#_AC7660AC-317B-4228-BDC1-29EA64046ACA" />
    </informationRequirement>
    <filter id="_002A0160-7641-4B78-8EF6-5A275C77D21E" typeRef="ScoredVendor" label="Best Vendor">
      <in id="_2E31F375-5877-4334-A84F-BFC62E147EB8">
        <literalExpression id="_EF5B363B-042A-40BB-80C0-63F100EFCB69" label="Expression Name">
          <text>Scored Vendors</text>
        </literalExpression>
      </in>
      <match id="_6225D19E-9428-4394-BAEB-12BD31F6E1B5">
        <literalExpression id="_984FB1B4-4F80-4B5B-AD4C-518CF1F22EC4" label="Expression Name">
          <text>item.score=max(Scored Vendors.score)</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Final Vendor Cost" id="_C34ED718-E249-4BA5-90AB-2BB4089E537D">
    <variable name="Final Vendor Cost" id="_6BA4CC1E-90E0-4B3D-B162-C7C60057F28C" typeRef="ScoredVendor" />
    <informationRequirement id="_5E9E0EB8-21A3-40A0-B4D8-EF93074EC698">
      <requiredDecision href="#_59511A81-63C2-4DEF-B089-A531CB7AC31F" />
    </informationRequirement>
    <informationRequirement id="_EC41501E-CE1F-4A6D-A45B-A8EBCBABC817">
      <requiredDecision href="#_2DC52B78-44F3-488D-9B7E-853B57815A51" />
    </informationRequirement>
    <literalExpression id="_14540ABC-2074-4A46-960B-AC5E7D2B6CE4" typeRef="ScoredVendor" label="Final Vendor Cost">
      <text>for v in Best Vendor return {vendorId: v.vendorId ,score : totalProcurementCost * v.basePriceFactor, basePriceFactor: v.basePriceFactor}</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="CalItemTotal" id="_7FC0D9DA-C2D8-40F2-B0AF-D881BE2A56BB">
    <variable name="CalItemTotal" id="_21BB93C7-CEDE-423E-A03D-442C7F7BA2EA" typeRef="number" />
    <encapsulatedLogic label="CalItemTotal" typeRef="number" id="_AEDC34A7-0824-410D-907D-42139CFCB3E0" kind="FEEL">
      <formalParameter id="_1A2187C6-0545-494D-B83F-1552B6E3628A" name="item" typeRef="Item" />
      <literalExpression id="_A1B15FA2-40D6-4F93-9141-00457A7F5C44" typeRef="number" label="Return">
        <text>if item.quantity = null or item.unitPrice = null then 0 else item.quantity * item.unitPrice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="IsVendorEligible" id="_178AF838-B108-45B3-9C1F-490C4F86E3DB">
    <variable name="IsVendorEligible" id="_CAF1D1F5-7FA0-40EE-850A-E88B9354F234" typeRef="boolean" />
    <encapsulatedLogic label="IsVendorEligible" typeRef="boolean" id="_EA536183-025E-434C-9316-7B4489AC97F0" kind="FEEL">
      <formalParameter id="_A6110343-7703-4152-A71B-D3B22CCC987B" name="vendor" typeRef="Vendor" />
      <formalParameter id="_9CF65D69-B4B7-4FC4-8868-121B92058AD3" name="policies" typeRef="Policies" />
      <literalExpression id="_FB90E9DC-C593-4EB5-A077-30D249C491A5" typeRef="boolean" label="Return">
        <text>vendor.complianceScore &gt;= policies.minComplianceScore and vendor.deliveryDays &lt;= policies.maxDeliveryDays</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="calVendorScore" id="_732E7991-A9FE-4B39-8DB3-A94228EBE565">
    <variable name="calVendorScore" id="_ABDC4401-DDF4-47EF-A8AF-613E2496E866" typeRef="number" />
    <encapsulatedLogic label="calVendorScore" typeRef="number" id="_80264984-BBC6-4FF3-B273-E2B94663ACBC" kind="FEEL">
      <formalParameter id="_85B85EC2-3442-43AB-9925-77D9A7688F52" name="vendor" typeRef="Vendor" />
      <context id="_F9DEB9D4-6B1D-4A82-9AA8-63F6431508EC" label="Return">
        <contextEntry id="_B884402C-CB7C-4033-A601-28DC8C2543A3">
          <variable id="_A49DAFBC-C9DC-469F-AC80-A92D9B60B3E8" name="ratingScore" typeRef="number" />
          <literalExpression id="_E610D7DF-B40F-4642-9498-0A8C7FF3FC0C" typeRef="number" label="ratingScore">
            <text>calVendorRating(vendor)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_23A3E0AA-412E-413D-944A-A3EA6BD6381D">
          <variable id="_DEB2F773-C5F4-4336-AF44-E51166798B54" name="deliveryScore" typeRef="number">
            <description></description>
          </variable>
          <conditional id="_8CF0C0A5-DD2F-48F1-B5C2-4A627FD6B4D3" typeRef="number" label="deliveryScore">
            <if id="_ECD7F9EF-E5C8-4AC1-9CF5-F7B731781580">
              <literalExpression id="_5D885360-E25E-4055-B482-C1295FFCA8B1" label="Expression Name">
                <text>vendor.deliveryDays &lt;=2</text>
              </literalExpression>
            </if>
            <then id="_E4EEDB14-9193-43B7-AC9C-DDB2AE3CB688">
              <literalExpression id="_BC36A220-2F0A-4D82-A540-21808424C61E" label="Expression Name">
                <text>20</text>
              </literalExpression>
            </then>
            <else id="_975F580E-58FF-46F3-BFC2-085E3C43BC5D">
              <literalExpression id="_BD804234-FB7A-4D44-849F-73148934BB09" label="Expression Name">
                <text>10</text>
              </literalExpression>
            </else>
          </conditional>
        </contextEntry>
        <contextEntry id="_F3732FA9-3D50-472F-AC26-F4EEDBE21201">
          <variable id="_6F453D6A-DF55-40C6-B124-4A9E9A0DD1B4" name="complianceScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_BB99305A-A4C3-4B9F-A0EE-1818BD007233" typeRef="number" label="complianceScore">
            <text>vendor.complianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_62734CAA-EF86-4EB2-BB00-AC07C8696F6B">
          <variable id="_D3024368-5C99-470B-B7D3-3DD4E073A696" name="totalScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_249B324A-F55B-4499-AC67-F5F7FE9A6E22" typeRef="number" label="totalScore">
            <text>ratingScore + deliveryScore + complianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_E70353DC-A6F1-43CD-88BA-D2638AEE4DA6">
          <literalExpression id="_6594EE5B-D6B1-4F3B-8F7E-E537B4991AF3" label="Return">
