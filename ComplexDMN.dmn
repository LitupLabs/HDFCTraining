  <decision name="Item Totals" id="_70ABAAF1-77FC-4B8C-AE17-3EC3360D95A2">
    <variable name="Item Totals" id="_A842328A-AEA7-4E95-8719-F0DF5E0A132B" typeRef="Amount" />
    <informationRequirement id="_8DBA2A1B-D97F-45DB-8AEB-DB69E1FE1A97">
      <requiredInput href="#_955BE7CC-3CD2-47BB-B281-13398D86F372" />
    </informationRequirement>
    <knowledgeRequirement id="_F226E9AF-0708-4B88-92FE-94835F4B7E4B">
      <requiredKnowledge href="#_6F73EC22-0051-4D2B-ADA3-FB830EB154C1" />
    </knowledgeRequirement>
    <for id="_77810447-5931-4F08-9718-E5398662159B" typeRef="Amount" label="Item Totals" iteratorVariable="item">
      <in id="_38947E13-3ED5-4CDC-BBAF-94816B5DE806">
        <literalExpression id="_DC1228F6-44A7-4217-ABA9-AD13B78CA502" label="Expression Name">
          <text>PurchaseRequest.items</text>
        </literalExpression>
      </in>
      <return id="_3C77A339-30BA-4703-9A70-A75A670C2298">
        <literalExpression id="_B05783E1-7909-4457-BDF2-AE7CC85CF863" label="Expression Name">
          <text>Calculate Item Total(item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="Total Procurement Cost" id="_7044F7C5-007A-4A34-AB6C-814DDB8E3EDC">
    <variable name="Total Procurement Cost" id="_3376BB65-4115-4531-B051-53035E68A37B" typeRef="number" />
    <informationRequirement id="_681FCEBC-531E-4255-AD2E-1367CCF005CB">
      <requiredDecision href="#_999F4139-61C9-472A-930A-3120D749374D" />
    </informationRequirement>
    <literalExpression id="_90CFB02F-0145-42DE-8474-30A0A7D79247" typeRef="number" label="Total Procurement Cost">
      <text>sum(Filtered Item Totals)</text>
    </literalExpression>
  </decision>
  <decision name="Eligible Vendors" id="_18476A7B-2C29-4DB8-ADCD-3E30332A85F7">
    <variable name="Eligible Vendors" id="_2466ECE1-2C86-4F52-89E1-68EB856227B4" typeRef="VendorList" />
    <informationRequirement id="_89CCF396-BE33-4226-B4AB-36C9631664B9">
      <requiredInput href="#_900A773B-C06D-4692-91D1-529F36481EF9" />
    </informationRequirement>
    <informationRequirement id="_0641381C-EC4E-4530-976D-3BCDED49D49E">
      <requiredInput href="#_22FD2A3D-1FDF-43F3-ACDB-4365830867C2" />
    </informationRequirement>
    <knowledgeRequirement id="_3F2FB65A-CE7B-487E-B4E8-D18C37A915CB">
      <requiredKnowledge href="#_A9B0EF4E-94E1-42AF-A783-255143D035B8" />
    </knowledgeRequirement>
    <filter id="_CCA30894-B958-4D1C-B649-F80BF99579A8" typeRef="VendorList" label="Eligible Vendors">
      <in id="_D2B338EC-3404-4713-9573-EC08CAD0AE2F">
        <literalExpression id="_A6C231CF-0D06-4B3D-90B3-7DC2DFF4C5F5" label="Expression Name">
          <text>Vendors</text>
        </literalExpression>
      </in>
      <match id="_F33E7220-58BC-4470-A05A-F9176D38B8F7">
        <literalExpression id="_B500C6D5-84EE-4A81-870B-0EBFEB80F918" label="Expression Name">
          <text>Is Vendor Eligible(item,Policies)</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Filtered Item Totals" id="_999F4139-61C9-472A-930A-3120D749374D">
    <variable name="Filtered Item Totals" id="_24ADAF3D-3ED9-4F7D-BD0D-C61579C7CCCC" typeRef="Amount" />
    <informationRequirement id="_F50E9D18-E982-433D-AD2D-D92101FD8421">
      <requiredDecision href="#_70ABAAF1-77FC-4B8C-AE17-3EC3360D95A2" />
    </informationRequirement>
    <filter id="_EE66E0FC-5D54-44F3-9D0D-D3C3FD7C5B46" typeRef="Amount" label="Filtered Item Totals">
      <in id="_D57E0FA6-6E70-4E2F-8E39-830C9B63806C">
        <literalExpression id="_FE88490C-D999-4D6A-BC38-47EE7506A214" label="Expression Name">
          <text>Item Totals</text>
        </literalExpression>
      </in>
      <match id="_03EF4A4F-D0BA-45E8-ABB5-422B371F026F">
        <literalExpression id="_941D03E3-996B-4DD0-B9F2-F9FC6F01C50B" label="Expression Name">
          <text>item !=0</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Scored Vendors" id="_6328711D-05F3-4022-957B-79E7AD372723">
    <variable name="Scored Vendors" id="_909AD00D-3CDD-45DE-B204-711795419216" typeRef="ScoredVendorList" />
    <informationRequirement id="_DF1E554D-D852-40D4-A4C8-0A21E05BAB1A">
      <requiredDecision href="#_18476A7B-2C29-4DB8-ADCD-3E30332A85F7" />
    </informationRequirement>
    <knowledgeRequirement id="_F4DB48A1-841D-4833-9E62-4AADB125E06D">
      <requiredKnowledge href="#_70909945-C9D7-44C8-B8D9-2FEDA39F6B30" />
    </knowledgeRequirement>
    <literalExpression id="_D8CF2E4A-ACDC-411F-BA15-E6C0224FF5D6" typeRef="ScoredVendorList" label="Scored Vendors">
      <text>for v in Eligible Vendors
return {
vendorId: v.vendorId,
score: Calculate Vendor Score(v),
basePriceFactor: v.basePriceFactor
}</text>
    </literalExpression>
  </decision>
  <decision name="Best Vendor" id="_2467E1F1-3DF5-4441-8BEA-07D8664D9378">
    <variable name="Best Vendor" id="_3DFD527E-6F5E-4E68-A1FC-B502402DD56F" typeRef="ScoredVendor" />
    <informationRequirement id="_060FED3C-46CC-459D-9B5F-E26E5137CA31">
      <requiredDecision href="#_6328711D-05F3-4022-957B-79E7AD372723" />
    </informationRequirement>
    <filter id="_7F0555DB-6895-4255-BA65-EDFF61600D4C" typeRef="ScoredVendor" label="Best Vendor">
      <in id="_EEADE711-338B-4CFA-990F-82576D3D3DD2">
        <literalExpression id="_522C729F-41A0-4237-A0D0-F5B788FF2297" label="Expression Name">
          <text>Scored Vendors</text>
        </literalExpression>
      </in>
      <match id="_EF10D5BE-C183-43DD-B523-F21A356D90C2">
        <literalExpression id="_E7B55B1A-66A1-4E33-B109-AB0E09A26A33" label="Expression Name">
          <text>item.score=max(Scored Vendors.score)
 </text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Final Vendor" id="_63276C3F-BC77-47BF-8BBE-E72E6A12003B">
    <variable name="Final Vendor" id="_F0CD4ACA-3957-44E7-B380-2D8464E2C1B4" typeRef="ScoredVendor" />
    <informationRequirement id="_C800D4CE-F2FA-45B9-9598-B5D2B0E88CDF">
      <requiredDecision href="#_7044F7C5-007A-4A34-AB6C-814DDB8E3EDC" />
    </informationRequirement>
    <informationRequirement id="_CFE0833D-0AFD-465D-8EE1-0FA07FF8412E">
      <requiredDecision href="#_2467E1F1-3DF5-4441-8BEA-07D8664D9378" />
    </informationRequirement>
    <literalExpression id="_BA15E414-B04D-499E-A8D0-C4901C4006CD" typeRef="ScoredVendor" label="Final Vendor">
      <text>for v in Best Vendor
return {
vendorId: v.vendorId,
score: Total Procurement Cost* v.basePriceFactor,
basePriceFactor: v.basePriceFactor
}
 </text>
    </literalExpression>
  </decision>
  <decision name="Approval Decision" id="_74F4FA2C-64F3-4511-A525-FC6F1EC64453">
    <variable name="Approval Decision" id="_0DBD588E-9237-4EFD-94A8-BDA66E11C10E" typeRef="boolean" />
    <informationRequirement id="_5944A212-8E47-45A9-B77B-99A4EE9FC562">
      <requiredDecision href="#_63276C3F-BC77-47BF-8BBE-E72E6A12003B" />
    </informationRequirement>
    <informationRequirement id="_B5AB577C-33D9-491F-8C61-167355D623C4">
      <requiredInput href="#_22FD2A3D-1FDF-43F3-ACDB-4365830867C2" />
    </informationRequirement>
    <literalExpression id="_46DE0942-B439-487F-B803-1CD78F01ECF1" typeRef="boolean" label="Approval Decision">
      <text>Final Vendor . score &gt; Policies.approvalThreshold</text>
    </literalExpression>
  </decision>
  <decision name="Recommended Vendor" id="_61B27A00-07BF-4303-AFD5-6C22D024C670">
    <variable name="Recommended Vendor" id="_36E76AC4-D7BF-4107-9D55-BAC3CA1C344F" typeRef="Recommendation" />
    <informationRequirement id="_8E1C0388-11D6-4AF1-8975-4B27413DF8D7">
      <requiredDecision href="#_63276C3F-BC77-47BF-8BBE-E72E6A12003B" />
    </informationRequirement>
    <informationRequirement id="_7BEDB423-E7A5-4850-A83B-B74C5D386A1F">
      <requiredDecision href="#_74F4FA2C-64F3-4511-A525-FC6F1EC64453" />
    </informationRequirement>
    <literalExpression id="_DCB599AF-EC52-4EF0-95DE-17AA4FD345E7" typeRef="Recommendation" label="Recommended Vendor">
      <text>for v in Final Vendor
return {
selectedVendor: Final Vendor,
approvalRequired: Approval Decision
}</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Calculate Item Total" id="_6F73EC22-0051-4D2B-ADA3-FB830EB154C1">
    <variable name="Calculate Item Total" id="_60D153C5-71CF-4F41-90B5-DD5862988743" typeRef="number" />
    <encapsulatedLogic label="Calculate Item Total" typeRef="number" id="_22B5C2B3-B44A-4DDA-A799-1B2A5C9092EC" kind="FEEL">
      <formalParameter id="_F78297F9-B149-445A-AA93-D4F8945B5EAE" name="item" typeRef="Item" />
      <literalExpression id="_810E0687-E926-47C8-B03A-6075B902BDBF" typeRef="number" label="Return">
        <text>if item.quantity =null or item.unitPrice = null then 0 else item.quantity * item.unitPrice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Is Vendor Eligible" id="_A9B0EF4E-94E1-42AF-A783-255143D035B8">
    <variable name="Is Vendor Eligible" id="_97301227-1CF9-466E-B259-BCFED624E12F" typeRef="boolean" />
    <encapsulatedLogic label="Is Vendor Eligible" typeRef="boolean" id="_29C75B7C-7A70-475D-979A-00AA49AD81B8" kind="FEEL">
      <formalParameter id="_B575A581-5128-4ACE-B397-2C5648F1BEF3" name="vendor" typeRef="Vendor" />
      <formalParameter id="_A199340C-AEB2-43F4-87C6-02B635D93842" name="policies" typeRef="Policies" />
      <conditional id="_C2A36AB0-966C-43D6-8811-2B6D089C0F7A" typeRef="boolean" label="Return">
        <if id="_5DC7F48E-3729-4C85-BADC-6E9CF0783A0A">
          <literalExpression id="_81B3BD85-A5D1-43B6-827F-CB043238FD04" label="Expression Name">
            <text>vendor.complianceScore &gt;= policies.minComplianceScore and vendor.deliveryDays &lt;= policies.maxDeliveryDays</text>
          </literalExpression>
        </if>
        <then id="_71F07F53-0671-413C-853F-FDE37003CC5C">
          <literalExpression id="_2AA3F155-DBF6-4449-B830-D0B3B28F442D" label="Expression Name">
            <text>true</text>
          </literalExpression>
        </then>
        <else id="_54E7F145-8C63-4512-BF07-628580DD027B">
          <literalExpression id="_4312D8B0-0E64-407B-83EE-9C6BE8FA7256" label="Expression Name">
            <text>false</text>
          </literalExpression>
        </else>
      </conditional>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Rating" id="_731AD5B3-3A2E-46BC-8844-586B87BB6F66">
    <variable name="Calculate Vendor Rating" id="_5D599931-8751-46E2-8A29-07295B9C6D75" typeRef="number" />
    <encapsulatedLogic label="Calculate Vendor Rating" typeRef="number" id="_8AF91DC4-7301-4FA2-92D0-CFC514EA4B38" kind="FEEL">
      <formalParameter id="_A99B64FA-C0F1-46C5-8EEE-D2772AAFA5F9" name="vendor" typeRef="Vendor" />
      <literalExpression id="_D7332100-5416-414F-A8F1-41E1A4C7B966" label="Return">
        <text>vendor.rating * 10</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Score" id="_70909945-C9D7-44C8-B8D9-2FEDA39F6B30">
    <variable name="Calculate Vendor Score" id="_46078753-9549-444D-AE17-45EDC7BDBA5E" />
    <encapsulatedLogic label="Calculate Vendor Score" id="_DBB4767A-A97E-4BCF-9FAD-A6ACEA58E41D" kind="FEEL">
      <formalParameter id="_E9CBADFC-150A-4DF8-A0B5-23F46D447379" name="vendor" typeRef="Vendor" />
      <context id="_49950C32-079F-42B5-A4CD-8262F9616239" label="Return">
        <contextEntry id="_87F4709B-FD86-4125-82A7-19BF4925B281">
          <variable id="_EC6E6AC4-BA90-457A-AF16-0E567CE11520" name="ratingScore" typeRef="number" />
          <literalExpression id="_715CEF5D-58EE-4A82-A42D-4F3B4C6B923C" typeRef="number" label="ratingScore">
            <text>Calculate Vendor Rating(vendor)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_84120887-5357-4216-8BCF-94C0BD1629AC">
          <variable id="_C2E900DC-0EDF-4F6E-8447-049E4121008B" name="deliveryScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_8EB46C2C-0F2E-444E-B223-096CC1358D8D" typeRef="number" label="deliveryScore">
            <text>if vendor.deliveryDays &lt;= 5 then 20 else 10</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_CDCED6F7-96CD-4ECB-95A4-A83FA77C4BD1">
          <variable id="_FDF8C7A9-4246-4B9C-980A-527CF458A8D4" name="complianceScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_F87B966A-273D-4F16-A414-33191D27A0FC" typeRef="number" label="complianceScore">
            <text>vendor.complianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_8325D590-51C8-4B93-91D2-C8552242C790">
          <variable id="_4D133338-9605-4390-9803-5BC8E6AD2821" name="totalScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_133EE834-332F-45D2-8D01-FB79887555B6" typeRef="number" label="totalScore">
            <text>ratingScore + deliveryScore +complianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_3BC62D49-7E2F-4F0D-B809-45C365112D4B">
          <literalExpression id="_94D73D75-0915-422D-B066-084D0D1AC526" label="Return">
            <text>totalScore</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
    <knowledgeRequirement id="_99C53906-8D89-41AA-AD60-D4780FAEF202">
      <requiredKnowledge href="#_731AD5B3-3A2E-46BC-8844-586B87BB6F66" />
    </knowledgeRequirement>
  </businessKnowledgeModel>
