  <decision name="Item Totals" id="_BC5FF909-25BB-4E58-A4CF-73BCD386E0A5">
    <variable name="Item Totals" id="_D2B76630-9AEA-444C-98B5-280207B7E3B3" typeRef="ItemTotal" />
    <informationRequirement id="_DAC92875-1DC1-4DFF-8E01-F81A1F53AEFC">
      <requiredInput href="#_6AF234AF-A793-49EE-B617-6D30E85432DD" />
    </informationRequirement>
    <knowledgeRequirement id="_C35CC857-D3B6-4E9D-8D25-480C2D5047CE">
      <requiredKnowledge href="#_8210AB07-7786-4DC3-90C9-E7A9EFF68F1E" />
    </knowledgeRequirement>
    <for id="_8FE34ED6-45F1-4946-AE93-151FF295C18D" typeRef="ItemTotal" label="Item Totals" iteratorVariable="item">
      <in id="_3C8BE4AD-918F-445E-A1EE-5DB93DC9E944">
        <literalExpression id="_C27070B2-38E0-4D97-9D71-E2778AC83E64" label="Expression Name">
          <text>PurchaseRequest.items</text>
        </literalExpression>
      </in>
      <return id="_CBC68451-8DB6-40B1-9B0C-3EB5F054E1BB">
        <literalExpression id="_073372B6-C4C7-4361-9F09-4CE27C039388" label="Expression Name">
          <text>Calculate Item Total(item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="Total Procurement Cost" id="_09DC17B0-2E1C-4805-B62C-85DBB50D1F06">
    <variable name="Total Procurement Cost" id="_4F537D0C-B967-4A5B-B396-25393F8A33BF" typeRef="number" />
    <informationRequirement id="_02DC4215-4525-48E0-8329-181E7DD39018">
      <requiredDecision href="#_BC5FF909-25BB-4E58-A4CF-73BCD386E0A5" />
    </informationRequirement>
    <literalExpression id="_377984D7-ECD9-4655-BBF9-62B2ED643B93" typeRef="number" label="Total Procurement Cost">
      <text>sum(Item Totals)</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Calculate Item Total" id="_8210AB07-7786-4DC3-90C9-E7A9EFF68F1E">
    <variable name="Calculate Item Total" id="_19BF7F64-4E59-4A32-AAC3-D8122832C409" typeRef="number" />
    <encapsulatedLogic label="Calculate Item Total" typeRef="number" id="_AF181F5A-3F23-4F29-A049-D34B3A51387A" kind="FEEL">
      <formalParameter id="_B18D8DDF-6C5E-4594-BD63-906D1E874951" name="Item" typeRef="Item" />
      <literalExpression id="_A1A19103-E2F9-4630-A65B-3AFF1422162A" typeRef="number" label="Return">
        <text>if Item.quantity = null or Item.unitPrice = null then 0 else Item.quantity * Item.unitPrice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Is Vendor Eligible" id="_31128800-42A4-4FA0-A757-33FD0D5F4B1C">
    <variable name="Is Vendor Eligible" id="_95028976-6798-4CBE-9D36-B04C1DBE7079" typeRef="boolean" />
    <encapsulatedLogic label="Is Vendor Eligible" typeRef="boolean" id="_75EF7C76-FC5A-44A8-A6A2-04AA82D88B02" kind="FEEL">
      <formalParameter id="_DB7F3203-A046-4AAC-B829-05EC1EC7F67B" name="vendor" typeRef="Vendor" />
      <formalParameter id="_AA64F7E2-7F2D-4067-9B4E-BA74D73772C3" name="policies" typeRef="Policies" />
      <conditional id="_21674A22-7B0C-4EA6-8049-5AA60417607D" label="Return">
        <if id="_C93D8FF8-84A2-4D69-A4BC-28576CFBE9B9">
          <literalExpression id="_5E4E8A81-AF94-4EF8-9356-EEBD65A06777" label="Expression Name">
            <text>vendor.complianceScore &gt; policies.minComplianceScore and vendor.deliveryDays &lt;= policies.maxDeliveryDyas</text>
          </literalExpression>
        </if>
        <then id="_CD9D091D-FBA0-49FC-9E68-3CF3D5843C57">
          <literalExpression id="_49911ABC-B09E-4D7E-AAD6-49EAFBFB50B3" label="Expression Name">
            <text>true</text>
          </literalExpression>
        </then>
        <else id="_3DD7B034-C72D-4EA1-B269-646E9D7710FC">
          <literalExpression id="_6EA7C3B9-A6E7-47D0-A21E-485ACDCBD9B0" label="Expression Name">
            <text>false</text>
          </literalExpression>
        </else>
      </conditional>
    </encapsulatedLogic>
  </businessKnowledgeModel>
