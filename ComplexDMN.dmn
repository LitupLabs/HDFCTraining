    <filter id="_6255B816-9D79-4A73-A69D-35876571672C" typeRef="Amount" label="Filtered ItemTotal">
      <in id="_04EB9C4A-0B3D-409B-8878-6A6BA50F6436">
        <literalExpression id="_E31590D3-2327-42EC-A2C0-60AADE2796D5" label="Expression Name">
          <text>Item Total</text>
        </literalExpression>
      </in>
      <match id="_33F565F9-008C-4E2F-856F-48E673806D8F">
        <literalExpression id="_9FEF7CAB-A91E-4D48-A7EB-F09C32D838B2" label="Expression Name">
          <text>item!=0</text>
        </literalExpression>
