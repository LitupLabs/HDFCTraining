  <decision name="Item Totals" id="_70ABAAF1-77FC-4B8C-AE17-3EC3360D95A2">
    <variable name="Item Totals" id="_A842328A-AEA7-4E95-8719-F0DF5E0A132B" typeRef="ItemTotal" />
    <informationRequirement id="_8DBA2A1B-D97F-45DB-8AEB-DB69E1FE1A97">
      <requiredInput href="#_955BE7CC-3CD2-47BB-B281-13398D86F372" />
    </informationRequirement>
    <knowledgeRequirement id="_F226E9AF-0708-4B88-92FE-94835F4B7E4B">
      <requiredKnowledge href="#_6F73EC22-0051-4D2B-ADA3-FB830EB154C1" />
    </knowledgeRequirement>
    <for id="_77810447-5931-4F08-9718-E5398662159B" typeRef="ItemTotal" label="Item Totals" iteratorVariable="item">
      <in id="_38947E13-3ED5-4CDC-BBAF-94816B5DE806">
        <literalExpression id="_DC1228F6-44A7-4217-ABA9-AD13B78CA502" label="Expression Name">
          <text>PurchaseRequest.items</text>
        </literalExpression>
      </in>
      <return id="_3C77A339-30BA-4703-9A70-A75A670C2298">
        <literalExpression id="_B05783E1-7909-4457-BDF2-AE7CC85CF863" label="Expression Name">
          <text>Calculate Item Total(item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="Total Procurement Cost" id="_7044F7C5-007A-4A34-AB6C-814DDB8E3EDC">
    <variable name="Total Procurement Cost" id="_3376BB65-4115-4531-B051-53035E68A37B" typeRef="number" />
    <informationRequirement id="_DBB7AD98-524A-4FA9-865A-3E77B71434C8">
      <requiredDecision href="#_70ABAAF1-77FC-4B8C-AE17-3EC3360D95A2" />
    </informationRequirement>
    <literalExpression id="_90CFB02F-0145-42DE-8474-30A0A7D79247" typeRef="number" label="Total Procurement Cost">
      <text>sum(Item Totals)</text>
    </literalExpression>
  </decision>
  <decision name="Eligible Vendors" id="_18476A7B-2C29-4DB8-ADCD-3E30332A85F7">
    <variable name="Eligible Vendors" id="_2466ECE1-2C86-4F52-89E1-68EB856227B4" typeRef="VendorList" />
    <informationRequirement id="_89CCF396-BE33-4226-B4AB-36C9631664B9">
      <requiredInput href="#_900A773B-C06D-4692-91D1-529F36481EF9" />
    </informationRequirement>
    <informationRequirement id="_0641381C-EC4E-4530-976D-3BCDED49D49E">
      <requiredInput href="#_22FD2A3D-1FDF-43F3-ACDB-4365830867C2" />
    </informationRequirement>
    <knowledgeRequirement id="_3F2FB65A-CE7B-487E-B4E8-D18C37A915CB">
      <requiredKnowledge href="#_A9B0EF4E-94E1-42AF-A783-255143D035B8" />
    </knowledgeRequirement>
    <filter id="_CCA30894-B958-4D1C-B649-F80BF99579A8" typeRef="VendorList" label="Eligible Vendors">
      <in id="_D2B338EC-3404-4713-9573-EC08CAD0AE2F">
        <literalExpression id="_A6C231CF-0D06-4B3D-90B3-7DC2DFF4C5F5" label="Expression Name">
          <text>Vendors</text>
        </literalExpression>
      </in>
      <match id="_F33E7220-58BC-4470-A05A-F9176D38B8F7">
        <literalExpression id="_B500C6D5-84EE-4A81-870B-0EBFEB80F918" label="Expression Name">
          <text>Is Vendor Eligible(item,Policies)</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <businessKnowledgeModel name="Calculate Item Total" id="_6F73EC22-0051-4D2B-ADA3-FB830EB154C1">
    <variable name="Calculate Item Total" id="_60D153C5-71CF-4F41-90B5-DD5862988743" typeRef="number" />
    <encapsulatedLogic label="Calculate Item Total" typeRef="number" id="_22B5C2B3-B44A-4DDA-A799-1B2A5C9092EC" kind="FEEL">
      <formalParameter id="_F78297F9-B149-445A-AA93-D4F8945B5EAE" name="item" typeRef="Item" />
      <literalExpression id="_810E0687-E926-47C8-B03A-6075B902BDBF" typeRef="number" label="Return">
        <text>if item.quantity==null or item.unitPrice == null then 0 else item.quantity * item.unitPrice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Is Vendor Eligible" id="_A9B0EF4E-94E1-42AF-A783-255143D035B8">
    <variable name="Is Vendor Eligible" id="_97301227-1CF9-466E-B259-BCFED624E12F" typeRef="boolean" />
    <encapsulatedLogic label="Is Vendor Eligible" typeRef="boolean" id="_29C75B7C-7A70-475D-979A-00AA49AD81B8" kind="FEEL">
      <formalParameter id="_B575A581-5128-4ACE-B397-2C5648F1BEF3" name="vendor" typeRef="Vendor" />
      <formalParameter id="_A199340C-AEB2-43F4-87C6-02B635D93842" name="policies" typeRef="Policies" />
      <conditional id="_01E6DD8A-3C4D-4CA7-A741-4D8F398FF8CB" label="Return">
        <if id="_1E0AA1DD-B641-459F-91FB-9B1BF30415B7">
          <literalExpression id="_D17160C7-2000-4397-83CC-66B0B6726BBC" label="Expression Name">
            <text>vendor.complianceScore &gt;= policies.minComplianceScore and vendor.deliveryDays &lt;= policies.maxDeliveryDays</text>
          </literalExpression>
        </if>
        <then id="_B13C31C5-A7E8-41AF-AC53-2E7A233BD3FF">
          <literalExpression id="_0CEC498B-7DF4-45FE-9497-CDF535D63D88" label="Expression Name">
            <text>true</text>
          </literalExpression>
        </then>
        <else id="_98BCC67F-8D69-4CB0-A49E-34A55BADFA71">
          <literalExpression id="_4B30B964-5D9D-4C06-98D1-105FB3062D88" label="Expression Name">
            <text>false</text>
          </literalExpression>
        </else>
      </conditional>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Score" id="_19558442-FB67-4332-B4BF-B95350148AA5">
    <variable name="Calculate Vendor Score" id="_CA0400B7-F62A-480E-9848-37C6D7ABED5B" />
    <encapsulatedLogic label="Calculate Vendor Score" id="_129B1953-0067-4BA3-B1C9-2F8B54C20B31" kind="FEEL">
      <formalParameter id="_C3964D3D-33EA-40CE-826F-B2911514A8C4" name="vendor" typeRef="Vendor" />
      <context id="_537CF78F-FFA6-486E-A4C4-ECED7C68CDD9" label="Return">
        <contextEntry id="_BD203CEA-1EC4-4829-AA11-714613DB880A">
          <variable id="_CB580B57-48C3-4F58-A578-54525F505398" name="ratingScore" typeRef="number" />
          <literalExpression id="_C68CE022-FC96-49DA-B8B7-551327A86E91" typeRef="number" label="ratingScore">
            <text>Calculate Vendor Rating(vendor)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_83AB613B-1F84-4323-87BC-7D8576F935AB">
          <variable id="_F159737F-D19F-46A4-8339-D655E9262EFA" name="deliveryScore" typeRef="number">
            <description></description>
          </variable>
          <conditional id="_34DBE4F3-1D2F-43F5-AAD9-3ECB800E7BD4" typeRef="number" label="deliveryScore">
            <if id="_C9767694-415C-49A8-B39E-371C33E75D13">
              <literalExpression id="_CC8227B2-D781-4A5E-A059-5420E4602D26" label="Expression Name">
                <text>vendor.deliverDays &lt;= </text>
              </literalExpression>
            </if>
            <then id="_0C40F0A1-7529-420E-A8D9-BCF27AA51998" />
            <else id="_29CA70F0-DD13-4C51-AA3F-A4DE971FFC4F" />
          </conditional>
        </contextEntry>
      </context>
    </encapsulatedLogic>
    <knowledgeRequirement id="_129FFFDA-DE44-4F46-AF41-32257C411ACD">
      <requiredKnowledge href="#_731AD5B3-3A2E-46BC-8844-586B87BB6F66" />
    </knowledgeRequirement>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Rating" id="_731AD5B3-3A2E-46BC-8844-586B87BB6F66">
    <variable name="Calculate Vendor Rating" id="_5D599931-8751-46E2-8A29-07295B9C6D75" />
    <encapsulatedLogic label="Calculate Vendor Rating" id="_8AF91DC4-7301-4FA2-92D0-CFC514EA4B38" kind="FEEL">
