    <itemComponent id="_80E2DA0B-33F3-4E5F-84B5-4B2326D0D3A9" name="vendorId" isCollection="false" typeLanguage="https://www.omg.org/spec/DMN/20240513/FEEL/">
      <typeRef>string</typeRef>
    </itemComponent>
