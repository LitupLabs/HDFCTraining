  <decision name="Item Total" id="_B1BB4AC7-E95A-49FC-B1CC-9951D842E034">
    <variable name="Item Total" id="_145F7895-FE2B-4B00-AB89-4AE19BC962BA" typeRef="Amount" />
    <informationRequirement id="_6BB6F146-00E1-47E1-942F-A31B29196322">
      <requiredInput href="#_C6C5FEAA-BF21-4CC4-8CEA-89BC3A91C1FE" />
    </informationRequirement>
    <knowledgeRequirement id="_F7F056A4-66E4-44F9-86F2-1BE62DE91871">
      <requiredKnowledge href="#_CF9E87E2-4138-4580-BDBC-5D7E46F5044B" />
    </knowledgeRequirement>
    <for id="_D421CADB-5B90-4E0F-88E8-D95D67689C7F" typeRef="Amount" label="Item Total" iteratorVariable="Item">
      <in id="_54C27631-3BF1-4119-9A55-E31AAB588D84">
        <literalExpression id="_200BA7C2-F8C9-42A4-B770-591E6AB3FAD9" label="Expression Name">
          <text>PurchaseRequest.item</text>
        </literalExpression>
      </in>
      <return id="_D126C7FC-AC14-46EA-9E9C-5D298627A51E">
        <literalExpression id="_4C0B4CEF-99A4-423E-89C1-B25D3FC77F3B" label="Expression Name">
          <text>Calculated item Total(Item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="Total Procurement Cost" id="_CBFA46F8-C4C7-4410-B1F6-363AB93C8F62">
    <variable name="Total Procurement Cost" id="_53B398A4-27B8-4313-B3BF-E2F119F2B449" typeRef="number" />
    <informationRequirement id="_EC22320B-2B2F-4235-9B6A-61C110AED3B7">
      <requiredDecision href="#_D9F2CB7C-98EF-485D-B631-57E9678ED6E3" />
    </informationRequirement>
    <literalExpression id="_1C8FB7F5-5D3D-4E2C-B739-C540C07710EC" typeRef="number" label="Total Procurement Cost">
      <text>sum(Item Total)</text>
    </literalExpression>
  </decision>
  <decision name="Filtered ItemTotal" id="_D9F2CB7C-98EF-485D-B631-57E9678ED6E3">
