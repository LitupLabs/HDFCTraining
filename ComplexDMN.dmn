  <decision name="Item Total" id="_7F0C5F2A-E2AA-4BB4-AF42-295DD249CF82">
    <variable name="Item Total" id="_4AECC0C1-B274-4561-B148-73E71DEA90CC" typeRef="Amount" />
    <informationRequirement id="_371E0EF2-D5FE-4890-BB94-ED22F2E8D390">
      <requiredInput href="#_F6DF58C6-5616-47B6-9013-3088843221AF" />
    </informationRequirement>
    <knowledgeRequirement id="_3B184B19-99F2-4B32-845F-FE3E9326C4C6">
      <requiredKnowledge href="#_9CA8680C-FD67-4357-90B2-28CEFF64C7F0" />
    </knowledgeRequirement>
    <for id="_FCC89402-F4C0-4962-ACB7-923A1B651E22" typeRef="Amount" label="Item Total" iteratorVariable="Item">
      <in id="_63C5E221-6DE9-40A3-AAD3-D31C5B315C7E">
        <literalExpression id="_A44C2ECC-22FA-45BD-8739-6B1123C676C8" label="Expression Name">
          <text>PurchaseRequest.Item</text>
        </literalExpression>
      </in>
      <return id="_24B6F6DE-C03F-404D-8EA7-593B06F7503C">
        <literalExpression id="_B800161C-117C-4A83-84DC-5B6E2D0974AF" label="Expression Name">
          <text>Calculate Item Total(Item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="Total Procurement Cost" id="_856EFE18-AF49-4F17-B937-E0B554ED6FF1">
    <variable name="Total Procurement Cost" id="_EC0FBE3E-44BF-420A-BEAD-FE914905A78E" typeRef="number" />
    <informationRequirement id="_9FE2622D-1111-429A-B653-DAEAE74103C5">
      <requiredDecision href="#_7F0C5F2A-E2AA-4BB4-AF42-295DD249CF82" />
    </informationRequirement>
    <literalExpression id="_CE9D6781-AE25-4A47-BEF7-F78E670A0D1B" typeRef="number" label="Total Procurement Cost">
      <text>sum(Item Total)</text>
    </literalExpression>
  </decision>
  <decision name="Eligible Vendors" id="_2F7E14BB-3763-4F49-BACF-1AFA9854E464">
    <variable name="Eligible Vendors" id="_4F88EBF2-16B4-4D55-984E-4600E5F1CD5A" typeRef="VendorList" />
    <informationRequirement id="_1A9C8BF3-14A5-4A7B-8380-51C2872320B8">
      <requiredInput href="#_437FCD67-38E9-4AFB-A0A4-E1A2894DDAEF" />
    </informationRequirement>
    <informationRequirement id="_87D758B5-7603-45F5-8FF0-0C7B2DF4B705">
      <requiredInput href="#_550D3964-0DBA-4929-8CCA-B4B20F49217D" />
    </informationRequirement>
    <knowledgeRequirement id="_724D9D75-7816-4FE2-AF63-D493C88DC6B6">
      <requiredKnowledge href="#_4F849266-5C06-457C-A40B-6DD69A4F5832" />
    </knowledgeRequirement>
    <knowledgeRequirement id="_E056320D-8493-48D8-B4EB-00983BC4CD32">
      <requiredKnowledge href="#_964BEDD1-D834-4ADB-AE49-1D7CD2C4F3C4" />
    </knowledgeRequirement>
    <for id="_2E8EB798-78EA-4722-93D0-16B2CAA408FD" typeRef="VendorList" label="Eligible Vendors" iteratorVariable="vendor">
      <in id="_D998C920-B84B-40B6-B89E-C11FC5225B9C">
        <literalExpression id="_DBD3364F-AAE3-4CCB-A10B-BE6C1997EFE6" label="Expression Name">
          <text>Vendors</text>
        </literalExpression>
      </in>
      <return id="_0CBCA295-AEE4-44FC-A5F7-F4C9CDD5EDDC">
        <literalExpression id="_8941F9AB-1596-48B2-9718-2F8913965A0B" label="Expression Name">
          <text>Is Vendor Eligible(Item, Polices)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="ScoredVendor" id="_2EA16FE7-5E26-437A-8FA6-D8093BB05592">
    <variable name="ScoredVendor" id="_8FC4A647-4205-434C-8859-1CF2B590BB57" typeRef="ScoredVendorList" />
    <informationRequirement id="_B70E0FD7-686F-4CDB-94B8-FDE0CB126705">
      <requiredDecision href="#_2F7E14BB-3763-4F49-BACF-1AFA9854E464" />
    </informationRequirement>
    <knowledgeRequirement id="_66B1854C-5767-4FC2-A63F-714DDF23E9E2">
      <requiredKnowledge href="#_964BEDD1-D834-4ADB-AE49-1D7CD2C4F3C4" />
    </knowledgeRequirement>
    <literalExpression id="_C1991EB1-224F-4C7B-91E3-027493116542" typeRef="ScoredVendorList" label="ScoredVendor">
      <text>
for v in Eligible Vendors
return {
vendorId: v.vendorId,
score: Calculate Vendor Score(v),
basePriceFactor: v.basePriceFactor
}

</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Calculate Item Total" id="_9CA8680C-FD67-4357-90B2-28CEFF64C7F0">
    <variable name="Calculate Item Total" id="_D52082F1-14EC-4CD1-9740-DA7233FE6307" typeRef="number" />
    <encapsulatedLogic label="Calculate Item Total" typeRef="number" id="_DF3E002D-D963-4120-93CA-B57ECCDF9DC7" kind="FEEL">
      <formalParameter id="_0002A8F6-6D53-4452-90BC-42CE3F787B82" name="Item" typeRef="Item" />
      <literalExpression id="_8171DA81-A8AC-4AC1-8463-63F3ECA57FA1" label="Return">
        <text>if Item.Quantity = null or Item.UnitPrice = null then 0 else Item.Quantity * Item.UnitPrice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Is Vendor Eligible" id="_4F849266-5C06-457C-A40B-6DD69A4F5832">
    <variable name="Is Vendor Eligible" id="_1205250B-EA2E-4E88-8231-C436BF6537BC" typeRef="boolean" />
    <encapsulatedLogic label="Is Vendor Eligible" typeRef="boolean" id="_B3C28E89-D363-455C-A53E-AD15FF7E4A99" kind="FEEL">
      <formalParameter id="_325E14E7-9380-44A0-B6DC-22B723ABD161" name="Vendor" typeRef="Vendor" />
      <formalParameter id="_C7E8576D-C7DF-49D4-8227-43519D6A5850" name="Polices" typeRef="Polices" />
      <conditional id="_14E07FCA-F966-49B3-9358-067533B0D707" label="Return">
        <if id="_799DF2A4-5942-43B6-83B9-18DE8AA4EF4A">
          <literalExpression id="_8658C670-54E3-4232-B5F8-644DEDCA0B7F" label="Expression Name">
            <text>Vendor.ComplianceScore &gt;= Polices.MinComplainceScore and Vendor.DeliveryDays &lt;= Polices.MaxDeliveryDays</text>
          </literalExpression>
        </if>
        <then id="_A7B03475-B6C3-46F5-9413-702918C46269">
          <literalExpression id="_19A97390-AB46-455A-B874-D3873412A25C" label="Expression Name">
            <text>true</text>
          </literalExpression>
        </then>
        <else id="_E9C397B4-2485-4321-A1EA-7E351EA935AA">
          <literalExpression id="_479082BC-0C3E-4FFC-A0DF-76CDECF7F692" label="Expression Name">
            <text>false</text>
          </literalExpression>
        </else>
      </conditional>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Score" id="_964BEDD1-D834-4ADB-AE49-1D7CD2C4F3C4">
    <variable name="Calculate Vendor Score" id="_5C310D23-AD31-4C32-A111-5ABE10D9B208" typeRef="number" />
    <encapsulatedLogic label="Calculate Vendor Score" typeRef="number" id="_6C6A2F25-794A-4826-A5ED-8AB7E1882DFF" kind="FEEL">
      <formalParameter id="_3F504FC3-E746-4CB2-B447-8DF95BBFD72C" name="Vendor" typeRef="Vendor" />
      <context id="_98ED34DA-35BA-4B50-8286-DB7ECF002481" typeRef="number" label="Return">
        <contextEntry id="_755F72B8-1A5B-44B9-BC40-B9367A06DC5F">
          <variable id="_FCFCFA62-9AD5-49BD-A289-4C73674AC86B" name="RatingScore" typeRef="number" />
          <literalExpression id="_19DE8040-65A5-42F2-8B9F-3BD694E2BAE5" typeRef="number" label="RatingScore">
            <text>Calculate Vendor Rating(Vendor)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_BEB8E355-125E-495A-A0C8-03C7D7616807">
          <variable id="_15D66701-49DC-44DC-A86A-3204DD31F7D6" name="DeliveryScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_A2DE9162-629C-43E0-BB0D-DFFD343443E7" typeRef="number" label="DeliveryScore">
            <text>if Vendor.DeliveryDays &lt;= 3 then 20 else 10 </text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_C64F0B6D-9CBF-4A4E-B043-716AB1526AC9">
          <variable id="_E9D8B602-E8D7-41E6-9AF8-565BEDA9CC3E" name="ComplianceScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_5D10C2E5-6E51-41CA-8AB5-546DB69D28BA" typeRef="number" label="ComplianceScore">
            <text>Vendor.ComplianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_15EB4CBE-46C6-4759-854C-3583990572A8">
          <variable id="_F836E0EE-7408-4731-A027-39BB7FD7D294" name="TotalScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_70C39C3B-21A5-44CF-BC7D-BBE67089D5BC" typeRef="number" label="TotalScore">
            <text>RatingScore + DeliveryScore + ComplianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_22EC8EC2-1105-4EF6-A7AA-065E8216C4BD">
          <literalExpression id="_EC42B94D-F82D-4492-AEEA-D0DE21D52ED5" typeRef="number" label="Return">
            <text>TotalScore</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
    <knowledgeRequirement id="_E12CB529-68C6-4156-BE28-E1AD1409A4E0">
      <requiredKnowledge href="#_58ED6085-540A-44B9-B96E-58C7AAC24510" />
    </knowledgeRequirement>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Rating" id="_58ED6085-540A-44B9-B96E-58C7AAC24510">
    <variable name="Calculate Vendor Rating" id="_8A470BB8-6C4C-43E4-9CD6-D63ED87DB10D" typeRef="number" />
    <encapsulatedLogic label="Calculate Vendor Rating" typeRef="number" id="_F0B24763-58B6-4FD8-9B7F-F13BA027D9B2" kind="FEEL">
      <formalParameter id="_E87AFC36-4694-428F-A5CB-3C9A452E6252" name="Vendor" typeRef="Vendor" />
      <literalExpression id="_97C66ED9-A712-4C84-96BC-ECC253642191" label="Return">
        <text>Vendor.Rating * 10</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
