  <decision name="Item Total" id="_B1BB4AC7-E95A-49FC-B1CC-9951D842E034">
    <variable name="Item Total" id="_145F7895-FE2B-4B00-AB89-4AE19BC962BA" typeRef="Amount" />
    <informationRequirement id="_6BB6F146-00E1-47E1-942F-A31B29196322">
      <requiredInput href="#_C6C5FEAA-BF21-4CC4-8CEA-89BC3A91C1FE" />
    </informationRequirement>
    <knowledgeRequirement id="_F7F056A4-66E4-44F9-86F2-1BE62DE91871">
      <requiredKnowledge href="#_CF9E87E2-4138-4580-BDBC-5D7E46F5044B" />
    </knowledgeRequirement>
    <for id="_D421CADB-5B90-4E0F-88E8-D95D67689C7F" typeRef="Amount" label="Item Total" iteratorVariable="Item">
      <in id="_54C27631-3BF1-4119-9A55-E31AAB588D84">
        <literalExpression id="_200BA7C2-F8C9-42A4-B770-591E6AB3FAD9" label="Expression Name">
          <text>PurchaseRequest.item</text>
        </literalExpression>
      </in>
      <return id="_D126C7FC-AC14-46EA-9E9C-5D298627A51E">
        <literalExpression id="_4C0B4CEF-99A4-423E-89C1-B25D3FC77F3B" label="Expression Name">
          <text>Calculated item Total(Item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="Total Procurement Cost" id="_CBFA46F8-C4C7-4410-B1F6-363AB93C8F62">
    <variable name="Total Procurement Cost" id="_53B398A4-27B8-4313-B3BF-E2F119F2B449" typeRef="number" />
    <informationRequirement id="_EC22320B-2B2F-4235-9B6A-61C110AED3B7">
      <requiredDecision href="#_D9F2CB7C-98EF-485D-B631-57E9678ED6E3" />
    </informationRequirement>
    <literalExpression id="_1C8FB7F5-5D3D-4E2C-B739-C540C07710EC" typeRef="number" label="Total Procurement Cost">
      <text>sum(Filtered ItemTotal)</text>
    </literalExpression>
  </decision>
  <decision name="Filtered ItemTotal" id="_D9F2CB7C-98EF-485D-B631-57E9678ED6E3">
    <variable name="Filtered ItemTotal" id="_5019886E-5237-44EE-8A04-8826A74C1184" typeRef="Amount" />
    <informationRequirement id="_B0D859A9-8E51-4DDF-ADAE-7A871C206A70">
      <requiredDecision href="#_B1BB4AC7-E95A-49FC-B1CC-9951D842E034" />
    </informationRequirement>
    <filter id="_6255B816-9D79-4A73-A69D-35876571672C" typeRef="Amount" label="Filtered ItemTotal">
      <in id="_04EB9C4A-0B3D-409B-8878-6A6BA50F6436">
        <literalExpression id="_E31590D3-2327-42EC-A2C0-60AADE2796D5" label="Expression Name">
          <text>Item Total</text>
        </literalExpression>
      </in>
      <match id="_33F565F9-008C-4E2F-856F-48E673806D8F">
        <literalExpression id="_9FEF7CAB-A91E-4D48-A7EB-F09C32D838B2" label="Expression Name">
          <text>item!=0</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Eligible Vendors" id="_1AA6B94A-1D85-4891-AA30-46422E697EC7">
    <variable name="Eligible Vendors" id="_0B0CE45D-9635-473F-8F16-527ACAE66D4C" typeRef="VendorList" />
    <informationRequirement id="_B1655665-114C-47A4-8B51-FB40CEBBCAF4">
      <requiredInput href="#_910FA2EE-9453-4102-B993-B10906488663" />
    </informationRequirement>
    <informationRequirement id="_5C8C1FAD-F93C-4223-9A02-AD561C66BC38">
      <requiredInput href="#_309F4044-E11D-4003-9527-6111FC537D58" />
    </informationRequirement>
    <knowledgeRequirement id="_39E21CE9-530A-49E6-A61D-41F240E72F0B">
      <requiredKnowledge href="#_A660E6D5-4722-4793-9D2C-779238041CE7" />
    </knowledgeRequirement>
    <filter id="_365CA392-85ED-4CDE-A6C2-16710EA40674" typeRef="VendorList" label="Eligible Vendors">
      <in id="_2B342B48-41AF-4A54-916E-9C0E1F54411B">
        <literalExpression id="_E629DB30-2828-4F49-BE55-556B9511A9C6" label="Expression Name">
          <text>vendor</text>
        </literalExpression>
      </in>
      <match id="_28ED74BD-4A6A-4443-AB67-04F575812A90">
        <literalExpression id="_EFF43200-503A-4A03-B9F3-E51FAC38D867" label="Expression Name">
          <text>Is Vendor Eligible(vendor,Policies)</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="Scored Vendors" id="_8EEC2024-F0F1-4678-85F2-1FF766A0FA2B">
    <variable name="Scored Vendors" id="_CD6071CF-ADB8-4B71-AAD2-6C4D389F9C7B" typeRef="ScoredVendorList" />
    <informationRequirement id="_D46E658C-9748-464A-8BB4-649E04E61030">
      <requiredDecision href="#_1AA6B94A-1D85-4891-AA30-46422E697EC7" />
    </informationRequirement>
    <knowledgeRequirement id="_1048354E-F362-4AE5-AD8A-391C5630D326">
      <requiredKnowledge href="#_BB09A63A-D1CD-482B-8ABA-9279505206F3" />
    </knowledgeRequirement>
    <literalExpression id="_697C069B-4707-45E6-9CBE-E1124E55396E" typeRef="ScoredVendorList" label="Scored Vendors">
      <text>for v in Eligible Vendors
return {
vendorId: v.vendorId,
score: Calculate Vendor Score(v),
basePriceFactor: v.basePriceFactor
}</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Calculated item Total" id="_CF9E87E2-4138-4580-BDBC-5D7E46F5044B">
    <variable name="Calculated item Total" id="_BB62395F-0927-4F66-95B9-9FAFE978763D" typeRef="number" />
    <encapsulatedLogic label="Calculated item Total" typeRef="number" id="_5B348055-DC90-4177-B7B3-B1311175C0AA" kind="FEEL">
      <formalParameter id="_26DA6F53-2324-43AF-836D-53386E6945B8" name="item" typeRef="Item" />
      <literalExpression id="_C6D42A6B-7961-4717-A6C9-A63A1893B0E0" typeRef="number" label="Return">
        <text>if  item.quantity = null or item.unitPrice = null then 0 else item.quantity * item.unitPrice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Is Vendor Eligible" id="_A660E6D5-4722-4793-9D2C-779238041CE7">
    <variable name="Is Vendor Eligible" id="_05814B09-46A0-4BFF-99F9-E2092BBA9AA0" typeRef="boolean" />
    <encapsulatedLogic label="Is Vendor Eligible" typeRef="boolean" id="_D90FF116-7422-4A44-BE4C-1C24EA2E7F40" kind="FEEL">
      <formalParameter id="_744B6425-F54B-4689-81EE-67056B03B54F" name="vendor" typeRef="vendor" />
      <formalParameter id="_04C80032-6C45-47B5-8D4B-AF1D15391E0C" name="policies" typeRef="Policies" />
      <conditional id="_C80500EB-D3D9-472A-B278-11CF69446ECD" typeRef="boolean" label="Return">
        <if id="_1C0CF010-7EAB-46FB-A069-9F34AA32C077">
          <literalExpression id="_F14CBA8F-B41F-46BF-A3E6-00AD09A1E2E9" label="Expression Name">
            <text>vendor.complianceScore &gt;= policies.minComplianceScore and vendor.deliveryDays &lt;= policies.maxDeliveryDays</text>
          </literalExpression>
        </if>
        <then id="_7BE2C073-9BC4-44CD-8856-221CB1424909">
          <literalExpression id="_54E958F2-98EE-4755-81E3-89B16C553C5F" label="Expression Name">
            <text>true</text>
          </literalExpression>
        </then>
        <else id="_2417C667-BC8D-4D88-A644-BCE04CBA4719">
          <literalExpression id="_B8D2ABA6-3B8D-409E-86F1-1EBD721517A6" label="Expression Name">
            <text>false</text>
          </literalExpression>
        </else>
      </conditional>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Rating" id="_1D75E0E3-62E3-46B2-AECA-4FF030FDA909">
    <variable name="Calculate Vendor Rating" id="_B938E2B2-2165-485A-B421-4395C02EA51C" typeRef="number" />
    <encapsulatedLogic label="Calculate Vendor Rating" typeRef="number" id="_7E54EFDF-7E76-431C-8899-A535F13EFBE4" kind="FEEL">
      <formalParameter id="_08F0FC92-DB38-4410-AFFA-F8F8265E92DB" name="vendor" typeRef="vendor" />
      <literalExpression id="_83F4C9DF-F884-4B34-8981-36E37E217EAA" typeRef="number" label="Return">
        <text>vendor.rating * 10</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Vendor Score" id="_BB09A63A-D1CD-482B-8ABA-9279505206F3">
    <variable name="Calculate Vendor Score" id="_3A9000FC-5B10-41D6-BFC5-EC77EACE97B1" typeRef="number" />
    <encapsulatedLogic label="Calculate Vendor Score" typeRef="number" id="_4C839526-C37A-49FD-BEB9-0E3C8417EDD1" kind="FEEL">
      <formalParameter id="_F8F59B52-70B0-46D7-8A6C-0421713C7C07" name="vendor" typeRef="vendor" />
      <context id="_9A4D2C31-A2C2-45FA-AF22-6158BDC344D2" typeRef="number" label="Return">
        <contextEntry id="_FD3DC2F6-23BB-4039-92E5-E70B7CB1D57A">
          <variable id="_BE1CA565-EE8F-4148-B682-479422816392" name="ratingscore" typeRef="number" />
          <literalExpression id="_E8511B16-8F1C-4B7C-86E4-D6FD42D36750" typeRef="number" label="ratingscore">
            <text>Calculate vendor rating(vendor)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_256D6823-B944-4027-988F-F7749AE903C7">
          <variable id="_81F01CF6-C919-4419-B9CF-5606877FA958" name="deliveryscore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_6C5C4AA0-8AD4-4ED9-9156-98108BD53B1C" typeRef="number" label="deliveryscore">
            <text>if vendor.deliveryDays &lt;=5 then 20 else 10</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_6BFBAE32-42CB-42A7-AF5D-2BEF7CB59864">
          <variable id="_FE74BCB5-2B26-4ADE-B602-C513358F1040" name="Compliancescore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_9C9FBF2D-5B6F-4EB9-B804-6FD65ECA22A4" typeRef="number" label="Compliancescore">
            <text>vendor.complianceScore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_611206CE-D637-4E0F-8987-BF91E75629C9">
          <variable id="_F142E4F3-96E8-461B-9803-773DA2587F1F" name="totalScore" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_6A179F7D-E5F5-4B3C-91AA-8854B1554699" typeRef="number" label="totalScore">
            <text>ratingscore + deliveryscore + Compliancescore</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_367D4575-B23A-474B-9CF8-503B5A4181BA">
          <literalExpression id="_B6D638B7-DEE3-4932-9811-F2468A771076" typeRef="number" label="Return">
            <text>totalScore</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
    <knowledgeRequirement id="_34D9B8C1-AADA-469F-B99B-8AF06EE9F89E">
      <requiredKnowledge href="#_1D75E0E3-62E3-46B2-AECA-4FF030FDA909" />
    </knowledgeRequirement>
  </businessKnowledgeModel>
  <inputData name="PurchaseRequest" id="_C6C5FEAA-BF21-4CC4-8CEA-89BC3A91C1FE">
    <variable name="PurchaseRequest" id="_B4AFC247-C032-4C8E-9128-0C58F2D6D840" typeRef="PurchaseRequest" />
  </inputData>
  <inputData name="vendor" id="_910FA2EE-9453-4102-B993-B10906488663">
    <variable name="vendor" id="_F4A137FA-144C-4AAA-AC98-B1803D34C902" typeRef="VendorList" />
  </inputData>
  <inputData name="Policies" id="_309F4044-E11D-4003-9527-6111FC537D58">
    <variable name="Policies" id="_EFEF1339-C68F-4F4A-B649-6B24BD28373F" typeRef="Policies" />
  </inputData>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="_D82EF6F0-5940-4258-A5D9-A353F024EC36" name="Default DRD" useAlternativeInputDataShape="false">
