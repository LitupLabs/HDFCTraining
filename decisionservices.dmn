  <businessKnowledgeModel name="calcuate risk score" id="_387A0FFB-3856-4220-B16C-6493B80DB193">
    <variable name="calcuate risk score" id="_8DE532F7-E64B-4351-90DA-CA9532162E6A" typeRef="number" />
    <encapsulatedLogic label="calcuate risk score" typeRef="number" id="_16785391-A909-43AB-BE05-A4DB0292ED70" kind="FEEL">
      <formalParameter id="_B586BFA9-7B9B-45B7-97E5-E2B3D3A620BF" name="loan application" typeRef="loanapplication" />
      <literalExpression id="_0E76A0A7-8A3E-40E8-9A0F-C813F611FDFE" typeRef="number" label="Return">
        <text>if loan application.customer.creditscore &gt;= 750 then 3 else if loan application.customer.creditscore &gt;= 650 then 2 else 1</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="calculate financial eligibilty" id="_FD6B9CAB-356A-40EB-AF25-E12538E4EF60">
    <variable name="calculate financial eligibilty" id="_84C4BCEA-57D7-4A30-B404-2E3252822CB3" typeRef="number" />
    <encapsulatedLogic label="calculate financial eligibilty" typeRef="number" id="_6124C7CB-3B17-49C8-AADC-45C89CD0784E" kind="FEEL">
      <formalParameter id="_5EF0F390-165D-4CCD-BA17-FF9A7B0F031E" name="loan application" typeRef="loanapplication" />
      <literalExpression id="_837FA535-1C27-4DF2-89E2-CA938236FA11" typeRef="number" label="Return">
        <text>loan application.financials.monthlyincome + sum(loan application.financials.otherincome) - loan application.financials.existingEMIs</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
