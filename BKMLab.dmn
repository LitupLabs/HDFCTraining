  <decision name="Risk Category" id="_8BAE4C3D-8710-4BA1-96B8-5A1F3CD5B7DA">
    <variable name="Risk Category" id="_82E52CF2-689D-4112-AF9E-BA0E52F0ED02" typeRef="RiskCategory" />
    <informationRequirement id="_9442630F-3F96-42ED-BDDB-0E343C196262">
      <requiredInput href="#_0CC646A0-2FDA-4073-9017-897F1380F3E8" />
    </informationRequirement>
    <knowledgeRequirement id="_59B95AEA-7C8F-4A0D-AA44-B1E5BC9AB601">
      <requiredKnowledge href="#_64390EA2-E165-4FA0-862A-6EBE4EB3B913" />
    </knowledgeRequirement>
    <literalExpression id="_B8041461-17EB-413B-8E89-D861A05ACB5B" typeRef="RiskCategory" label="Risk Category">
      <text>if Calculated Risk Score() &lt; 2 then &quot;HIGH&quot; else if Calculated Risk Score() = 3 then &quot;MEDIUM&quot; else &quot;LOW&quot;</text>
    </literalExpression>
  </decision>
  <decision name="Financial Eligibility" id="_8A7D59B7-E256-442F-966C-E1A950B98520">
    <variable name="Financial Eligibility" id="_8F209172-109D-4647-9E9D-688BA5F045DB" typeRef="boolean" />
    <informationRequirement id="_D4BD77C5-8A95-4403-AD04-F172C9C2327C">
      <requiredInput href="#_0CC646A0-2FDA-4073-9017-897F1380F3E8" />
    </informationRequirement>
    <knowledgeRequirement id="_08C1C16F-D602-4855-9347-198D9265A0BC">
      <requiredKnowledge href="#_76FBD8D6-C150-48A2-9A60-01AED3D831DC" />
    </knowledgeRequirement>
    <conditional id="_DFE8C4EE-8298-4734-8EB5-F8F4D2390028" typeRef="boolean" label="Financial Eligibility">
      <if id="_D4CA9979-99FB-46CA-AA58-0306146430C5">
        <literalExpression id="_D4542894-F3CA-49FB-BE07-77CFEAD497BF" label="Expression Name">
          <text>Calculate Financia Strngth() &gt;30000</text>
        </literalExpression>
      </if>
      <then id="_05079B8A-CDA2-4D1E-B388-7E15F990E3F6">
        <literalExpression id="_A5D24831-CB44-4240-ABCC-FDA79B4494D9" label="Expression Name">
          <text>true</text>
        </literalExpression>
      </then>
      <else id="_1C74267A-4773-4EB1-AAC2-825D81BC0ACB">
        <literalExpression id="_2FE5A0A9-6822-4D10-8E3E-554A8E4C58A4" label="Expression Name">
          <text>false</text>
        </literalExpression>
      </else>
    </conditional>
  </decision>
  <decision name="Loan approval" id="_E09D5E10-A53B-417D-A513-8BCE4E07811A">
    <variable name="Loan approval" id="_A76B9497-DE66-4848-B3F8-CD4CB3D36365" typeRef="string" />
    <informationRequirement id="_E63AE8AC-6ECE-4023-8776-657F3F662BA4">
      <requiredDecision href="#_8BAE4C3D-8710-4BA1-96B8-5A1F3CD5B7DA" />
    </informationRequirement>
    <informationRequirement id="_5AA3AFC7-A57A-49DF-B114-8447B0848614">
      <requiredDecision href="#_8A7D59B7-E256-442F-966C-E1A950B98520" />
    </informationRequirement>
    <conditional id="_2C04F651-5457-4947-9C4B-550FEEC64296" typeRef="string" label="Loan approval">
      <if id="_1E514B8E-6078-47C4-A19A-1D0E1E5E0369">
        <literalExpression id="_A4B971C4-CBC6-45F4-A636-5CA8EF64A3F2" label="Expression Name">
          <text>Risk Category != &quot;HIGH&quot; and Financial Eligibility = true</text>
        </literalExpression>
      </if>
      <then id="_9E0B79EA-3EB7-41E3-8EC1-C3D92E9BCA57">
        <literalExpression id="_5CB0D284-DBD7-494F-9787-A886D425E3B1" label="Expression Name">
          <text>&quot;Loan is Approved since the risk category is not high and Financial Eligibility is permissible&quot;</text>
        </literalExpression>
      </then>
      <else id="_2F6F1727-7B1A-40A9-B720-966D9F5B68C3">
        <literalExpression id="_18073A1D-A487-49E6-B5B9-BCBF626E4FFE" label="Expression Name">
          <text>&quot;Loan is Rejected due to  the risk category is&quot; + Risk Category  + &quot;and financial Eligibility is &quot; + string(Financial Eligibility)</text>
        </literalExpression>
      </else>
    </conditional>
  </decision>
  <businessKnowledgeModel name="Calculated Risk Score" id="_64390EA2-E165-4FA0-862A-6EBE4EB3B913">
    <variable name="Calculated Risk Score" id="_9BD9152B-C42C-47D9-8784-889E81BF2164" typeRef="number" />
    <encapsulatedLogic label="Calculated Risk Score" typeRef="number" id="_2785E559-7518-4BF0-AA8F-2472CE23B5E7" kind="FEEL">
      <formalParameter id="_E9492A73-6A6B-40DA-B2D6-38C0D55D61DF" name="Loanapplication" typeRef="LoanApplication" />
      <decisionTable id="_F19002D3-CFC8-4D88-8FF7-49B8B4A73477" typeRef="number" hitPolicy="UNIQUE" label="Return">
        <input id="_4C97A7B3-0792-4063-B61B-C5CBD0AB190B">
          <inputExpression id="_60280907-4C95-4DF8-A751-9B500D9EA5A2" typeRef="number">
            <text>Loanapplication.Customer.creditScore</text>
          </inputExpression>
        </input>
        <output id="_F987745D-4E9F-4389-8F18-E0BB94BC6977" />
        <annotation name="Annotations" />
        <rule id="_A37CF89B-8F29-42AD-8F15-B701AA28DB4B">
          <inputEntry id="_69BB36C4-6F61-4F8D-99E4-E6A05240ABF6">
            <text>&lt; 0</text>
          </inputEntry>
          <outputEntry id="_0CD2B622-6846-453B-89F2-C4402F2885D0">
            <text>0</text>
          </outputEntry>
          <annotationEntry>
            <text>// Your annotations here</text>
          </annotationEntry>
        </rule>
        <rule id="_BD92953F-D92A-4F99-B4A7-07B7DD4B73B4">
          <inputEntry id="_269230DC-BB3E-4CBA-8018-CFBA537FC110">
            <text>[0 .. 650]</text>
          </inputEntry>
          <outputEntry id="_C77D52D4-F9A4-4EEC-9B6D-15E0E3627091">
            <text>2</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_C42BD410-F6EE-48DF-9999-5468FCA03082">
          <inputEntry id="_2FBACE39-F9BF-4279-95EC-B34D145D561B">
            <text>(650 .. 780]</text>
          </inputEntry>
          <outputEntry id="_3F7E6086-4686-4628-B4E0-0CDA624126A7">
            <text>3</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_8D665D0E-89DC-49EF-AE91-7256DA757FC4">
          <inputEntry id="_F51D1ED7-D66E-4552-8A8F-A6ADAEE480F4">
            <text>&gt; 780</text>
          </inputEntry>
          <outputEntry id="_11AB7069-CB04-4CA7-BE37-D98E5BD756D2">
            <text>1</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
      </decisionTable>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Financia Strngth" id="_76FBD8D6-C150-48A2-9A60-01AED3D831DC">
    <variable name="Calculate Financia Strngth" id="_B436DB39-B1A3-48BD-8714-DBC792E9F6A8" typeRef="number" />
    <encapsulatedLogic label="Calculate Financia Strngth" typeRef="number" id="_642513F0-9040-400B-A51E-F3A8D9342BCF" kind="FEEL">
      <formalParameter id="_7359BCA2-8CE9-4E06-8B3D-BDD471B05CB9" name="Loanapplication" typeRef="LoanApplication" />
      <context id="_DACBB4E5-4305-498F-A220-10FCD834155F" typeRef="number" label="Return">
        <contextEntry id="_B5E7D4BD-0CF4-4C47-B0FB-2E65A18E27F7">
          <variable id="_6CF92751-6CA9-41FC-BE8F-13F87018889B" name="MonthlyIncome" typeRef="number" />
          <literalExpression id="_2AB715B2-9BF4-4AA4-8EA5-F569924236DE" typeRef="number" label="MonthlyIncome">
            <text>Loanapplication.Financials.monthlyIncomes</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_EEAE424D-0494-409F-A9FC-24182AF388EE">
          <variable id="_B7C0E88E-754D-4B8C-B0C1-835B842052CA" name="TotalIncome" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_B31D24D7-C5DE-4E0F-B57B-C70447B4E8E1" typeRef="number" label="TotalIncome">
            <text>MonthlyIncome + sum( Loanapplication.Financials.otherincomes )</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_7240E78F-4F19-4317-AEA5-75C11AD636C9">
          <literalExpression id="_F9C68A2E-F31E-4075-982D-6E0E8220377B" typeRef="number" label="Return">
            <text>TotalIncome - Loanapplication.Financials.existingEMIs</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
  </businessKnowledgeModel>
