  <itemDefinition id="_1E064876-D9A9-4F25-ABA7-B3B5CA38582F" name="RiskCategory" isCollection="true" typeLanguage="https://www.omg.org/spec/DMN/20240513/FEEL/">
    <typeRef>string</typeRef>
    <allowedValues id="_0829954C-29AA-4D5E-91DE-0A3D35FCA4EF" kie:constraintType="enumeration">
      <text>&quot;HIGH&quot;, &quot;MEDIUM&quot;, &quot;LOW&quot;</text>
    </allowedValues>
  </itemDefinition>
