  <decision name="Risk Category" id="_139C3BD3-F2F0-4B28-8E6A-C11FB8C1E080">
    <variable name="Risk Category" id="_3F175C0C-C8D8-404A-BFEA-3362DBE80351" />
    <informationRequirement id="_41E0BB24-00D6-47E2-9E6E-649C3966B19E">
      <requiredInput href="#_B2407208-7EBC-407C-B5FC-9AB5A51F4CED" />
    </informationRequirement>
    <knowledgeRequirement id="_B5376100-65EE-4DFE-86F5-868991531EA5">
      <requiredKnowledge href="#_DB91EB6A-9435-4AD7-9E09-6FA9BC1D5B3E" />
    </knowledgeRequirement>
    <literalExpression id="_07A7A5C3-B67D-4401-9AB4-E71885FE9CDB" label="Risk Category">
      <text>if Calculate Risk Score () &lt;= 2 then &quot;High&quot; else if Calculate Risk Score() = 3 then &quot;MEDIUM&quot; else &quot;LOW&quot;</text>
    </literalExpression>
  </decision>
  <decision name="Financial Eligibility" id="_DE12B9C9-A9B4-43F4-97EB-C9ED22E2B788">
    <variable name="Financial Eligibility" id="_EF13DE63-51E0-4F86-A06C-B85D7FBFB231" typeRef="boolean" />
    <informationRequirement id="_D7F10D4D-8FC9-4FA3-9606-DEFFA1B8C8EC">
      <requiredInput href="#_B2407208-7EBC-407C-B5FC-9AB5A51F4CED" />
    </informationRequirement>
    <knowledgeRequirement id="_2B188454-D9A8-412F-A918-6A2FF8702AB7">
      <requiredKnowledge href="#_950C6856-112C-42E6-8602-94E2A45168FA" />
    </knowledgeRequirement>
    <conditional id="_868BAFDC-AF5D-48C0-818F-9E14B36940DF" typeRef="boolean" label="Financial Eligibility">
      <if id="_0BFA0CF5-B193-499F-9122-3EE335512F1E">
        <literalExpression id="_045C55D5-7A3A-41AB-B70C-1C239AFFDFFA" label="Expression Name">
          <text>Calculate Finacial Strength() &gt;3000</text>
        </literalExpression>
      </if>
      <then id="_2220B155-CEE2-4782-B55F-91F292FC1F29">
        <literalExpression id="_15DA176C-F303-432D-A109-E67D52134987" label="Expression Name">
          <text>true</text>
        </literalExpression>
      </then>
      <else id="_65ED8EF8-2D8E-40AA-91E1-657E14F6CCF4">
        <literalExpression id="_4C04B623-3FFC-41B3-AACD-AC906A5F2E6F" label="Expression Name">
          <text>false</text>
        </literalExpression>
      </else>
    </conditional>
  </decision>
  <decision name="Loan Approval" id="_472F2616-1A15-4C0D-9C87-7604902ECF26">
    <variable name="Loan Approval" id="_E4D5A13C-22FA-4BF3-B038-B01D94246214" typeRef="boolean" />
  </decision>
  <businessKnowledgeModel name="Calculate Risk Score" id="_DB91EB6A-9435-4AD7-9E09-6FA9BC1D5B3E">
    <variable name="Calculate Risk Score" id="_334A55E3-0E47-42E7-92C9-24290E7A6F36" typeRef="number" />
    <encapsulatedLogic label="Calculate Risk Score" typeRef="number" id="_412DCDB3-6A62-410A-88C6-939C871AE48B" kind="FEEL">
      <formalParameter id="_976FBF49-CEA6-41A9-B8CA-BFD86A80BF83" name="LoanAppliaction" typeRef="LoanAppliaction" />
      <decisionTable id="_4EEDB242-3FA9-43AA-9423-C4A1ED467824" typeRef="number" hitPolicy="UNIQUE" label="Return">
        <input id="_F7ED1470-39DD-4DE3-88C7-54B1FD72F234">
          <inputExpression id="_66E80F97-6E3E-4919-9B53-C19DA8AB8B59" typeRef="number">
            <text>LoanAppliaction.customer.creditScore</text>
          </inputExpression>
        </input>
        <output id="_48CDF4A6-EE68-4D3D-98F7-F367F162F6A2" />
        <annotation name="Annotations" />
        <rule id="_980E5921-8CED-4A24-BB04-C09417F884D6">
          <inputEntry id="_38016C0A-5D8F-42C7-B0CE-60CFD132907C">
            <text>&lt; 0</text>
          </inputEntry>
          <outputEntry id="_88E198CC-CC61-448A-9223-0A20597163F2">
            <text>0</text>
          </outputEntry>
          <annotationEntry>
            <text>// Your annotations here</text>
          </annotationEntry>
        </rule>
        <rule id="_5D242386-D81B-453F-9AB8-C3D9A7656205">
          <inputEntry id="_3F42D63E-C821-4FAC-811A-C73FC97EFBA8">
            <text>[0 .. 650]</text>
          </inputEntry>
          <outputEntry id="_94441546-4DEE-4788-95EA-D6F32D2E5CC0">
            <text>2</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_B13C1663-8703-42FC-B47F-865DF895B01F">
          <inputEntry id="_A05B637E-23ED-4FA6-96F9-98129B8BC018">
            <text>(650 .. 750]</text>
          </inputEntry>
          <outputEntry id="_D0457DC3-4362-4D3D-8537-1219E41CDD7E">
            <text>3</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_A9201D04-6DD5-4B95-9E50-5DA5C29FCBB3">
          <inputEntry id="_B876DC27-4E29-4C35-A929-76F3DB2EBD73">
            <text>&gt; 750</text>
          </inputEntry>
          <outputEntry id="_38E88BBB-FD43-4252-91E1-0733A26526C6">
            <text>4</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
      </decisionTable>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Finacial Strength" id="_950C6856-112C-42E6-8602-94E2A45168FA">
    <variable name="Calculate Finacial Strength" id="_69090C2E-6CBF-441C-BE8A-06E197589C67" />
    <encapsulatedLogic label="Calculate Finacial Strength" id="_FF9D54AF-7A08-4F11-833B-122831C863FC" kind="FEEL">
      <formalParameter id="_1E753312-5E4E-484F-A867-4E7813D5295B" name="loanAppliaction" typeRef="LoanAppliaction" />
      <context id="_C6077024-057A-43A6-A3D1-034DB2948AAA" label="Return">
        <contextEntry id="_F81CF5D4-5E7F-4E77-9178-FB4E9305AAB1">
          <variable id="_1B6C7F0B-9A1D-45B8-9776-15AC20BEC3E6" name="MontlyIncome" typeRef="number" />
          <literalExpression id="_F3F74058-5D53-4607-B830-A9FC87E653C4" typeRef="number" label="MontlyIncome">
            <text>LoanApplication.financials.monthlyIncome</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_A06DDA5E-E81B-4180-955C-256E79BF5DDC">
          <variable id="_67A25177-3F99-4AB8-AC06-53A1BFF0D968" name="totalIncome" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_60628872-C899-405E-842E-519586D63FB7" typeRef="number" label="totalIncome">
            <text>monthlyIncome + sum(LoanApplication.financials.otherIncomes)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_46DB5C5D-97F4-49CE-BBD3-BFB8153EFE4E">
          <literalExpression id="_56D2C8DB-8DF9-4BC7-9E5C-9FCF68AF7B3B" label="Return">
            <text>totalIncome - LoanApplication.financials.existingEMIs</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <inputData name="LoanAppliaction" id="_B2407208-7EBC-407C-B5FC-9AB5A51F4CED">
    <variable name="LoanAppliaction" id="_E6E2F89E-133A-4263-B846-C0092BC9CCB1" />
