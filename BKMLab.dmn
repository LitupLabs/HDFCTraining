  <decision name="risk category" id="_C1C4CB5B-61C3-4DAC-ADA1-13B49ABB4C37">
    <variable name="risk category" id="_77DA0FE4-D812-4385-8579-F46B9D00A7AA" typeRef="riskcategory" />
    <informationRequirement id="_7EAFD303-343D-4791-A81C-16B29D9B7C4C">
      <requiredInput href="#_E64716F9-8BC7-4FE1-BE32-1B5D0D6364AF" />
    </informationRequirement>
    <knowledgeRequirement id="_DD5D81A9-33DF-4C21-BB8F-D485840DFC4A">
      <requiredKnowledge href="#_05D4BCF0-5BE5-4498-A38E-0D42E6DC7FEE" />
    </knowledgeRequirement>
    <literalExpression id="_4A9B7EB5-DACE-4440-8918-596BFF18D99B" typeRef="riskcategory" label="risk category">
      <text>if calculate risk score() &lt;= 2 then &quot;HIGH&quot; else if calculate risk score() = 3 then &quot;MEDIUM&quot; else &quot;LOW&quot;</text>
    </literalExpression>
  </decision>
  <decision name="financial eligibilty" id="_858A5628-6DDC-41B3-BD59-A128EFFE0291">
    <variable name="financial eligibilty" id="_76A51E2B-0BF8-4793-A45F-6B488F59145C" typeRef="boolean" />
    <informationRequirement id="_A7AF535B-FD91-4D0E-8A21-256E60814DA6">
      <requiredInput href="#_E64716F9-8BC7-4FE1-BE32-1B5D0D6364AF" />
    </informationRequirement>
    <knowledgeRequirement id="_87894526-5FBB-4C2B-B2A6-398901263553">
      <requiredKnowledge href="#_6BD405C9-8FBF-4FED-99D1-AA6F9BF85C13" />
    </knowledgeRequirement>
    <conditional id="_EAF3D1AC-A5FF-472D-ABE1-C885B76E395C" typeRef="boolean" label="financial eligibilty">
      <if id="_AAAF1684-2DF6-4E39-A690-99BC2D0984DB">
        <literalExpression id="_ACF53D76-4A31-4DE3-9AB4-204D8D7B1A2E" label="Expression Name">
          <text>calculate financial strength() &gt; 30000</text>
        </literalExpression>
      </if>
      <then id="_1E72024C-D4A6-46CF-8339-A8D8BE573629">
        <literalExpression id="_CC43709E-4287-4BDF-BEB4-F74A55CC24BF" label="Expression Name">
          <text>true</text>
        </literalExpression>
      </then>
      <else id="_C7031BD5-2906-4B2F-8CF2-570275100F5B">
        <literalExpression id="_910CCC22-1B8D-4980-A399-EC98CD82661C" label="Expression Name">
          <text>false</text>
        </literalExpression>
      </else>
    </conditional>
  </decision>
  <decision name="loan approval" id="_14AF68A8-0969-41BC-A023-DFE188EF9D7F">
    <variable name="loan approval" id="_BCE677C8-1FD0-46E4-B703-92ACE7A4316F" typeRef="boolean" />
    <informationRequirement id="_A25F443A-B044-446E-ADE2-D0B751233894">
      <requiredDecision href="#_C1C4CB5B-61C3-4DAC-ADA1-13B49ABB4C37" />
    </informationRequirement>
    <informationRequirement id="_83AB395B-F76D-4906-A238-00D5727BAB02">
      <requiredDecision href="#_858A5628-6DDC-41B3-BD59-A128EFFE0291" />
    </informationRequirement>
    <conditional id="_3FC0943C-21F4-4DD6-9A71-FFF0CB90685B" typeRef="boolean" label="loan approval">
      <if id="_0278F37E-E51F-406A-9436-CAA4B9BE8B89">
        <literalExpression id="_B8A72F7B-DCB1-4676-93FF-C4C26C66D486" label="Expression Name">
          <text>risk category !=&quot;HIGH&quot; and financial eligibility = true</text>
        </literalExpression>
      </if>
      <then id="_70C192F4-5F93-4B0A-B274-9909512914F7">
        <literalExpression id="_338D84E9-CEEF-4D1E-ADAE-F8ACCE9193B1" label="Expression Name">
          <text>&quot;loan is approved since vyour risk category is not HIGH and financial stats are permissible&quot;</text>
        </literalExpression>
      </then>
      <else id="_0B2F20CB-A9F9-4F93-BCA2-2BE7EA2F81E1">
        <literalExpression id="_CCBA8962-2E0F-458C-8CAC-947FBBA33F8D" label="Expression Name">
          <text>&quot;loan is rejected because your risk category is&quot; + risk category + &quot;and your financial strength is&quot; + financial eligibility</text>
        </literalExpression>
      </else>
    </conditional>
  </decision>
  <businessKnowledgeModel name="calculate risk score" id="_05D4BCF0-5BE5-4498-A38E-0D42E6DC7FEE">
    <variable name="calculate risk score" id="_E9E153F4-343A-4817-9414-8E9DDF1CA2F2" />
    <encapsulatedLogic label="calculate risk score" id="_AE9DF084-BDFD-4A88-BBEB-CB01E0C3641F" kind="FEEL">
      <formalParameter id="_FD8FF624-1882-44BA-BF24-418D1D6B70D4" name="loanapplication" typeRef="loanapplication" />
      <decisionTable id="_1CC3CDB4-C281-409F-98E8-064909290B5D" typeRef="number" hitPolicy="UNIQUE" label="Return">
        <input id="_E3E89053-72AA-49C5-8CA4-14EA0AC646DA">
          <inputExpression id="_9F387215-D80D-42D4-9A74-252F4AC32D28" typeRef="number">
            <text>loanapplication.customer.creditscore</text>
          </inputExpression>
        </input>
        <output id="_667CFA79-6365-4DE5-94BF-A2E2F2558A0C" />
        <annotation name="Annotations" />
        <rule id="_F6030820-B7BC-405D-A21B-9D3256D63FA1">
          <inputEntry id="_96BE1FD8-E542-44A2-A2DA-D1FB65EAADC3">
            <text>&lt; 0</text>
          </inputEntry>
          <outputEntry id="_B40CA608-9548-4037-AAD3-4E81D973107B">
            <text>0</text>
          </outputEntry>
          <annotationEntry>
            <text>// Your annotations here</text>
          </annotationEntry>
        </rule>
        <rule id="_32613997-C99C-4781-96EB-24342353C61D">
          <inputEntry id="_DE7B0B2E-7650-4788-BFB5-F201AE442ABB">
            <text>[0 .. 650]</text>
          </inputEntry>
          <outputEntry id="_B092D7BA-9570-423C-9C6B-55D133863EDF">
            <text>2</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_40CC0DEF-06D7-4E6F-8817-CF919D3BD76D">
          <inputEntry id="_A0792088-125B-4B58-A414-E7B6A1EE6A1B">
            <text>(650 .. 750]</text>
          </inputEntry>
          <outputEntry id="_EE72D5BA-EC3F-451F-B35B-83BECDDA4F90">
            <text>3</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_5CC325E3-C6C6-40BA-8F35-122A072DC319">
          <inputEntry id="_D65E4228-2A21-457C-A912-C7197D6B0BA6">
            <text>&gt; 750</text>
          </inputEntry>
          <outputEntry id="_BA6FE5B2-ECC1-4EB2-869F-2EB2B069F082">
            <text>4</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
      </decisionTable>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="calculate financial strength" id="_6BD405C9-8FBF-4FED-99D1-AA6F9BF85C13">
    <variable name="calculate financial strength" id="_2F2850F0-2752-4B23-BF95-FA85A849E4D2" />
    <encapsulatedLogic label="calculate financial strength" id="_DA29438D-D627-4826-9100-4DD54C78DE9A" kind="FEEL">
      <formalParameter id="_24BDEAE9-C502-4E80-A13E-24D22DB8F115" name="loanapplication" typeRef="loanapplication" />
      <context id="_9AE8445D-19E6-4462-8097-A9EB583B4BCF" label="Return">
        <contextEntry id="_673ACA89-8E86-42EC-B272-1DF174FC8EC4">
          <variable id="_93672166-CC7E-41EB-B774-9E0D8E6F4185" name="monthlyincome" typeRef="number" />
          <literalExpression id="_C529BDBE-F5E5-418D-8909-146A2D39B80B" typeRef="number" label="monthlyincome">
            <text>loanapplication.financials.monthlyincome</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_7E5293D6-E753-44B0-A0DC-5463F8F01AD7">
          <variable id="_E1E1CAC7-43EF-4264-81FF-E734AD0296E1" name="totalincome" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_E0DB2168-DA1E-44B9-B41C-85CAC59B701E" typeRef="number" label="totalincome">
            <text>monthlyincome + sum(loanapplication.financials.collections)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_A0406227-DA0C-43F8-904B-9E4A77104EE4">
          <literalExpression id="_AD3F5CFF-02CE-48DA-AD75-E6DECAF375CE" label="Return">
            <text>totalincome - loanapplication.financials.existingemis</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
  </businessKnowledgeModel>
