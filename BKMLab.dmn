  <decision name="RiskCategory" id="_CCFDA7F8-C998-47E1-83A3-230C08E2FD2F">
    <variable name="RiskCategory" id="_94DC1F70-39C2-400D-A1B9-271DC087C0D1" typeRef="RiskCategory" />
    <informationRequirement id="_F5F78457-5D6E-4518-B49D-F41247AB29FD">
      <requiredInput href="#_19606DF8-EE4B-441A-8E0B-52437B8E0F48" />
    </informationRequirement>
    <knowledgeRequirement id="_A23BAE6E-AA3D-4075-B6D5-C00FBEACFD43">
      <requiredKnowledge href="#_1902B0FB-1216-4BB1-9C88-A7495488A6C9" />
    </knowledgeRequirement>
    <literalExpression id="_266F8C6D-58F7-44FE-A4EB-C0BE249AD9A8" typeRef="RiskCategory" label="RiskCategory">
      <text>if CreditRiskScore() &lt;= 2 then &quot;LOW&quot;
else if CreditRiskScore() = 3 then &quot;MEDIUM&quot;
else &quot;HIGH&quot;</text>
    </literalExpression>
  </decision>
  <decision name="isFinancialEligible" id="_8529F4FE-CF9B-4FA4-8016-8714A3F176AD">
    <variable name="isFinancialEligible" id="_CA660E51-1142-4FE9-99F2-182678F7B3EF" typeRef="boolean" />
    <informationRequirement id="_EA97F086-81D0-41DA-9530-C9EBC40E1C01">
      <requiredInput href="#_19606DF8-EE4B-441A-8E0B-52437B8E0F48" />
    </informationRequirement>
    <knowledgeRequirement id="_F2381D9A-A360-4261-94D1-2AB16A5F4B5A">
      <requiredKnowledge href="#_A88207A4-557D-40B1-83D1-1C04A7D8EE04" />
    </knowledgeRequirement>
    <conditional id="_E7E42BE9-A69C-4A82-9EA4-4643E2884F1C" typeRef="boolean" label="isFinancialEligible">
      <if id="_B8554186-E586-4602-B182-F01ADE60684C">
        <literalExpression id="_B5CD255C-F2AC-4A2A-9590-4D547EA5193F" label="Expression Name">
          <text>CalculateFinancialStrength () &gt; 30000</text>
        </literalExpression>
      </if>
      <then id="_C935731F-152C-4C84-9F6B-CC4699CAAC4A">
        <literalExpression id="_16DC6946-8090-4AD4-AF09-46A5F18F0F83" label="Expression Name">
          <text>true</text>
        </literalExpression>
      </then>
      <else id="_4D74B740-5A9F-4619-A8DA-0AB28E2CA21D">
        <literalExpression id="_BF28DB9F-A424-4812-B5CD-E6B25A2D33C4" label="Expression Name">
          <text>false</text>
        </literalExpression>
      </else>
    </conditional>
  </decision>
  <decision name="LoanApproval" id="_8A30E811-A9BC-4A29-8232-66E3F11947A2">
    <variable id="_8EAA7E67-3146-4CB2-A781-2A74E7E89CB1" typeRef="string" name="LoanApproval" />
    <informationRequirement id="_19301D9D-4285-4EFC-B42F-CF6697ECAA04">
      <requiredDecision href="#_CCFDA7F8-C998-47E1-83A3-230C08E2FD2F" />
    </informationRequirement>
    <informationRequirement id="_495F66FA-4C64-405E-A99E-C2DD00AD5C4C">
      <requiredDecision href="#_8529F4FE-CF9B-4FA4-8016-8714A3F176AD" />
    </informationRequirement>
    <conditional id="_7972845A-C411-4FCB-8924-80550E1EA2FD" typeRef="string" label="LoanApproval">
      <if id="_45BCEE87-35C9-49BF-A0D1-1119D0D375C5">
        <literalExpression id="_4AEEA2AE-CF3A-4E78-8584-6EC8A0B3A108" label="Expression Name">
          <text>RiskCategory != &quot;HIGH&quot; and isFinancialEligible = true</text>
        </literalExpression>
      </if>
      <then id="_9B950CEA-4282-4A84-9197-AC2E7B96E9C9">
        <literalExpression id="_393B1BAC-2F80-4191-A737-F2614F511753" label="Expression Name">
          <text>&quot;Loan is approved&quot;</text>
        </literalExpression>
      </then>
      <else id="_A962857D-4BE3-4E94-85F0-AA192041D0A6">
        <literalExpression id="_719CA8CF-2E9A-4620-97B6-C1FECD237D83" label="Expression Name">
          <text>&quot;Loan rejected due to Risk category is: &quot; + RiskCategory + &quot; FInancialigibility is &quot; + string(isFinancialEligible)</text>
        </literalExpression>
      </else>
    </conditional>
  </decision>
  <businessKnowledgeModel name="CreditRiskScore" id="_1902B0FB-1216-4BB1-9C88-A7495488A6C9">
    <variable name="CreditRiskScore" id="_04C3F33E-9084-4BC7-B8B0-6B00EE0029D1" typeRef="number" />
    <encapsulatedLogic label="CreditRiskScore" typeRef="number" id="_AA6C9EA0-7349-4D9C-82FB-87FC30D8EDF7" kind="FEEL">
      <formalParameter id="_6FC471EE-EC5B-43F4-8532-E0B33B1C4C16" name="LoanApplication" typeRef="LoanApplication" />
      <decisionTable id="_C3C7767C-FEC0-489F-B1BC-3714B6C3BA4B" typeRef="number" hitPolicy="UNIQUE" label="Return">
        <input id="_73B98374-FD08-43AB-A645-56F4B29DF1DE">
          <inputExpression id="_1AC0839A-7607-4881-BF09-4BFE741A683C" typeRef="number">
            <text>LoanApplication.customer.creditScore</text>
          </inputExpression>
        </input>
        <output id="_3F714CCD-3478-4EA6-8B83-0C843629C562" />
        <annotation name="Annotations" />
        <rule id="_3AF5DEDB-4BEE-41FA-B383-8D0190B533D3">
          <inputEntry id="_E95E110C-88B6-4AA9-B1D3-0D36722A1351">
            <text>&lt;0</text>
          </inputEntry>
          <outputEntry id="_30973954-3CBD-4429-9D70-C6D9561012F2">
            <text>0</text>
          </outputEntry>
          <annotationEntry>
            <text>// Your annotations here</text>
          </annotationEntry>
        </rule>
        <rule id="_BA8E9B5D-2216-45B2-9953-54F739DAB232">
          <inputEntry id="_10752D51-D10B-40CC-A196-EACE7D468709">
            <text>[0 .. 650]</text>
          </inputEntry>
          <outputEntry id="_330AA4EF-6C75-4EE3-B880-BE883391D997">
            <text>2</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_87B95C0C-B4A4-4C7A-9A43-2DE5B6C26F72">
          <inputEntry id="_D524F936-EDE9-4805-9B61-1BC2D83E3122">
            <text>(650 .. 750]</text>
          </inputEntry>
          <outputEntry id="_81EF49AB-1A6D-4A7E-9647-0ECBAD3226FA">
            <text>3</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_38F9C275-24DC-494E-9110-D9656DFF8E87">
          <inputEntry id="_9E8D52FF-AC5B-4590-A75A-95124826DC07">
            <text>&gt;750</text>
          </inputEntry>
          <outputEntry id="_39624942-9D7D-46E3-9CC6-D8D2117FC75A">
            <text>4</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
      </decisionTable>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="CalculateFinancialStrength" id="_A88207A4-557D-40B1-83D1-1C04A7D8EE04">
    <variable name="CalculateFinancialStrength" id="_F7263D61-C7D2-44AA-A35D-899179488EF9" typeRef="number" />
    <encapsulatedLogic label="CalculateFinancialStrength" typeRef="number" id="_1C67041C-F646-4DCD-A279-205CB810F30D" kind="FEEL">
      <formalParameter id="_BA040237-261A-47D3-A874-F4BA19424DAF" name="LoanApplication" typeRef="LoanApplication" />
      <context id="_0407722E-AE85-4F6B-9685-B7C3E8751144" typeRef="number" label="Return">
        <contextEntry id="_45376FB4-C37B-4E43-AC78-5224B33FA320">
          <variable id="_597B60EC-7C45-47ED-AAAD-59CB5F9C92D9" name="monthlyIncome" typeRef="number" />
          <literalExpression id="_8133ED17-E6F0-46A9-8E25-A3ED9259D412" typeRef="number" label="monthlyIncome">
            <text>LoanApplication.financials.monthlyIncome</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_4626ACE3-C42E-4B75-AB7B-B5854AE681F4">
          <variable id="_305E6D08-4054-44E1-816F-B9975729EE0E" name="totalIncome" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_746614DF-FA75-432F-A89C-E28466492428" typeRef="number" label="totalIncome">
            <text>monthlyIncome + sum(LoanApplication.financials.otherIncomes)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_B604CF46-29C4-4113-B18F-AE823846346B">
          <literalExpression id="_34A7B1A0-8E9C-42FF-B161-12EAA485F4E4" typeRef="number" label="Return">
            <text>totalIncome - LoanApplication.financials.existingEMIs</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
  </businessKnowledgeModel>
