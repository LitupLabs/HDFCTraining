  <decision name="Risk Category" id="_AB706955-AFE1-4081-8DA6-0D9D9BBFED54">
    <variable name="Risk Category" id="_D37E21E7-D539-4BB8-94A4-E2A1B338718B" typeRef="RiskCategory" />
    <informationRequirement id="_05D1B9B3-75EF-4A15-A321-0D1EED0D0B78">
      <requiredInput href="#_CEC36F80-90A1-4589-85D3-25A21B192F58" />
    </informationRequirement>
    <knowledgeRequirement id="_D35B68E3-0EA4-4E5A-9322-BD75F060E9A1">
      <requiredKnowledge href="#_51F2AB96-6DAC-45CD-8F62-18E7B319AF75" />
    </knowledgeRequirement>
    <literalExpression id="_4EE47AD7-0D3C-4708-AD09-9EB5947EEFC9" typeRef="RiskCategory" label="Risk Category">
      <text>if Calculate Risk Score() &lt;= 2 then &quot;HIGH&quot; else if Calculate Risk Score() = 3 then &quot;MEDIUM&quot; else &quot;LOW&quot;</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="Calculate Risk Score" id="_51F2AB96-6DAC-45CD-8F62-18E7B319AF75">
    <variable name="Calculate Risk Score" id="_24E39A8A-3524-4540-87A3-D37B96C1E2AF" typeRef="number" />
    <encapsulatedLogic label="Calculate Risk Score" typeRef="number" id="_84A56428-F80E-4D9B-9C61-A476386F0D74" kind="FEEL">
      <formalParameter id="_4B3B713E-11AA-46BD-B2FD-6A626A3670BD" name="LoanApplication" typeRef="LoanApplication" />
      <decisionTable id="_248D97D6-F3E7-4862-BFBA-194CBBAC89CD" typeRef="number" hitPolicy="UNIQUE" label="Return">
        <input id="_A610258C-6B57-4ECA-B77D-457E2B8C4E5A">
          <inputExpression id="_E8765D27-BB41-4E88-A7A9-4E95EC1C740B" typeRef="number">
            <text>LoanApplication.customer.creditScore</text>
          </inputExpression>
        </input>
        <output id="_DFD16394-D90D-46BA-BE8D-531A5BDD40F5" />
        <annotation name="Annotations" />
        <rule id="_972CED08-CD2C-4A9B-96CF-D82F17D095F0">
          <inputEntry id="_DEEC3F7F-7FDD-4B07-9C6F-E65B227C7AA6">
            <text>&lt; 0</text>
          </inputEntry>
          <outputEntry id="_B6FBCA7A-AD03-4B6C-BB6C-DD300703C0BB">
            <text>0</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_BE1BF8C2-9848-4985-AE56-23FBE6E0192E">
          <inputEntry id="_03CF83DC-EEC7-4F2F-A00A-F8DEF609D626">
            <text>[0 .. 650]</text>
          </inputEntry>
          <outputEntry id="_7E1CD738-04D7-447D-8C3B-603C53150B36">
            <text>2</text>
          </outputEntry>
          <annotationEntry>
            <text>// Your annotations here</text>
          </annotationEntry>
        </rule>
        <rule id="_EE6ED860-D185-424B-9801-5651C2DA0349">
          <inputEntry id="_D14A8B4C-09B9-4429-BFF0-1F914381CCA9">
            <text>(650 .. 750]</text>
          </inputEntry>
          <outputEntry id="_941D114B-3281-443F-8CEF-89842627CC91">
            <text>3</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_4A47D63D-DCDC-4ACD-A9F1-B6BA01058CA9">
          <inputEntry id="_29AADC71-F6FF-47A0-820F-BBF88C5E3B30">
            <text>&gt; 750</text>
          </inputEntry>
          <outputEntry id="_14C7E4E6-FFD1-4942-A774-41C5A908D72A">
            <text>4</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
      </decisionTable>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Financial Strength" id="_5CE0153E-AFFC-4E2A-A418-237A6B9CEAC6">
    <variable name="Calculate Financial Strength" id="_1C63D41C-3816-4955-A224-91375048CEC5" typeRef="number" />
    <encapsulatedLogic label="Calculate Financial Strength" typeRef="number" id="_48E14B4C-F9E8-4BE2-BD50-3C3D6AC607EF" kind="FEEL">
      <formalParameter id="_CDAB1399-3771-4FEA-A4AC-888E0FB8604B" name="LoanApplication" typeRef="LoanApplication" />
      <context id="_AA2F7398-9E99-4A4C-BC6D-ABF239FA66E1" typeRef="number" label="Return">
        <contextEntry id="_1FEA1D95-14E6-4848-B567-7A61B3CC5230">
          <variable id="_DBA90BB0-1A0F-40E9-A326-BE1D80490586" name="monthlyIncome" typeRef="number" />
          <literalExpression id="_0E025932-F1A6-4AD9-9E40-8F09F4EA9096" typeRef="number" label="monthlyIncome">
            <text>LoanApplication.financials.monthlyIncome</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_BF8902D5-1D47-479E-869C-4A29BFC1FE47">
          <variable id="_EAD04C66-B3C1-4AA3-9757-6FEC69A0D8C8" name="totalIncome" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_510FABB7-C006-4BF1-A4BE-69CBCA8995A8" typeRef="number" label="totalIncome">
            <text>monthlyIncome + sum(LoanApplication.financials.otherIncomes)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_C60FABEA-80F1-4574-8A97-D5AE17405BAD">
          <literalExpression id="_4805C76F-1EDC-4CA9-95F8-2BC7933C8C2B" typeRef="number" label="Return">
            <text>totalIncome - LoanApplication.financials.existingEMIs</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <inputData name="LoanApplication" id="_CEC36F80-90A1-4589-85D3-25A21B192F58">
    <variable name="LoanApplication" id="_0C2171B4-AC62-4E4E-90A0-67580E20501E" typeRef="LoanApplication" />
