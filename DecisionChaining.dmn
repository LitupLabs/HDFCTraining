  <decision name="EMI Ratio" id="_2B2424AF-66A1-4242-A8C8-A362E8BB16DB">
    <variable name="EMI Ratio" id="_78F3EAD4-D5F4-401B-BD92-7AC51992FA74" typeRef="number" />
    <informationRequirement id="_A0A83D7D-D94D-490B-A7F3-A42888B54DAB">
      <requiredInput href="#_83A12C82-B151-456C-BEC8-D019ABFDF870" />
    </informationRequirement>
    <informationRequirement id="_631D275E-8558-4A1B-9244-DEDE4117F81F">
      <requiredDecision href="#_217F8B81-E1CF-45A4-9021-CA0274D8600C" />
    </informationRequirement>
    <literalExpression id="_0DD53F83-E2D7-47C0-970A-6946DEB58E70" typeRef="number" label="EMI Ratio">
      <text>LoanApplication.financials.existingEMIs / Total Income</text>
    </literalExpression>
  </decision>
  <decision name="Total Income" id="_217F8B81-E1CF-45A4-9021-CA0274D8600C">
    <variable name="Total Income" id="_71DEDCE3-5434-4649-94D5-5714CB36958C" typeRef="number" />
    <informationRequirement id="_400313CD-59F0-4499-86CE-F62414D6E4C4">
      <requiredInput href="#_83A12C82-B151-456C-BEC8-D019ABFDF870" />
    </informationRequirement>
    <literalExpression id="_94DB1A99-F9D6-4A2D-AB43-7BD58D1699BD" typeRef="number" label="Total Income">
      <text>LoanApplication.financials.monthlyIncome + sum(LoanApplication.financials.otherIncomes)</text>
    </literalExpression>
  </decision>
