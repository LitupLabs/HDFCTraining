  <decision name="Total Income" id="_B72925F7-106F-4133-A6E8-736D0BE40F3C">
    <variable name="Total Income" id="_30705B78-1CAF-49D0-9393-3CBAAAB472A2" typeRef="number" />
    <informationRequirement id="_5A60EFE6-4BDA-4571-AD02-105E1BD43550">
      <requiredInput href="#_490DE456-F5B2-4E6E-A53B-1A0EC1F2C8D6" />
    </informationRequirement>
    <literalExpression id="_0278338E-27F4-4947-B1F0-88C418D3568D" typeRef="number" label="Total Income">
      <text>LoanApplication.financials.monthlyIncome + sum(LoanApplication.financials.otherIncomes)</text>
    </literalExpression>
  </decision>
  <decision name="EMI Ration" id="_A3F3CC4F-3222-4F71-AE45-7B21AFB1D9B2">
    <variable name="EMI Ration" id="_C54C0FCD-F512-4C41-B2FA-DEA78E067044" typeRef="number" />
    <informationRequirement id="_FECDAE93-11AA-439D-AF68-1CDD771390D6">
      <requiredInput href="#_490DE456-F5B2-4E6E-A53B-1A0EC1F2C8D6" />
    </informationRequirement>
    <informationRequirement id="_CCB8611F-D9CC-406E-A0DC-D958401C9A7E">
      <requiredDecision href="#_B72925F7-106F-4133-A6E8-736D0BE40F3C" />
    </informationRequirement>
    <literalExpression id="_7B908C72-F93D-4CE8-B899-2E7689820871" typeRef="number" label="EMI Ration">
      <text>LoanApplication.financials.existingEMIs / Total Income</text>
    </literalExpression>
  </decision>
  <decision name="Risk Category" id="_0AC24382-2427-4E6F-9AD0-727C666F07DF">
    <variable name="Risk Category" id="_1AD808B2-1A45-4EC1-8354-6EA15934FE98" typeRef="RiskCategory" />
    <informationRequirement id="_636C5978-0B51-4DBF-B25F-532AA16BB8EB">
      <requiredDecision href="#_A3F3CC4F-3222-4F71-AE45-7B21AFB1D9B2" />
    </informationRequirement>
    <decisionTable id="_A9D32B4C-700A-46CC-97FC-4BF498F05739" typeRef="RiskCategory" hitPolicy="RULE ORDER" label="Risk Category">
      <input id="_7F84C10C-027B-43AF-B3B0-23C0609FD49A">
        <inputExpression id="_10491F23-D7C0-4E02-9CB6-701C5EAF2DAD" typeRef="number">
          <text>EMI Ration</text>
        </inputExpression>
      </input>
      <output id="_219FF7FC-8191-4BCD-B9CE-9947B09AA415" typeRef="RiskCategory" />
      <annotation name="Annotations" />
      <rule id="_2659BE9E-1C87-411C-BAB9-C1590A2C2348">
        <inputEntry id="_1542AA5D-35D0-4FC1-8D70-B99B1DCCBEFE">
          <text>&lt;= .3</text>
        </inputEntry>
        <outputEntry id="_73043898-FEA4-476A-B723-44DBD236F5FD">
          <text>&quot;LOW&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text>// Your annotations here</text>
        </annotationEntry>
      </rule>
      <rule id="_8CAA2EBA-B726-448C-8383-03CAB5640E3F">
        <inputEntry id="_BFA0DE72-2FCE-4C2F-9065-24F4E59EC359">
          <text>(.3 .. .5]</text>
        </inputEntry>
        <outputEntry id="_4AC6717A-F48D-4AF2-93AC-4A3438089ECE">
          <text>&quot;MEDIUM&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
      <rule id="_07580F88-B479-4FFB-8593-30F08F7913BB">
        <inputEntry id="_43DB9E5F-6C0C-4543-8B25-77316D85563F">
          <text>&gt; .41</text>
        </inputEntry>
        <outputEntry id="_69DF65E1-4A54-4A7B-9F9B-B8B9C97AB7BD">
          <text>&quot;HIGH&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
    </decisionTable>
  </decision>
