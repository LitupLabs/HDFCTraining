  <decision name="NumOfLiveTrades" id="_C6161D11-AC99-40EF-823E-75C4438500B1">
    <variable name="NumOfLiveTrades" id="_CAEA294B-4B01-451E-A728-CC97A12402D9" typeRef="string" />
    <informationRequirement id="_902FB004-2736-4856-A5FA-14B78882A4CC">
      <requiredInput href="#_995D532E-751A-45C4-B549-5F0037B4EF3F" />
    </informationRequirement>
    <literalExpression id="_80288D0E-CFE6-48DA-B522-3B8869FA5662" typeRef="string" label="NumOfLiveTrades">
      <text>count(
      for t in tbl_tradelines return 
        IsLiveDate(t.tl_closed_date)   
       )                                     
</text>
    </literalExpression>
  </decision>
  <decision name="cntOfUnSecureLiveLoan" id="_9E97FA08-4F33-4EBC-B5EA-D8853DA36EA9">
    <variable name="cntOfUnSecureLiveLoan" id="_B395F99A-4D19-47C1-BAEB-5663903BFD80" typeRef="TradeLine" />
    <informationRequirement id="_F9E90224-238C-44B5-9B2F-4D32FB053C21">
      <requiredInput href="#_995D532E-751A-45C4-B549-5F0037B4EF3F" />
    </informationRequirement>
    <literalExpression id="_BCEA1BAE-2973-4EE5-A229-85A48E876FA4" typeRef="TradeLine" label="cntOfUnSecureLiveLoan">
      <text>		
count(
      for t in tbl_tradelines return
	  ( IsUnsecured(tl_acct_type) = true 
         and IsLive(t.tl_closed_date)   
       )                                     
)</text>
    </literalExpression>
  </decision>
  <decision name="totalBureauOverDue" id="_F884F5AE-EA83-4FBE-9A6B-8787E6EA67B6">
    <variable name="totalBureauOverDue" id="_1B684CE3-2FBD-411B-B6BF-D5E3FD2FA3C0" typeRef="tbl_tradelines" />
    <informationRequirement id="_A6D40A60-57A1-4FBC-B806-D078F32A999D">
      <requiredInput href="#_995D532E-751A-45C4-B549-5F0037B4EF3F" />
    </informationRequirement>
    <literalExpression id="_19FD2B78-FBD2-4ED5-B407-D514FF3199E5" typeRef="tbl_tradelines" label="totalBureauOverDue">
      <text>sum( for t in tbl_tradelines return t.t1_overdue_amount)</text>
    </literalExpression>
  </decision>
