  <decision name="total income" id="_7B7A56AD-8A5E-40C5-B838-74CA0319B7EF">
    <variable name="total income" id="_601E8F24-D12E-46BB-9113-2674AB88A6FB" typeRef="number" />
    <informationRequirement id="_D0A4F7DD-CE3B-4C20-90FA-DC54E2C4936F">
      <requiredInput href="#_60B24732-1A75-4EA6-846E-24E60A1C8C9A" />
    </informationRequirement>
    <literalExpression id="_C883BF85-6A51-4782-A903-7F1639804037" typeRef="number" label="total income">
      <text>loanapplication.financials.monthlyincome + sum(loanapplication.financials.otherincome)</text>
    </literalExpression>
  </decision>
  <decision name="emi ratio" id="_8E5FD4D3-3669-4019-9F4B-CCDF1C92562C">
    <variable name="emi ratio" id="_DAAFDFC0-CA03-44FA-ABF0-A07C65087965" />
    <informationRequirement id="_11FCD31E-45CD-4E50-8FA5-3516383CA16B">
      <requiredInput href="#_60B24732-1A75-4EA6-846E-24E60A1C8C9A" />
    </informationRequirement>
    <informationRequirement id="_16AFD1FB-1DDA-4A4A-AC57-34EE3F41D88F">
      <requiredDecision href="#_7B7A56AD-8A5E-40C5-B838-74CA0319B7EF" />
    </informationRequirement>
    <literalExpression id="_F7E75B2A-AB93-4B46-A788-8C18A3BC670D" label="emi ratio">
      <text>loanapplication.financials.existingEMIs / total income</text>
    </literalExpression>
  </decision>
  <decision name="risk category" id="_9539BC80-1F86-49ED-B096-4AF0560F4803">
    <variable name="risk category" id="_7FF71673-F213-4A56-8591-463A756E3F60" />
    <informationRequirement id="_966BA4EC-AC07-4306-8A75-A81650C80A76">
      <requiredDecision href="#_8E5FD4D3-3669-4019-9F4B-CCDF1C92562C" />
    </informationRequirement>
    <decisionTable id="_84C7C051-7D01-4429-9697-07C4A9CA3A0F" hitPolicy="UNIQUE" label="risk category">
      <input id="_CBF6817D-F02B-47F1-9AF3-C54EF1BBC587">
        <inputExpression id="_2846C062-2857-4FD5-8424-02CCD3528599">
          <text>emi ratio</text>
        </inputExpression>
      </input>
      <output id="_EBE23744-9E90-4EA9-A054-DAE6524EA95E" />
      <annotation name="Annotations" />
      <rule id="_DBCF8FDA-7644-4042-AC9C-F592E1A9F098">
        <inputEntry id="_0D3AE797-E136-4397-84F1-E06F1EDBCE8C">
          <text>&lt;= .3</text>
        </inputEntry>
        <outputEntry id="_06BF79E3-0229-4B47-AAF0-70BD737559E5">
          <text>&quot;LOW&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text>// Your annotations here</text>
        </annotationEntry>
      </rule>
      <rule id="_1D256D1D-929C-46E8-A589-F9B03427576E">
        <inputEntry id="_7E1FF765-9787-49E8-9BD2-8D47DC3F2A42">
          <text>(.3 .. .5]</text>
        </inputEntry>
        <outputEntry id="_4E73117F-56E4-4DE4-8CC2-62C1CEA2F74D">
          <text>&quot;MEDIUM&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
      <rule id="_5B5A1656-551D-43BC-8850-D41627C51E35">
        <inputEntry id="_255151C2-77E1-4E87-9AEC-116EDAD1A74E">
          <text>&gt; .5</text>
        </inputEntry>
        <outputEntry id="_0BEFC6A6-09E2-462D-B068-BB028CDA315D">
          <text>&quot;HIGH&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
    </decisionTable>
  </decision>
