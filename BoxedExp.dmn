  <decision name="EMIsLst" id="_0085B809-1220-42C2-B2D2-CFBD73160E6E">
    <variable name="EMIsLst" id="_05CEA7EE-2039-478A-8A40-C3FB5BB352CC" typeRef="EMIs" />
    <informationRequirement id="_3D2A1607-E278-45C9-8B9E-1AB3790EF165">
      <requiredInput href="#_E20652AB-5296-426C-A085-EBE57E31BA6F" />
    </informationRequirement>
    <list id="_47236BC9-CF3F-41D7-AFF7-1A450F772CDD" label="EMIsLst" typeRef="EMIs">
      <literalExpression id="_245B7ED0-8304-4D88-B6AB-623264C8463B" typeRef="EMIs" label="Expression Name">
        <text>for emi in LoanApplication.loans.emi return emi</text>
      </literalExpression>
    </list>
  </decision>
  <decision name="totalAmount" id="_336822AF-99DE-4A88-8E71-4AEE89CF8A4C">
    <variable id="_B18E02B1-56F7-4279-9984-9D1AD94A77D7" typeRef="Totalamount" name="totalAmount" />
    <informationRequirement id="_8249F8C5-04D9-4CDB-A214-8A2DD0FDAA7E">
      <requiredInput href="#_E20652AB-5296-426C-A085-EBE57E31BA6F" />
    </informationRequirement>
    <for id="_446C16CC-C2ED-44C5-98AF-A64C715E7D7B" typeRef="Totalamount" label="totalAmount" iteratorVariable="loan">
      <in id="_FA27C032-67CA-42B1-BAB3-1095BE9DC790">
        <literalExpression id="_3B5AE9B5-673F-4AB1-A437-E74B29B4C8FC" label="Expression Name">
          <text>LoanApplication.loans</text>
        </literalExpression>
      </in>
      <return id="_AB793FD8-801B-4D0B-A4CC-F3DF8364EE59">
        <literalExpression id="_7808117E-1CF1-4031-B21A-DD13420A4EBB" label="Expression Name">
          <text>loan.emi * loan.tenure</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="EMIsCalculation" id="_7EA59B26-F0E2-45D5-B357-65F939468451">
    <variable name="EMIsCalculation" id="_E48DBD07-B753-41FB-B4EA-52940EEC9BDF" typeRef="EMIs" />
    <informationRequirement id="_70E2635F-19E3-43B6-9A6E-2695DB525F4E">
      <requiredDecision href="#_0085B809-1220-42C2-B2D2-CFBD73160E6E" />
    </informationRequirement>
    <literalExpression id="_35B9CD0E-A3C2-4163-A2C5-C005775C5DD0" typeRef="EMIs" label="EMIsCalculation">
      <text>for emi in EMIsLst return emi</text>
    </literalExpression>
  </decision>
  <decision name="HighValueLoans" id="_5622D94D-7AF1-45EF-BDAF-D337667E4336">
    <variable name="HighValueLoans" id="_0A7299F2-3940-4DCB-B5AD-A0B5614C6EC6" typeRef="Loan" />
    <informationRequirement id="_A8961FBA-43AD-4F68-91C9-F1FC36C90506">
      <requiredInput href="#_E20652AB-5296-426C-A085-EBE57E31BA6F" />
    </informationRequirement>
    <filter id="_1B18C261-6E41-4145-8DF6-AFC37F2A9A07" typeRef="Loan" label="HighValueLoans">
      <in id="_AA3CE260-10B6-4F20-9748-7ACBC8DEC990">
        <literalExpression id="_B966E0DA-33CB-4BCE-AF0B-4E746FBF0C66" label="Expression Name">
          <text>LoanApplication.loans</text>
        </literalExpression>
      </in>
      <match id="_B8BD7BB6-0287-443B-A6C6-D14974044FBB">
        <literalExpression id="_6BCC277E-D9AA-402D-BAA2-1E7C36A865C8" label="Expression Name">
          <text>item.emi &gt; 200</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <decision name="atLeastHighValueLoan" id="_34DB5281-A9E4-4391-AE8D-41F02E637506">
    <variable name="atLeastHighValueLoan" id="_82F8F575-29FE-4214-AFC2-B726E4FEBB2E" typeRef="boolean" />
    <informationRequirement id="_383D2B2B-6669-49BB-93E0-4AEAA74B7AEE">
      <requiredDecision href="#_5622D94D-7AF1-45EF-BDAF-D337667E4336" />
    </informationRequirement>
    <some id="_E87E2AB8-494B-4774-8A37-7D8B1115A032" typeRef="boolean" label="atLeastHighValueLoan" iteratorVariable="loan">
      <in id="_AED84818-50A0-42B0-8A02-AF54E910AE3E">
        <literalExpression id="_F0E5746F-51C2-4265-8C1C-1AA6EBAC0879" label="Expression Name">
          <text>HighValueLoans</text>
        </literalExpression>
      </in>
      <satisfies id="_71D6816A-6EEC-4CFB-A6B2-E2D2F25B1646">
        <literalExpression id="_84D3BF17-A73D-4D5C-B233-725E6978DC33" label="Expression Name">
          <text>loan.emi &gt; 200 and loan.tenure &gt; 5</text>
        </literalExpression>
      </satisfies>
    </some>
  </decision>
  <decision name="cntHighValueEMI" id="_24A1081C-AF86-49BD-92E5-8CD0A43A0F6F">
