    </informationRequirement>
    <for id="_C321CF13-0048-4A56-B224-9AA9922A4933" typeRef="Totalamount" label="TotalAmount" iteratorVariable="loan">
      <in id="_501D9103-FE03-4EB0-BD0F-E58129BF8EA6">
        <literalExpression id="_A0270A85-6F16-4245-9A1D-91EADD258657" label="Expression Name">
          <text>Loanapplication.loans</text>
        </literalExpression>
      </in>
      <return id="_3B42F7E9-034D-4A00-9937-97607BAFDB62">
        <literalExpression id="_76B23457-A595-488B-A332-873A7C8E81D9" label="Expression Name">
