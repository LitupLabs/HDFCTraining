    </informationRequirement>
    <literalExpression id="_223F7BFB-0AFE-4B75-BB5C-67B18813168B" typeRef="number" label="cntHighValueEMI">
      <text>count(HighValueLoans)</text>
    </literalExpression>
  </decision>
