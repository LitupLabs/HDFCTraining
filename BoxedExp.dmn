  <decision name="EMIsLst" id="_0085B809-1220-42C2-B2D2-CFBD73160E6E">
    <variable name="EMIsLst" id="_05CEA7EE-2039-478A-8A40-C3FB5BB352CC" typeRef="EMIs" />
    <informationRequirement id="_3D2A1607-E278-45C9-8B9E-1AB3790EF165">
      <requiredInput href="#_E20652AB-5296-426C-A085-EBE57E31BA6F" />
    </informationRequirement>
    <list id="_47236BC9-CF3F-41D7-AFF7-1A450F772CDD" label="EMIsLst" typeRef="EMIs">
      <literalExpression id="_245B7ED0-8304-4D88-B6AB-623264C8463B" typeRef="EMIs" label="Expression Name">
        <text>for emi in LoanApplication.loans.emi return emi</text>
      </literalExpression>
    </list>
  </decision>
  <decision name="totalAmount" id="_336822AF-99DE-4A88-8E71-4AEE89CF8A4C">
    <variable id="_B18E02B1-56F7-4279-9984-9D1AD94A77D7" typeRef="Totalamount" name="totalAmount" />
    <informationRequirement id="_8249F8C5-04D9-4CDB-A214-8A2DD0FDAA7E">
      <requiredInput href="#_E20652AB-5296-426C-A085-EBE57E31BA6F" />
    </informationRequirement>
    <for id="_446C16CC-C2ED-44C5-98AF-A64C715E7D7B" typeRef="Totalamount" label="totalAmount" iteratorVariable="loan">
      <in id="_FA27C032-67CA-42B1-BAB3-1095BE9DC790">
        <literalExpression id="_3B5AE9B5-673F-4AB1-A437-E74B29B4C8FC" label="Expression Name">
          <text>LoanApplication.loans</text>
        </literalExpression>
      </in>
      <return id="_AB793FD8-801B-4D0B-A4CC-F3DF8364EE59">
        <literalExpression id="_7808117E-1CF1-4031-B21A-DD13420A4EBB" label="Expression Name">
          <text>loan.emi * loan.tenure</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="EMIsCalculation" id="_7EA59B26-F0E2-45D5-B357-65F939468451">
    <variable name="EMIsCalculation" id="_E48DBD07-B753-41FB-B4EA-52940EEC9BDF" typeRef="EMIs" />
    <informationRequirement id="_70E2635F-19E3-43B6-9A6E-2695DB525F4E">
      <requiredDecision href="#_0085B809-1220-42C2-B2D2-CFBD73160E6E" />
    </informationRequirement>
    <literalExpression id="_35B9CD0E-A3C2-4163-A2C5-C005775C5DD0" typeRef="EMIs" label="EMIsCalculation">
      <text>for emi in EMIsLst return emi * 1.1</text>
    </literalExpression>
  </decision>
