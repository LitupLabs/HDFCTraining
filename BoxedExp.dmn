    </informationRequirement>
    <list id="_3B2168A5-1771-40E6-B3AD-565424ABD2F2" typeRef="EMI" label="EMIsList">
      <literalExpression id="_7B8027BB-A5AE-4535-A7B9-D1452D2219D8" typeRef="EMI" label="Expression Name">
        <text>for emi in Loanapplication.loans.emi return emi</text>
