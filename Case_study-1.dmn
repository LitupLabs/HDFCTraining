  <decision name="totalBureauOverDue" id="_FE9A31CE-5C45-4448-83BE-C07F26B46BD8">
    <variable name="totalBureauOverDue" id="_C871D6DC-F8AE-49FD-94E6-6B176302B7C0" typeRef="number" />
    <informationRequirement id="_E6A9FE53-6471-44AA-A155-55F8576044FB">
      <requiredInput href="#_4E424C55-6A42-4349-84BC-84334D228350" />
    </informationRequirement>
    <context id="_4A580D2E-6E65-4449-93A7-76D418EBB6E5" typeRef="number" label="totalBureauOverDue">
      <contextEntry id="_57F84E00-5640-4503-A4BB-F077D9220545">
        <variable id="_2F9CEEC6-33A4-4CC4-952C-341AEBCC5BF3" name="for_loop" typeRef="overdue" />
        <for id="_B7048F09-CA40-450C-883E-A880DBEB6FF8" typeRef="overdue" label="for_loop" iteratorVariable="o">
          <in id="_F87D46F7-D748-43D4-BBAA-5AF56A9E60F6">
            <literalExpression id="_FD2D3F98-AE6A-40B1-84A3-C087E819EA1C" label="Expression Name">
              <text>tradeline</text>
            </literalExpression>
          </in>
          <return id="_FBAFE321-67EC-4E90-A825-C24D0FC88BE2">
            <literalExpression id="_695C52BD-AD6B-4366-B14D-34FD65F7FEFF" label="Expression Name">
              <text>if o.tl_overdue_amount = null then 0 else o.tl_overdue_amount</text>
            </literalExpression>
          </return>
        </for>
      </contextEntry>
      <contextEntry id="_A4F8DFB3-0521-44D4-A1B1-68055BAEE31E">
        <literalExpression id="_6141BDFE-BCE2-4D7F-9739-07A155D912F5" typeRef="number" label="totalBureauOverDue">
          <text>sum(for_loop)</text>
        </literalExpression>
      </contextEntry>
    </context>
  </decision>
