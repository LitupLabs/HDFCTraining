  <decision name="Risk Category" id="_DA7B136D-FF98-4886-B049-684BEB7C1E36">
    <variable name="Risk Category" id="_E6D03BB8-2F63-4181-9204-7D8A49D7B4C4" typeRef="RiskCategory" />
    <informationRequirement id="_2D5E7F18-6D30-4CC7-806D-6CD3946C5372">
      <requiredInput href="#_77F93F92-0068-4B38-885A-9B6F14CB8388" />
    </informationRequirement>
    <knowledgeRequirement id="_33747ED1-2653-4AA5-AC56-4FFB8BA99362">
      <requiredKnowledge href="#_4EB231EE-3AE7-4164-AB46-1531226425BA" />
    </knowledgeRequirement>
    <literalExpression id="_A3286AAF-8AF5-483A-BF97-4B62CAF45E0F" typeRef="RiskCategory" label="Risk Category">
      <text>if Calculate Risk Score() &lt;= 2 then &quot;HIGH&quot; else if Calculate Risk Score() = 3 then &quot;MEDIUM&quot; else &quot;LOW&quot;
 </text>
    </literalExpression>
  </decision>
  <decision name="Financial Eligibility" id="_56A2CA26-11F6-440E-BCFC-624AA32C7F20">
    <variable name="Financial Eligibility" id="_7BD1F24D-38AC-4459-9D93-62BF8815FBD0" typeRef="boolean" />
    <informationRequirement id="_3E9C3E57-8692-4DEC-8B38-0CD698BE726F">
      <requiredInput href="#_77F93F92-0068-4B38-885A-9B6F14CB8388" />
    </informationRequirement>
    <knowledgeRequirement id="_19B22B52-0E89-43F6-A3CD-89C7351415DA">
      <requiredKnowledge href="#_A5C3F4A6-613D-46B4-8981-52D1290D24CA" />
    </knowledgeRequirement>
    <conditional id="_DECE93CC-B6D2-4B0B-BEE6-33FBB7C2D16E" typeRef="boolean" label="Financial Eligibility">
      <if id="_60CA5B1D-EC6C-4B14-8677-98F79D3AA26F">
        <literalExpression id="_C213F5DE-241D-4388-81F7-2D356387A58C" label="Expression Name">
          <text>Calculate Financial strength()&gt;30000</text>
        </literalExpression>
      </if>
      <then id="_D4EAADBF-703D-4019-A7D4-C197B989FE80">
        <literalExpression id="_5252206E-657F-4477-96FE-C503836ED143" label="Expression Name">
          <text>True</text>
        </literalExpression>
      </then>
      <else id="_59E9A35B-A89D-4379-B3F6-AD934E1A4803">
        <literalExpression id="_AF5E3561-27E4-4685-8B44-C274119AB916" label="Expression Name">
          <text>false</text>
        </literalExpression>
      </else>
    </conditional>
  </decision>
  <decision name="LoanApproval" id="_29EFA9AE-4137-483E-BF71-2E8C00B11A94">
    <variable name="LoanApproval" id="_18CE412E-E49D-4264-BB25-5E197E56E9B7" typeRef="string" />
    <informationRequirement id="_5A6CEE5F-B873-4B49-9F72-B40E8EDC5194">
      <requiredDecision href="#_56A2CA26-11F6-440E-BCFC-624AA32C7F20" />
    </informationRequirement>
    <informationRequirement id="_20849DF0-645D-4AC7-85A4-A4AEEDCBF7AA">
      <requiredDecision href="#_DA7B136D-FF98-4886-B049-684BEB7C1E36" />
    </informationRequirement>
    <conditional id="_7A27BB07-6B54-4B4D-A3E8-27AF5F00AFAA" typeRef="string" label="LoanApproval">
      <if id="_3F8325FC-6E5B-4DEA-8D23-C4EF1E829A25">
        <literalExpression id="_23C0D219-A300-4A1A-A7E6-8513D79544C8" label="Expression Name">
          <text>Risk Category !=&apos;HIGH&apos; and Financial Eligibility=true</text>
        </literalExpression>
      </if>
      <then id="_EDC46AFB-3C8B-43D1-8F97-9BEC3853C73E">
        <literalExpression id="_B6D8AD90-13E8-4032-B4B6-CDDE9B87A7E7" label="Expression Name" />
      </then>
      <else id="_DF57977C-7EC0-45A3-9CCE-FF5B18367F94" />
    </conditional>
  </decision>
